---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
}

const { title = 'Inari Global Foods | 頂級海膽供應鏈專家' } = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "稻荷環球食品 | Inari Global Foods",
  "url": "https://inariglobal.com",
  "description": "香港和澳門領先的海膽和三文魚供應商，提供來自日本、挪威、加拿大等全球頂級產區的優質海鮮。",
  "areaServed": ["香港", "澳門", "Hong Kong", "Macau"],
  "priceRange": "$$$",
  "servesCuisine": ["日本料理", "海鮮", "刺身"],
  "telephone": "+852-XXXX-XXXX",
  "email": "info@inariglobal.com"
};
---

<!doctype html>
<html lang="zh-Hant" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+TC:wght@300;500;700&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
	</head>
	<body>
		<slot />
		<ChatWidget />
	</body>
</html>
