---
interface Props {
  active: 'dashboard' | 'orders' | 'products' | 'knowledge';
}
const { active } = Astro.props;

function navCls(key: string) {
  return `navitem${active === key ? ' active' : ''}`;
}
---

<aside class="admin-side">
  <!-- Brand -->
  <div class="brand">
    <div class="mark" style="background:var(--sea);color:var(--paper)">稻</div>
    <div>
      <div style="font-weight:700;font-size:14px">稻荷後台</div>
      <div style="font-size:10px;font-family:var(--mono);color:oklch(70% 0.01 240);margin-top:1px">MANAGER · 管理中心</div>
    </div>
  </div>

  <!-- Nav -->
  <div class="sect">管理</div>
  <a href="/admin/" class={navCls('dashboard')} style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    總覽
  </a>
  <a href="/admin/orders" class={navCls('orders')} style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h6a2 2 0 0 1 2 2v14l-5-2-5 2V6a2 2 0 0 1 2-2z"/></svg>
    訂單管理
  </a>
  <a href="/admin/products" class={navCls('products')} style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h12l4 4v12H4z"/><path d="M8 12h8M8 16h5M8 8h4"/></svg>
    商品管理
  </a>
  <a href="/admin/knowledge" class={navCls('knowledge')} style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    知識庫
  </a>

  <div class="sect" style="margin-top:8px">員工入口</div>
  <a href="/shop/admin/orders" class="navitem" style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
    員工訂單管理
  </a>
  <a href="/shop" class="navitem" style="text-decoration:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11 12 4l8 7v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z"/></svg>
    返回商城
  </a>

  <!-- User footer -->
  <div style="margin-top:auto;padding:14px 10px;display:flex;align-items:center;gap:10px">
    <div style="width:32px;height:32px;border-radius:50%;background:var(--sea);color:white;display:grid;place-items:center;font-weight:700;flex-shrink:0" id="admin-avatar">M</div>
    <div>
      <div style="font-size:12px;font-weight:600" id="admin-name">管理員</div>
      <div style="font-size:10px;color:oklch(70% 0.01 240);font-family:var(--mono)">MANAGER</div>
    </div>
    <button onclick="logout()" style="margin-left:auto;background:transparent;border:none;cursor:pointer;padding:4px;color:oklch(60% 0.01 240)" title="登出">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
    </button>
  </div>
</aside>

<script>
  fetch('/api/auth/me').then(r => r.json()).then(d => {
    if (d.username) {
      const el = document.getElementById('admin-name');
      const av = document.getElementById('admin-avatar');
      if (el) el.textContent = d.username;
      if (av) av.textContent = d.username[0]?.toUpperCase() || 'M';
    }
  }).catch(() => {});

  function logout() {
    fetch('/api/auth/logout', { method: 'POST' })
      .then(() => { window.location.href = '/shop/login'; });
  }
</script>
