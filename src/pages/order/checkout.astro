---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>稻荷商城 — 結帳</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
  </head>
  <body>
    <div class="app-header">
      <button class="icon-btn" onclick="window.location.href='/order'" aria-label="返回">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div style="margin-left:4px">
        <div style="font-family:var(--mono);font-size:10px;color:var(--mute);letter-spacing:.06em">CHECKOUT · GUEST</div>
        <div style="font-weight:700;font-size:15px;letter-spacing:-.01em">結帳</div>
      </div>
    </div>

    <div class="screen-scroll" style="flex:1">
      <div class="page-title">
        <div class="eyebrow">第 2 步 / 共 2 步</div>
        <h1>填寫送貨資料</h1>
        <div class="meta" id="checkout-meta">載入中...</div>
      </div>

      <div style="padding:4px 18px 16px">
        <div class="card">
          <div style="padding:12px 16px;border-bottom:1px solid var(--hairline);display:flex;align-items:center;justify-content:space-between;font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--mute)">
            <span>訂單摘要</span>
            <span style="color:var(--ink);font-family:var(--mono)" id="items-count">0 項</span>
          </div>
          <div id="checkout-items"><div style="padding:20px;text-align:center;color:var(--mute);font-size:13px">購物車是空的</div></div>
          <div style="padding:14px 16px;display:flex;justify-content:space-between;align-items:baseline;background:var(--paper-2)">
            <span style="font-size:12px;color:var(--mute);font-weight:600;letter-spacing:.06em;text-transform:uppercase">合計</span>
            <span style="font-family:var(--mono);font-size:22px;font-weight:700;color:var(--coral-deep)" id="checkout-total">MOP 0</span>
          </div>
        </div>
      </div>

      <div style="padding:0 18px 16px;display:flex;flex-direction:column;gap:14px">
        <div class="field">
          <label>收貨人姓名 *</label>
          <input class="input" id="guest_name" type="text" placeholder="請輸入姓名" required />
        </div>
        <div class="field">
          <label>聯絡電話 *</label>
          <input class="input" id="guest_phone" type="tel" placeholder="如 66123456" required />
        </div>
        <div class="field">
          <label>送貨地址 *</label>
          <textarea class="textarea" id="guest_address" placeholder="請輸入完整送貨地址（大廈/街道/樓層）" required></textarea>
        </div>

        <div class="field">
          <label>送貨日期</label>
          <div style="position:relative">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
              style="position:absolute;left:14px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--mute);pointer-events:none">
              <rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/>
            </svg>
            <input class="input" type="date" id="delivery_date" style="padding-left:40px" required />
          </div>
          <div style="font-size:11px;color:var(--mute);margin-top:-2px" id="delivery-hint">最早可選明日</div>
        </div>

        <div class="field">
          <label>付款方式</label>
          <div style="display:flex;flex-direction:column;gap:8px">
            <div class="radio-card active" id="pay-現金" onclick="selectPayment('現金')">
              <div style="display:flex;align-items:center;gap:12px">
                <div class="dot-ring"></div>
                <span style="font-weight:600;font-size:14px">現金 · 貨到付款</span>
              </div>
              <span class="badge sea" style="font-size:10px">預設</span>
            </div>
            <div class="radio-card" id="pay-銀行轉帳" onclick="selectPayment('銀行轉帳')">
              <div style="display:flex;align-items:center;gap:12px">
                <div class="dot-ring"></div>
                <span style="font-weight:600;font-size:14px">銀行轉帳</span>
              </div>
            </div>
          </div>
        </div>

        <div class="field" id="receipt-field" style="display:none">
          <label>備款相片（轉帳後上傳，選填）</label>
          <input class="input" id="receipt_file" type="file" accept="image/*" capture="environment" />
          <div style="font-size:11px;color:var(--mute);margin-top:-2px">冇即時上傳都可以，職員審單時我哋會另外聯絡您核實</div>
        </div>

        <div class="field">
          <label>備注 (選填)</label>
          <textarea class="textarea" id="notes" placeholder="如送貨時間、特殊處理需求…"></textarea>
        </div>
      </div>
    </div>

    <div style="padding:14px 18px 18px;background:var(--paper);border-top:1px solid var(--hairline);flex-shrink:0">
      <button class="btn coral lg block" id="confirm-btn" onclick="submitOrder()">
        確認下單 · <span id="btn-total">MOP 0</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

    <script type="module">
      import { getCart, clearCart } from '/js/guest-cart.js';

      let selectedPayment = '現金';
      window.selectPayment = function(method) {
        selectedPayment = method;
        document.querySelectorAll('.radio-card').forEach(card => card.classList.remove('active'));
        document.getElementById('pay-' + method)?.classList.add('active');
        document.getElementById('receipt-field').style.display = method === '銀行轉帳' ? 'block' : 'none';
      };

      const tomorrow = new Date();
      tomorrow.setDate(tomorrow.getDate() + 1);
      const tomorrowStr = tomorrow.toISOString().slice(0, 10);
      const dateInput = document.getElementById('delivery_date');
      dateInput.min = tomorrowStr;
      dateInput.value = tomorrowStr;
      document.getElementById('delivery-hint').textContent = `最早可選明日 (${tomorrowStr})`;

      function fmtMOP(n) { return 'MOP ' + Number(n||0).toLocaleString('en-US',{maximumFractionDigits:0}); }

      function renderCart() {
        const cart = getCart();
        const items = cart.items || [];
        const total = items.reduce((s,i)=>s+(i.line_total||i.qty*i.unit_price||0),0);

        document.getElementById('checkout-meta').innerHTML = `合計 <span style="font-family:var(--mono);font-weight:700;color:var(--coral-deep)">${fmtMOP(total)}</span> · ${items.length} 件商品`;
        document.getElementById('items-count').textContent = items.length + ' 項';
        document.getElementById('checkout-total').textContent = fmtMOP(total);
        document.getElementById('btn-total').textContent = fmtMOP(total);

        if (items.length === 0) {
          document.getElementById('checkout-items').innerHTML = '<div style="padding:24px;text-align:center;color:var(--mute);font-size:13px">購物車是空的</div>';
          return;
        }
        document.getElementById('checkout-items').innerHTML = items.map(item => `
          <div style="padding:12px 16px;display:grid;grid-template-columns:1fr auto;gap:4px;border-bottom:1px solid var(--hairline)">
            <div>
              <div style="font-size:13px;font-weight:600;line-height:1.3">${item.product_name}</div>
              <div style="font-size:11px;color:var(--mute);margin-top:3px;font-family:var(--mono)">${item.sku || ''} · ${Number(item.qty).toLocaleString()} × ${fmtMOP(item.unit_price)} / ${item.unit || '件'}</div>
            </div>
            <div style="font-family:var(--mono);font-weight:700;font-size:14px;text-align:right">${fmtMOP(item.line_total || item.qty * item.unit_price)}</div>
          </div>`).join('');
      }
      renderCart();

      function compressImage(file) {
        return new Promise((resolve, reject) => {
          const img = new Image();
          const reader = new FileReader();
          reader.onload = (e) => { img.src = e.target.result; };
          reader.onerror = reject;
          img.onload = () => {
            const maxDim = 1280;
            const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
            const canvas = document.createElement('canvas');
            canvas.width = img.width * scale;
            canvas.height = img.height * scale;
            canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
            resolve(canvas.toDataURL('image/jpeg', 0.75));
          };
          img.onerror = reject;
          reader.readAsDataURL(file);
        });
      }

      window.submitOrder = async function() {
        const cart = getCart();
        if (!(cart.items || []).length) { alert('購物車是空的'); return; }

        const guest_name = document.getElementById('guest_name').value.trim();
        const guest_phone = document.getElementById('guest_phone').value.trim();
        const guest_delivery_address = document.getElementById('guest_address').value.trim();
        const delivery_date = document.getElementById('delivery_date').value;
        const notes = document.getElementById('notes').value.trim();

        if (!guest_name) { alert('請填寫收貨人姓名'); return; }
        if (!/^[0-9+\-\s]{6,20}$/.test(guest_phone)) { alert('請填寫有效聯絡電話'); return; }
        if (!guest_delivery_address) { alert('請填寫送貨地址'); return; }
        if (!delivery_date) { alert('請選擇送貨日期'); return; }

        const btn = document.getElementById('confirm-btn');
        btn.disabled = true;
        btn.textContent = '處理中...';

        try {
          const res = await fetch('/api/order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              items: cart.items.map(i => ({ product_id: i.product_id, sku: i.sku, product_name: i.product_name, qty: i.qty, unit: i.unit, unit_price: i.unit_price })),
              guest_name, guest_phone, guest_delivery_address,
              payment_method: selectedPayment,
              delivery_date, notes,
            }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) { alert('下單失敗: ' + (data.error || '請稍後重試')); return; }

          const fileInput = document.getElementById('receipt_file');
          if (selectedPayment === '銀行轉帳' && fileInput.files[0]) {
            try {
              const dataUrl = await compressImage(fileInput.files[0]);
              await fetch('/api/order/receipt', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ order_no: data.order_no, guest_phone, image_base64: dataUrl }),
              });
            } catch { /* 相片上傳失敗唔阻訂單完成,職員審單時另外聯絡核實 */ }
          }

          clearCart();
          window.location.href = '/order/confirmed?no=' + encodeURIComponent(data.order_no) + '&phone=' + encodeURIComponent(guest_phone);
        } catch {
          alert('下單失敗，請檢查網絡後重試');
        } finally {
          btn.disabled = false;
          btn.innerHTML = `確認下單 · <span id="btn-total">${document.getElementById('checkout-total').textContent}</span> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
        }
      };
    </script>
  </body>
</html>
