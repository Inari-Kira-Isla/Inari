---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>INARI - 知識庫管理</title>
  </head>
  <body>
    <div class="page">
      <header>
        <h1>INARI 知識庫管理</h1>
        <a href="/" class="back-link">← 返回首頁</a>
      </header>

      <div class="toolbar">
        <div class="filter-group">
          <label for="filter-category">篩選分類：</label>
          <select id="filter-category">
            <option value="">全部</option>
          </select>
        </div>
        <button id="btn-add" class="btn btn-primary">+ 新增知識</button>
      </div>

      <div id="list-container">
        <div class="loading">載入中...</div>
      </div>
    </div>

    <!-- 新增/編輯 Modal -->
    <div id="modal-overlay" class="modal-overlay hidden">
      <div class="modal">
        <h2 id="modal-title">新增知識</h2>
        <form id="modal-form">
          <input type="hidden" id="edit-id" />
          <div class="form-group">
            <label for="edit-category">分類 <span class="required">*</span></label>
            <input type="text" id="edit-category" placeholder="例：公司介紹、服務、FAQ、聯繫方式" list="category-suggestions" />
            <datalist id="category-suggestions"></datalist>
          </div>
          <div class="form-group">
            <label for="edit-question">問題（選填，適用 FAQ 類型）</label>
            <input type="text" id="edit-question" placeholder="例：你們提供哪些服務？" />
          </div>
          <div class="form-group">
            <label for="edit-answer">回答/內容 <span class="required">*</span></label>
            <textarea id="edit-answer" rows="6" placeholder="輸入詳細的回答或說明內容..."></textarea>
          </div>
          <p id="modal-error" class="error"></p>
          <div class="modal-actions">
            <button type="button" id="btn-cancel" class="btn btn-secondary">取消</button>
            <button type="submit" id="btn-save" class="btn btn-primary">儲存</button>
          </div>
        </form>
      </div>
    </div>

    <!-- 刪除確認 Modal -->
    <div id="delete-overlay" class="modal-overlay hidden">
      <div class="modal modal-sm">
        <h2>確認刪除</h2>
        <p class="delete-msg">確定要刪除這筆知識嗎？此操作無法復原。</p>
        <div class="modal-actions">
          <button type="button" id="btn-delete-cancel" class="btn btn-secondary">取消</button>
          <button type="button" id="btn-delete-confirm" class="btn btn-danger">刪除</button>
        </div>
      </div>
    </div>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: Inter, -apple-system, sans-serif;
        background: #f9fafb;
        min-height: 100vh;
        color: #111827;
      }
      .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 24px 16px;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }
      h1 {
        font-size: 24px;
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .back-link {
        color: #6b7280;
        text-decoration: none;
        font-size: 14px;
      }
      .back-link:hover { color: #3245ff; }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
        gap: 12px;
        flex-wrap: wrap;
      }
      .filter-group {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #6b7280;
      }
      select {
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 14px;
        background: #fff;
        outline: none;
        cursor: pointer;
      }
      select:focus { border-color: #3245ff; }

      .btn {
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      .btn:hover { opacity: 0.85; }
      .btn-primary {
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        color: #fff;
      }
      .btn-secondary {
        background: #f3f4f6;
        color: #374151;
      }
      .btn-danger {
        background: #ef4444;
        color: #fff;
      }

      .loading {
        text-align: center;
        padding: 48px;
        color: #9ca3af;
        font-size: 14px;
      }
      .empty-state {
        text-align: center;
        padding: 48px;
        color: #9ca3af;
        font-size: 14px;
      }

      .knowledge-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 12px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
      .card-content { flex: 1; min-width: 0; }
      .card-category {
        display: inline-block;
        background: linear-gradient(135deg, #3245ff22 0%, #bc52ee22 100%);
        color: #3245ff;
        border-radius: 6px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .card-question {
        font-weight: 600;
        font-size: 15px;
        margin-bottom: 6px;
        color: #1f2937;
      }
      .card-answer {
        font-size: 14px;
        color: #4b5563;
        white-space: pre-wrap;
        word-break: break-word;
        line-height: 1.6;
      }
      .card-meta {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 8px;
      }
      .card-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-shrink: 0;
      }
      .btn-icon {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        background: #fff;
        color: #374151;
        transition: all 0.15s;
      }
      .btn-icon:hover { background: #f3f4f6; }
      .btn-icon.delete:hover { background: #fee2e2; color: #ef4444; border-color: #fca5a5; }

      /* Modal */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        z-index: 100;
      }
      .modal-overlay.hidden { display: none; }
      .modal {
        background: #fff;
        border-radius: 16px;
        padding: 32px;
        width: 100%;
        max-width: 560px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      }
      .modal-sm { max-width: 380px; }
      .modal h2 {
        font-size: 20px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .form-group {
        margin-bottom: 16px;
      }
      .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
      }
      .required { color: #ef4444; }
      .form-group input, .form-group textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        outline: none;
        font-family: inherit;
        resize: vertical;
      }
      .form-group input:focus, .form-group textarea:focus { border-color: #3245ff; }
      .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px;
      }
      .delete-msg {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 4px;
        line-height: 1.6;
      }
      .error { color: #ef4444; font-size: 13px; min-height: 18px; margin-bottom: 4px; }
    </style>

    <script>
      let allItems = [];
      let deleteTargetId = null;
      const categories = new Set();

      const listContainer = document.getElementById("list-container");
      const filterSelect = document.getElementById("filter-category");
      const modalOverlay = document.getElementById("modal-overlay");
      const deleteOverlay = document.getElementById("delete-overlay");
      const modalTitle = document.getElementById("modal-title");
      const modalForm = document.getElementById("modal-form");
      const modalError = document.getElementById("modal-error");
      const editId = document.getElementById("edit-id");
      const editCategory = document.getElementById("edit-category");
      const editQuestion = document.getElementById("edit-question");
      const editAnswer = document.getElementById("edit-answer");
      const categorySuggestions = document.getElementById("category-suggestions");

      async function loadItems(category = "") {
        listContainer.innerHTML = '<div class="loading">載入中...</div>';
        const url = category ? `/api/knowledge?category=${encodeURIComponent(category)}` : "/api/knowledge";
        const res = await fetch(url);
        const data = await res.json();
        allItems = data.items || [];

        categories.clear();
        for (const item of allItems) {
          if (item.category) categories.add(item.category);
        }
        updateCategoryOptions();
        renderList(allItems);
      }

      function updateCategoryOptions() {
        const currentFilter = filterSelect.value;
        filterSelect.innerHTML = '<option value="">全部</option>';
        categorySuggestions.innerHTML = "";
        for (const cat of [...categories].sort()) {
          const opt = document.createElement("option");
          opt.value = cat;
          opt.textContent = cat;
          filterSelect.appendChild(opt);

          const suggestion = document.createElement("option");
          suggestion.value = cat;
          categorySuggestions.appendChild(suggestion);
        }
        filterSelect.value = currentFilter;
      }

      function renderList(items) {
        if (items.length === 0) {
          listContainer.innerHTML = '<div class="empty-state">目前沒有知識條目，點擊「新增知識」開始建立。</div>';
          return;
        }
        listContainer.innerHTML = items.map(item => `
          <div class="knowledge-card">
            <div class="card-content">
              <span class="card-category">${escapeHtml(item.category)}</span>
              ${item.question ? `<div class="card-question">${escapeHtml(item.question)}</div>` : ""}
              <div class="card-answer">${escapeHtml(item.answer)}</div>
              <div class="card-meta">建立：${item.created_at || ""} ${item.updated_at && item.updated_at !== item.created_at ? `· 更新：${item.updated_at}` : ""}</div>
            </div>
            <div class="card-actions">
              <button class="btn-icon" onclick="openEdit(${item.id})">編輯</button>
              <button class="btn-icon delete" onclick="openDelete(${item.id})">刪除</button>
            </div>
          </div>
        `).join("");
      }

      function escapeHtml(str) {
        if (!str) return "";
        return String(str)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      // 新增
      document.getElementById("btn-add").addEventListener("click", () => {
        modalTitle.textContent = "新增知識";
        editId.value = "";
        editCategory.value = "";
        editQuestion.value = "";
        editAnswer.value = "";
        modalError.textContent = "";
        modalOverlay.classList.remove("hidden");
        editCategory.focus();
      });

      // 取消
      document.getElementById("btn-cancel").addEventListener("click", () => {
        modalOverlay.classList.add("hidden");
      });

      modalOverlay.addEventListener("click", (e) => {
        if (e.target === modalOverlay) modalOverlay.classList.add("hidden");
      });

      // 編輯
      window.openEdit = function(id) {
        const item = allItems.find(i => i.id === id);
        if (!item) return;
        modalTitle.textContent = "編輯知識";
        editId.value = id;
        editCategory.value = item.category || "";
        editQuestion.value = item.question || "";
        editAnswer.value = item.answer || "";
        modalError.textContent = "";
        modalOverlay.classList.remove("hidden");
        editCategory.focus();
      };

      // 儲存（新增/更新）
      modalForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        modalError.textContent = "";
        const id = editId.value;
        const category = editCategory.value.trim();
        const question = editQuestion.value.trim();
        const answer = editAnswer.value.trim();

        if (!category || !answer) {
          modalError.textContent = "分類和回答為必填欄位";
          return;
        }

        const saveBtn = document.getElementById("btn-save");
        saveBtn.disabled = true;
        saveBtn.textContent = "儲存中...";

        try {
          const method = id ? "PUT" : "POST";
          const body = { category, question: question || null, answer };
          if (id) body.id = parseInt(id);

          const res = await fetch("/api/knowledge", {
            method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!res.ok) {
            modalError.textContent = data.error || "操作失敗";
          } else {
            modalOverlay.classList.add("hidden");
            await loadItems(filterSelect.value);
          }
        } catch (err) {
          modalError.textContent = "網路錯誤，請稍後再試";
        } finally {
          saveBtn.disabled = false;
          saveBtn.textContent = "儲存";
        }
      });

      // 刪除
      window.openDelete = function(id) {
        deleteTargetId = id;
        deleteOverlay.classList.remove("hidden");
      };

      document.getElementById("btn-delete-cancel").addEventListener("click", () => {
        deleteOverlay.classList.add("hidden");
        deleteTargetId = null;
      });

      deleteOverlay.addEventListener("click", (e) => {
        if (e.target === deleteOverlay) {
          deleteOverlay.classList.add("hidden");
          deleteTargetId = null;
        }
      });

      document.getElementById("btn-delete-confirm").addEventListener("click", async () => {
        if (!deleteTargetId) return;
        const confirmBtn = document.getElementById("btn-delete-confirm");
        confirmBtn.disabled = true;
        confirmBtn.textContent = "刪除中...";
        try {
          const res = await fetch(`/api/knowledge?id=${deleteTargetId}`, { method: "DELETE" });
          if (res.ok) {
            deleteOverlay.classList.add("hidden");
            deleteTargetId = null;
            await loadItems(filterSelect.value);
          }
        } finally {
          confirmBtn.disabled = false;
          confirmBtn.textContent = "刪除";
        }
      });

      // 分類篩選
      filterSelect.addEventListener("change", () => {
        loadItems(filterSelect.value);
      });

      // 初始載入
      loadItems();
    </script>
  </body>
</html>
