---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>INARI - 後台管理</title>
  </head>
  <body>
    <div class="page">
      <header>
        <h1>INARI 後台管理</h1>
        <a href="/" class="back-link">← 返回首頁</a>
      </header>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" id="tab-knowledge" onclick="switchTab('knowledge')">知識庫</button>
        <button class="tab-btn" id="tab-conversations" onclick="switchTab('conversations')">對話記錄</button>
      </div>

      <!-- Tab: 知識庫 -->
      <div id="panel-knowledge" class="tab-panel">
        <div class="toolbar">
          <div class="filter-group">
            <label for="filter-category">篩選分類：</label>
            <select id="filter-category">
              <option value="">全部</option>
            </select>
          </div>
          <button id="btn-add" class="btn btn-primary">+ 新增知識</button>
        </div>

        <div id="list-container">
          <div class="loading">載入中...</div>
        </div>
      </div>

      <!-- Tab: 對話記錄 -->
      <div id="panel-conversations" class="tab-panel hidden">
        <div class="conv-stats" id="conv-stats">
          <span class="stat-label">總對話數：</span>
          <span class="stat-value" id="total-sessions">-</span>
        </div>
        <div class="conv-layout">
          <div class="conv-sidebar" id="conv-sidebar">
            <div class="loading">載入中...</div>
          </div>
          <div class="conv-main" id="conv-main">
            <div class="conv-empty">請選擇左側的對話 session 來查看內容</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 新增/編輯 Modal -->
    <div id="modal-overlay" class="modal-overlay hidden">
      <div class="modal">
        <h2 id="modal-title">新增知識</h2>
        <form id="modal-form">
          <input type="hidden" id="edit-id" />
          <div class="form-group">
            <label for="edit-category">分類 <span class="required">*</span></label>
            <input type="text" id="edit-category" placeholder="例：公司介紹、服務、FAQ、聯繫方式" list="category-suggestions" />
            <datalist id="category-suggestions"></datalist>
          </div>
          <div class="form-group">
            <label for="edit-question">問題（選填，適用 FAQ 類型）</label>
            <input type="text" id="edit-question" placeholder="例：你們提供哪些服務？" />
          </div>
          <div class="form-group">
            <label for="edit-answer">回答/內容 <span class="required">*</span></label>
            <textarea id="edit-answer" rows="6" placeholder="輸入詳細的回答或說明內容..."></textarea>
          </div>
          <p id="modal-error" class="error"></p>
          <div class="modal-actions">
            <button type="button" id="btn-cancel" class="btn btn-secondary">取消</button>
            <button type="submit" id="btn-save" class="btn btn-primary">儲存</button>
          </div>
        </form>
      </div>
    </div>

    <!-- 刪除確認 Modal -->
    <div id="delete-overlay" class="modal-overlay hidden">
      <div class="modal modal-sm">
        <h2>確認刪除</h2>
        <p class="delete-msg">確定要刪除這筆知識嗎？此操作無法復原。</p>
        <div class="modal-actions">
          <button type="button" id="btn-delete-cancel" class="btn btn-secondary">取消</button>
          <button type="button" id="btn-delete-confirm" class="btn btn-danger">刪除</button>
        </div>
      </div>
    </div>

    <!-- 刪除 Session 確認 Modal -->
    <div id="delete-session-overlay" class="modal-overlay hidden">
      <div class="modal modal-sm">
        <h2>確認刪除對話</h2>
        <p class="delete-msg">確定要刪除這個 session 的所有對話嗎？此操作無法復原。</p>
        <div class="modal-actions">
          <button type="button" id="btn-session-delete-cancel" class="btn btn-secondary">取消</button>
          <button type="button" id="btn-session-delete-confirm" class="btn btn-danger">刪除</button>
        </div>
      </div>
    </div>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: Inter, -apple-system, sans-serif;
        background: #f9fafb;
        min-height: 100vh;
        color: #111827;
      }
      .page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 16px;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }
      h1 {
        font-size: 24px;
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .back-link {
        color: #6b7280;
        text-decoration: none;
        font-size: 14px;
      }
      .back-link:hover { color: #3245ff; }

      /* Tabs */
      .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 24px;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 0;
      }
      .tab-btn {
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: none;
        color: #6b7280;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        border-radius: 8px 8px 0 0;
        transition: all 0.15s;
      }
      .tab-btn:hover { color: #3245ff; background: #f3f4f6; }
      .tab-btn.active {
        color: #3245ff;
        border-bottom-color: #3245ff;
        background: #fff;
      }
      .tab-panel { }
      .tab-panel.hidden { display: none; }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
        gap: 12px;
        flex-wrap: wrap;
      }
      .filter-group {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #6b7280;
      }
      select {
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 14px;
        background: #fff;
        outline: none;
        cursor: pointer;
      }
      select:focus { border-color: #3245ff; }

      .btn {
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      .btn:hover { opacity: 0.85; }
      .btn-primary {
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        color: #fff;
      }
      .btn-secondary {
        background: #f3f4f6;
        color: #374151;
      }
      .btn-danger {
        background: #ef4444;
        color: #fff;
      }
      .btn-sm {
        padding: 6px 14px;
        font-size: 13px;
      }

      .loading {
        text-align: center;
        padding: 48px;
        color: #9ca3af;
        font-size: 14px;
      }
      .empty-state {
        text-align: center;
        padding: 48px;
        color: #9ca3af;
        font-size: 14px;
      }

      /* Knowledge Cards */
      .knowledge-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 12px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
      .card-content { flex: 1; min-width: 0; }
      .card-category {
        display: inline-block;
        background: linear-gradient(135deg, #3245ff22 0%, #bc52ee22 100%);
        color: #3245ff;
        border-radius: 6px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .card-question {
        font-weight: 600;
        font-size: 15px;
        margin-bottom: 6px;
        color: #1f2937;
      }
      .card-answer {
        font-size: 14px;
        color: #4b5563;
        white-space: pre-wrap;
        word-break: break-word;
        line-height: 1.6;
      }
      .card-meta {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 8px;
      }
      .card-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-shrink: 0;
      }
      .btn-icon {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        background: #fff;
        color: #374151;
        transition: all 0.15s;
      }
      .btn-icon:hover { background: #f3f4f6; }
      .btn-icon.delete:hover { background: #fee2e2; color: #ef4444; border-color: #fca5a5; }

      /* Conversations */
      .conv-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        font-size: 14px;
        color: #6b7280;
      }
      .stat-value {
        font-weight: 700;
        color: #3245ff;
        font-size: 16px;
      }
      .conv-layout {
        display: flex;
        gap: 16px;
        min-height: 500px;
      }
      .conv-sidebar {
        width: 320px;
        flex-shrink: 0;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        overflow-y: auto;
        max-height: 680px;
      }
      .conv-main {
        flex: 1;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        overflow-y: auto;
        max-height: 680px;
        display: flex;
        flex-direction: column;
      }
      .conv-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        color: #9ca3af;
        font-size: 14px;
        padding: 48px;
        text-align: center;
      }

      /* Session List Items */
      .session-item {
        padding: 14px 16px;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: background 0.1s;
      }
      .session-item:last-child { border-bottom: none; }
      .session-item:hover { background: #f9fafb; }
      .session-item.active { background: linear-gradient(135deg, #3245ff0d 0%, #bc52ee0d 100%); border-left: 3px solid #3245ff; }
      .session-preview {
        font-size: 13px;
        color: #1f2937;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
      }
      .session-meta {
        font-size: 11px;
        color: #9ca3af;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .session-count {
        display: inline-block;
        background: #f3f4f6;
        border-radius: 10px;
        padding: 1px 8px;
        font-size: 11px;
        color: #6b7280;
      }

      /* Conversation Messages */
      .conv-header {
        padding: 16px 20px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
      }
      .conv-header-title {
        font-size: 13px;
        color: #6b7280;
        font-weight: 500;
        word-break: break-all;
      }
      .conv-messages {
        flex: 1;
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        overflow-y: auto;
      }
      .msg-bubble {
        max-width: 80%;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.6;
        word-break: break-word;
        white-space: pre-wrap;
      }
      .msg-bubble.user {
        align-self: flex-end;
        background: #3245ff;
        color: #fff;
        border-bottom-right-radius: 4px;
      }
      .msg-bubble.assistant {
        align-self: flex-start;
        background: #f3f4f6;
        color: #111827;
        border-bottom-left-radius: 4px;
      }
      .msg-role {
        font-size: 11px;
        margin-bottom: 4px;
        color: #9ca3af;
      }
      .msg-role.user-role { text-align: right; }
      .msg-time {
        font-size: 10px;
        color: #9ca3af;
        margin-top: 3px;
      }
      .msg-time.user-time { text-align: right; }
      .msg-wrapper {
        display: flex;
        flex-direction: column;
      }
      .msg-wrapper.user-wrapper { align-items: flex-end; }
      .msg-wrapper.assistant-wrapper { align-items: flex-start; }

      /* Modal */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        z-index: 100;
      }
      .modal-overlay.hidden { display: none; }
      .modal {
        background: #fff;
        border-radius: 16px;
        padding: 32px;
        width: 100%;
        max-width: 560px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      }
      .modal-sm { max-width: 380px; }
      .modal h2 {
        font-size: 20px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .form-group {
        margin-bottom: 16px;
      }
      .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
      }
      .required { color: #ef4444; }
      .form-group input, .form-group textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        outline: none;
        font-family: inherit;
        resize: vertical;
      }
      .form-group input:focus, .form-group textarea:focus { border-color: #3245ff; }
      .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px;
      }
      .delete-msg {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 4px;
        line-height: 1.6;
      }
      .error { color: #ef4444; font-size: 13px; min-height: 18px; margin-bottom: 4px; }

      @media (max-width: 700px) {
        .conv-layout { flex-direction: column; }
        .conv-sidebar { width: 100%; max-height: 280px; }
        .conv-main { max-height: 400px; }
      }
    </style>

    <script>
      // ===================== TAB SWITCHING =====================
      function switchTab(tab) {
        document.getElementById("panel-knowledge").classList.toggle("hidden", tab !== "knowledge");
        document.getElementById("panel-conversations").classList.toggle("hidden", tab !== "conversations");
        document.getElementById("tab-knowledge").classList.toggle("active", tab === "knowledge");
        document.getElementById("tab-conversations").classList.toggle("active", tab === "conversations");
        if (tab === "conversations") loadSessions();
      }
      window.switchTab = switchTab;

      // ===================== KNOWLEDGE BASE =====================
      let allItems = [];
      let deleteTargetId = null;
      const categories = new Set();

      const listContainer = document.getElementById("list-container");
      const filterSelect = document.getElementById("filter-category");
      const modalOverlay = document.getElementById("modal-overlay");
      const deleteOverlay = document.getElementById("delete-overlay");
      const modalTitle = document.getElementById("modal-title");
      const modalForm = document.getElementById("modal-form");
      const modalError = document.getElementById("modal-error");
      const editId = document.getElementById("edit-id");
      const editCategory = document.getElementById("edit-category");
      const editQuestion = document.getElementById("edit-question");
      const editAnswer = document.getElementById("edit-answer");
      const categorySuggestions = document.getElementById("category-suggestions");

      async function loadItems(category = "") {
        listContainer.innerHTML = '<div class="loading">載入中...</div>';
        const url = category ? `/api/knowledge?category=${encodeURIComponent(category)}` : "/api/knowledge";
        const res = await fetch(url);
        const data = await res.json();
        allItems = data.items || [];

        categories.clear();
        for (const item of allItems) {
          if (item.category) categories.add(item.category);
        }
        updateCategoryOptions();
        renderList(allItems);
      }

      function updateCategoryOptions() {
        const currentFilter = filterSelect.value;
        filterSelect.innerHTML = '<option value="">全部</option>';
        categorySuggestions.innerHTML = "";
        for (const cat of [...categories].sort()) {
          const opt = document.createElement("option");
          opt.value = cat;
          opt.textContent = cat;
          filterSelect.appendChild(opt);

          const suggestion = document.createElement("option");
          suggestion.value = cat;
          categorySuggestions.appendChild(suggestion);
        }
        filterSelect.value = currentFilter;
      }

      function renderList(items) {
        if (items.length === 0) {
          listContainer.innerHTML = '<div class="empty-state">目前沒有知識條目，點擊「新增知識」開始建立。</div>';
          return;
        }
        listContainer.innerHTML = items.map(item => `
          <div class="knowledge-card">
            <div class="card-content">
              <span class="card-category">${escapeHtml(item.category)}</span>
              ${item.question ? `<div class="card-question">${escapeHtml(item.question)}</div>` : ""}
              <div class="card-answer">${escapeHtml(item.answer)}</div>
              <div class="card-meta">建立：${item.created_at || ""} ${item.updated_at && item.updated_at !== item.created_at ? `· 更新：${item.updated_at}` : ""}</div>
            </div>
            <div class="card-actions">
              <button class="btn-icon" onclick="openEdit(${item.id})">編輯</button>
              <button class="btn-icon delete" onclick="openDelete(${item.id})">刪除</button>
            </div>
          </div>
        `).join("");
      }

      function escapeHtml(str) {
        if (!str) return "";
        return String(str)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      document.getElementById("btn-add").addEventListener("click", () => {
        modalTitle.textContent = "新增知識";
        editId.value = "";
        editCategory.value = "";
        editQuestion.value = "";
        editAnswer.value = "";
        modalError.textContent = "";
        modalOverlay.classList.remove("hidden");
        editCategory.focus();
      });

      document.getElementById("btn-cancel").addEventListener("click", () => {
        modalOverlay.classList.add("hidden");
      });

      modalOverlay.addEventListener("click", (e) => {
        if (e.target === modalOverlay) modalOverlay.classList.add("hidden");
      });

      window.openEdit = function(id) {
        const item = allItems.find(i => i.id === id);
        if (!item) return;
        modalTitle.textContent = "編輯知識";
        editId.value = id;
        editCategory.value = item.category || "";
        editQuestion.value = item.question || "";
        editAnswer.value = item.answer || "";
        modalError.textContent = "";
        modalOverlay.classList.remove("hidden");
        editCategory.focus();
      };

      modalForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        modalError.textContent = "";
        const id = editId.value;
        const category = editCategory.value.trim();
        const question = editQuestion.value.trim();
        const answer = editAnswer.value.trim();

        if (!category || !answer) {
          modalError.textContent = "分類和回答為必填欄位";
          return;
        }

        const saveBtn = document.getElementById("btn-save");
        saveBtn.disabled = true;
        saveBtn.textContent = "儲存中...";

        try {
          const method = id ? "PUT" : "POST";
          const body = { category, question: question || null, answer };
          if (id) body.id = parseInt(id);

          const res = await fetch("/api/knowledge", {
            method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!res.ok) {
            modalError.textContent = data.error || "操作失敗";
          } else {
            modalOverlay.classList.add("hidden");
            await loadItems(filterSelect.value);
          }
        } catch (err) {
          modalError.textContent = "網路錯誤，請稍後再試";
        } finally {
          saveBtn.disabled = false;
          saveBtn.textContent = "儲存";
        }
      });

      window.openDelete = function(id) {
        deleteTargetId = id;
        deleteOverlay.classList.remove("hidden");
      };

      document.getElementById("btn-delete-cancel").addEventListener("click", () => {
        deleteOverlay.classList.add("hidden");
        deleteTargetId = null;
      });

      deleteOverlay.addEventListener("click", (e) => {
        if (e.target === deleteOverlay) {
          deleteOverlay.classList.add("hidden");
          deleteTargetId = null;
        }
      });

      document.getElementById("btn-delete-confirm").addEventListener("click", async () => {
        if (!deleteTargetId) return;
        const confirmBtn = document.getElementById("btn-delete-confirm");
        confirmBtn.disabled = true;
        confirmBtn.textContent = "刪除中...";
        try {
          const res = await fetch(`/api/knowledge?id=${deleteTargetId}`, { method: "DELETE" });
          if (res.ok) {
            deleteOverlay.classList.add("hidden");
            deleteTargetId = null;
            await loadItems(filterSelect.value);
          }
        } finally {
          confirmBtn.disabled = false;
          confirmBtn.textContent = "刪除";
        }
      });

      filterSelect.addEventListener("change", () => {
        loadItems(filterSelect.value);
      });

      loadItems();

      // ===================== CONVERSATIONS =====================
      let allSessions = [];
      let activeSessionId = null;
      let deleteSessionTarget = null;

      const convSidebar = document.getElementById("conv-sidebar");
      const convMain = document.getElementById("conv-main");
      const totalSessionsEl = document.getElementById("total-sessions");
      const deleteSessionOverlay = document.getElementById("delete-session-overlay");

      async function loadSessions() {
        convSidebar.innerHTML = '<div class="loading">載入中...</div>';
        try {
          const res = await fetch("/api/conversations");
          const data = await res.json();
          allSessions = data.sessions || [];
          totalSessionsEl.textContent = data.total || 0;
          renderSessions();
        } catch (err) {
          convSidebar.innerHTML = '<div class="empty-state">載入失敗</div>';
        }
      }

      function formatTime(ts) {
        if (!ts) return "";
        try {
          const d = new Date(ts.includes("T") ? ts : ts.replace(" ", "T") + "Z");
          return d.toLocaleString("zh-TW", { month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" });
        } catch { return ts; }
      }

      function renderSessions() {
        if (allSessions.length === 0) {
          convSidebar.innerHTML = '<div class="empty-state">尚無對話記錄</div>';
          return;
        }
        convSidebar.innerHTML = allSessions.map(s => `
          <div class="session-item ${activeSessionId === s.session_id ? 'active' : ''}" onclick="selectSession('${escapeHtml(s.session_id)}')">
            <div class="session-preview">${escapeHtml(s.preview || '（無訊息）')}</div>
            <div class="session-meta">
              <span>${formatTime(s.last_message_at)}</span>
              <span class="session-count">${s.message_count} 則</span>
            </div>
          </div>
        `).join("");
      }

      window.selectSession = async function(sessionId) {
        activeSessionId = sessionId;
        renderSessions();
        convMain.innerHTML = '<div class="loading">載入中...</div>';
        try {
          const res = await fetch(`/api/conversations?session_id=${encodeURIComponent(sessionId)}`);
          const data = await res.json();
          renderConversation(sessionId, data.messages || []);
        } catch (err) {
          convMain.innerHTML = '<div class="conv-empty">載入失敗</div>';
        }
      };

      function renderConversation(sessionId, messages) {
        const shortId = sessionId.length > 20 ? sessionId.substring(0, 20) + "..." : sessionId;
        convMain.innerHTML = `
          <div class="conv-header">
            <div class="conv-header-title">Session: ${escapeHtml(shortId)}</div>
            <button class="btn btn-danger btn-sm" onclick="openDeleteSession('${escapeHtml(sessionId)}')">刪除對話</button>
          </div>
          <div class="conv-messages" id="conv-messages-inner">
            ${messages.length === 0
              ? '<div style="color:#9ca3af;font-size:14px;text-align:center;padding:32px;">此對話沒有記錄</div>'
              : messages.map(m => `
                <div class="msg-wrapper ${m.role === 'user' ? 'user-wrapper' : 'assistant-wrapper'}">
                  <div class="msg-role ${m.role === 'user' ? 'user-role' : ''}">${m.role === 'user' ? '用戶' : 'AI 助手'}</div>
                  <div class="msg-bubble ${m.role === 'user' ? 'user' : 'assistant'}">${escapeHtml(m.message)}</div>
                  <div class="msg-time ${m.role === 'user' ? 'user-time' : ''}">${formatTime(m.created_at)}</div>
                </div>
              `).join("")
            }
          </div>
        `;
      }

      window.openDeleteSession = function(sessionId) {
        deleteSessionTarget = sessionId;
        deleteSessionOverlay.classList.remove("hidden");
      };

      document.getElementById("btn-session-delete-cancel").addEventListener("click", () => {
        deleteSessionOverlay.classList.add("hidden");
        deleteSessionTarget = null;
      });

      deleteSessionOverlay.addEventListener("click", (e) => {
        if (e.target === deleteSessionOverlay) {
          deleteSessionOverlay.classList.add("hidden");
          deleteSessionTarget = null;
        }
      });

      document.getElementById("btn-session-delete-confirm").addEventListener("click", async () => {
        if (!deleteSessionTarget) return;
        const confirmBtn = document.getElementById("btn-session-delete-confirm");
        confirmBtn.disabled = true;
        confirmBtn.textContent = "刪除中...";
        try {
          const res = await fetch(`/api/conversations?session_id=${encodeURIComponent(deleteSessionTarget)}`, { method: "DELETE" });
          if (res.ok) {
            deleteSessionOverlay.classList.add("hidden");
            if (activeSessionId === deleteSessionTarget) {
              activeSessionId = null;
              convMain.innerHTML = '<div class="conv-empty">請選擇左側的對話 session 來查看內容</div>';
            }
            deleteSessionTarget = null;
            await loadSessions();
          }
        } finally {
          confirmBtn.disabled = false;
          confirmBtn.textContent = "刪除";
        }
      });
    </script>
  </body>
</html>
