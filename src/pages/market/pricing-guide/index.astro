---
import Layout from '../../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "海膽現在的市場價格是多少？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "日本馬糞海膽（A級）目前市場價格約 $150-300/盒，視乎產地和季節。加拿大紅海膽約 $60-120/盒，性價比較高。價格會因供應情況波動，建議聯繫我們獲取最新報價。"
      }
    },
    {
      "@type": "Question",
      "name": "三文魚批發價格是多少？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "挪威三文魚批發價約 $50-80/kg，銀三文魚約 $55-75/kg，紅三文魚約 $70-100/kg，金王三文魚約 $120-180/kg。大量採購可獲更優惠價格。"
      }
    },
    {
      "@type": "Question",
      "name": "海膽價格什麼時候最低？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "海膽價格通常在夏季（6-8月）最低，因為日本馬糞海膽產季供應充足。冬季節日前後（12-1月）價格會上漲20-30%。建議在旺季備貨以節省成本。"
      }
    }
  ]
};
---

<Layout title="港澳市場行情 | Market Pricing | Inari Global Foods">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <nav class="fixed top-0 w-full z-50 px-8 py-6 flex justify-between items-center bg-ivory/80 backdrop-blur-sm">
    <div class="text-xl font-bold tracking-tighter playfair">INARI GLOBAL</div>
    <div class="hidden md:flex space-x-8 text-sm uppercase">
      <a href="/" class="hover:text-gold transition">Home</a>
      <a href="#pricing" class="hover:text-gold transition">Pricing</a>
    </div>
  </nav>

  <section class="min-h-screen pt-32 px-8 text-center">
    <h2 class="text-sm uppercase text-gray-500 mb-4">Market Intelligence</h2>
    <h1 class="text-4xl md:text-6xl font-light playfair mb-8">Market <span class="italic">Pricing</span></h1>
    <p class="max-w-xl mx-auto text-gray-600 mb-12">港澳海鮮市場即時行情參考，把握最佳採購時機。</p>
  </section>

  <section id="pricing" class="py-24 bg-white">
    <div class="container mx-auto px-8 max-w-6xl">
      <h3 class="text-2xl playfair italic text-center mb-12">海膽報價 Sea Urchin Pricing</h3>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-black">
              <th class="text-left py-3">品種</th>
              <th class="text-left py-3">產地</th>
              <th class="text-left py-3">等級</th>
              <th class="text-right py-3">價格 (HKD)</th>
              <th class="text-right py-3">單位</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">馬糞海膽</td>
              <td class="py-3">日本北海道</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">A級</span></td>
              <td class="text-right py-3 font-bold">$180-300</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">馬糞海膽</td>
              <td class="py-3">日本根室</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">A級</span></td>
              <td class="text-right py-3 font-bold">$200-350</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">紫海膽</td>
              <td class="py-3">日本東京灣</td>
              <td class="py-3"><span class="bg-gray-100 px-2 py-1 rounded text-xs">B級</span></td>
              <td class="text-right py-3 font-bold">$80-150</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">紅海膽</td>
              <td class="py-3">加拿大BC省</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">A級</td>
              <td class="text-right py-3 font-bold">$80-120</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">紅海膽</td>
              <td class="py-3">加拿大BC省</td>
              <td class="py-3"><span class="bg-gray-100 px-2 py-1 rounded text-xs">B級</td>
              <td class="text-right py-3 font-bold">$60-80</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">海膽</td>
              <td class="py-3">智利</td>
              <td class="py-3"><span class="bg-stone-100 px-2 py-1 rounded text-xs">C級</td>
              <td class="text-right py-3 font-bold">$30-60</td>
              <td class="text-right py-3">/盒 (500g)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-24 bg-warm-gray">
    <div class="container mx-auto px-8 max-w-6xl">
      <h3 class="text-2xl playfair italic text-center mb-12">三文魚報價 Salmon Pricing</h3>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-black">
              <th class="text-left py-3">品種</th>
              <th class="text-left py-3">產地</th>
              <th class="text-left py-3">等級</th>
              <th class="text-right py-3">價格 (HKD)</th>
              <th class="text-right py-3">單位</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">大西洋三文魚</td>
              <td class="py-3">挪威</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">刺身級</span></td>
              <td class="text-right py-3 font-bold">$55-80</td>
              <td class="text-right py-3">/kg</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">大西洋三文魚</td>
              <td class="py-3">蘇格蘭</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">刺身級</span></td>
              <td class="text-right py-3 font-bold">$50-75</td>
              <td class="text-right py-3">/kg</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">金王三文魚</td>
