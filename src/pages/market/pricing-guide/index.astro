              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">刺身級</span></td>
              <td class="text-right py-3 font-bold">$120-180</td>
              <td class="text-right py-3">/kg</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">紅三文魚</td>
              <td class="py-3">加拿大</td>
              <td class="py-3"><span class="bg-green-100 px-2 py-1 rounded text-xs">刺身級</span></td>
              <td class="text-right py-3 font-bold">$70-100</td>
              <td class="text-right py-3">/kg</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">銀三文魚</td>
              <td class="py-3">北美</td>
              <td class="py-3"><span class="bg-gray-100 px-2 py-1 rounded text-xs">烹飪級</span></td>
              <td class="text-right py-3 font-bold">$55-75</td>
              <td class="text-right py-3">/kg</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 font-medium">三文魚</td>
              <td class="py-3">智利</td>
              <td class="py-3"><span class="bg-stone-100 px-2 py-1 rounded text-xs">加工級</span></td>
              <td class="text-right py-3 font-bold">$30-45</td>
              <td class="text-right py-3">/kg</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-16 bg-black text-white text-center">
    <h3 class="text-2xl playfair italic mb-4">需要即時報價？</h3>
    <p class="text-gray-400 mb-8">價格會根據市場波動，請聯繫我們獲取本週最新報價</p>
    <a href="mailto:info@inariglobal.com" class="inline-block px-8 py-3 bg-white text-black hover:bg-gray-200 transition">
      聯繫我們
    </a>
  </section>

  <footer class="py-12 text-center text-xs text-gray-400">
    Inari Global Foods &copy; 2026. 稻荷環球食品
  </footer>
</Layout>
