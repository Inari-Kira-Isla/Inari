---
import Layout from '../../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "餐廳如何向稻荷採購海膽？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "餐廳可通過電話或電郵聯繫我們下單。我們提供餐廳批發價格，最低保養5盒起。首次採購可獲取樣品試用。我們提供送貨服務，確保海膽保持最佳狀態送達您的餐廳。"
      }
    },
    {
      "@type": "Question",
      "name": "酒店採購海膽有優惠嗎？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "是的，我們為酒店客户提供專屬批發價格，根據採購量提供更具競爭力的折扣。酒店客戶可享受定期配送服務，確保每日新鮮供應。我們也可根據酒店需求定制特殊產品規格。"
      }
    },
    {
      "@type": "Question",
      "name": "日本料理店需要什麼品質的海膽？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "日本料理店通常需要A級海膽，肉質飽滿、色澤橙黃、旨味濃郁。我們提供專業建議，根據您的菜單推薦最適合的品種。馬糞海膽是高端壽司店的首選。"
      }
    }
  ]
};
---

<Layout title="餐廳採購指南 | Restaurant Sourcing | Inari Global Foods">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <nav class="fixed top-0 w-full z-50 px-8 py-6 flex justify-between items-center bg-ivory/80 backdrop-blur-sm">
    <div class="text-xl font-bold tracking-tighter playfair">INARI GLOBAL</div>
    <div class="hidden md:flex space-x-8 text-sm uppercase">
      <a href="/" class="hover:text-gold transition">Home</a>
    </div>
  </nav>

  <section class="min-h-screen pt-32 px-8 text-center">
    <h2 class="text-sm uppercase text-gray-500 mb-4">For Restaurants</h2>
    <h1 class="text-4xl md:text-6xl font-light playfair mb-8">Restaurant <span class="italic">Sourcing</span></h1>
    <p class="max-w-xl mx-auto text-gray-600 mb-12">專業餐飲客戶採購指南，歡迎酒店、日本料理店、粵菜餐廳合作。</p>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-8 max-w-4xl">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8">
          <div class="text-4xl mb-4">🏨</div>
          <h3 class="text-xl font-bold mb-2">五星級酒店</h3>
          <p class="text-gray-600 text-sm">自助餐、高端餐廳、宴會部門，專屬批發價，定期配送</p>
        </div>
        <div class="text-center p-8">
          <div class="text-4xl mb-4">🍣</div>
          <h3 class="text-xl font-bold mb-2">日本料理店</h3>
          <p class="text-gray-600 text-sm">壽司店、割烹、居酒屋，A級品質保証</p>
        </div>
        <div class="text-center p-8">
          <div class="text-4xl mb-4">🥢</div>
          <h3 class="text-xl font-bold mb-2">粵菜餐廳</h3>
          <p class="text-gray-600 text-sm">婚宴、私房菜、特色創新菜式</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-warm-gray">
    <div class="container mx-auto px-8 max-w-4xl">
      <h3 class="text-2xl playfair italic text-center mb-8">採購流程</h3>
      <div class="space-y-4">
        <div class="flex items-center gap-4 bg-white p-4 rounded">
          <div class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div><strong>聯繫我們</strong> - 電話或電郵咨詢</div>
        </div>
        <div class="flex items-center gap-4 bg-white p-4 rounded">
          <div class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div><strong>產品介紹</strong> - 根據需求推薦適合產品</div>
        </div>
        <div class="flex items-center gap-4 bg-white p-4 rounded">
          <div class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div><strong>試樣品</strong> - 首次採購可申請樣品</div>
        </div>
        <div class="flex items-center gap-4 bg-white p-4 rounded">
          <div class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div><strong>確認訂單</strong> - 達成採購協議</div>
        </div>
        <div class="flex items-center gap-4 bg-white p-4 rounded">
          <div class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center font-bold">5</div>
          <div><strong>定期配送</strong> - 穩定供貨服務</div>
        </div>
      </div>
    </div>
  </section>

  <footer class="py-12 text-center text-xs text-gray-400">
    Inari Global Foods &copy; 2026. 稻荷環球食品
  </footer>
</Layout>
