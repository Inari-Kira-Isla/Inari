---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>稻荷商城 — 新增訂單</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
  </head>
  <body>
    <!-- App header -->
    <div class="app-header">
      <button class="icon-btn" onclick="window.location.href='/shop'" aria-label="返回">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div style="margin-left:4px">
        <div style="font-family:var(--mono);font-size:10px;color:var(--mute);letter-spacing:.06em">VOICE / TEXT ENTRY</div>
        <div style="font-weight:700;font-size:15px;letter-spacing:-.01em">新增訂單</div>
      </div>
    </div>

    <!-- Scrollable content -->
    <div class="screen-scroll" style="flex:1">
      <!-- Mode switcher -->
      <div style="padding:14px 18px 8px;display:flex;justify-content:center">
        <div class="segmented">
          <button id="btn-voice" class="active" onclick="setMode('voice')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;margin-right:4px;vertical-align:-2px"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
            語音
          </button>
          <button id="btn-text" onclick="setMode('text')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;margin-right:4px;vertical-align:-2px"><path d="M4 7h16M9 7v12M15 7v12"/></svg>
            文字
          </button>
        </div>
      </div>

      <!-- Voice mode -->
      <div id="voice-panel">
        <div class="mic-stage">
          <button class="mic-btn" id="mic-btn" onclick="toggleRecording()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:56px;height:56px"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
          </button>
          <div class="mic-caption" id="mic-caption">按一下開始說話</div>
          <div style="padding:14px 18px;background:var(--paper-2);border-radius:12px;width:100%;font-size:15px;color:var(--ink);line-height:1.6;font-weight:500;text-wrap:pretty;min-height:52px" id="voice-transcript">
            （語音識別結果將顯示在這裡）
          </div>
        </div>
      </div>

      <!-- Text mode -->
      <div id="text-panel" style="display:none;padding:14px 18px">
        <textarea class="textarea" id="text-input"
          placeholder="輸入商品清單，每行一項。例如：&#10;海膽5盒&#10;扇貝10隻&#10;三文魚2kg"
          style="min-height:160px"></textarea>
        <button class="btn primary block" style="margin-top:12px" onclick="parseText('text')">
          辨識商品
        </button>
      </div>

      <!-- Parse results -->
      <div id="results-panel" style="display:none">
        <div class="section-head" style="padding-top:22px">
          <h2 id="results-title">辨識結果</h2>
          <span style="font-size:12px;font-family:var(--mono);color:var(--mute)" id="results-summary"></span>
        </div>
        <div style="padding:0 18px 4px" id="parsed-list"></div>

        <div style="padding:8px 18px 16px">
          <button style="width:100%;padding:12px;border:1px dashed var(--hairline-strong);border-radius:10px;color:var(--mute);font-size:13px;font-weight:500" onclick="addManualItem()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;vertical-align:-3px;margin-right:6px"><path d="M12 5v14M5 12h14"/></svg>
            手動加入商品
          </button>
        </div>

        <div style="padding:0 18px 12px">
          <div class="card" style="padding:14px 16px;display:flex;justify-content:space-between;align-items:baseline">
            <span style="font-size:12px;color:var(--mute);font-weight:600;text-transform:uppercase;letter-spacing:.06em">預計合計</span>
            <span style="font-family:var(--mono);font-size:20px;font-weight:700;color:var(--coral-deep)" id="results-total">MOP 0</span>
          </div>
        </div>
      </div>

      <div style="height:20px"></div>
    </div>

    <!-- Bottom CTA -->
    <div style="padding:12px 18px 18px;background:var(--paper);border-top:1px solid var(--hairline)">
      <button class="btn coral lg block" id="checkout-btn" onclick="handleCheckout()">
        確認並結帳
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

    <!-- Tab bar -->
    <nav class="tab-bar">
      <button onclick="window.location.href='/shop'" id="tab-home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11 12 4l8 7v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z"/></svg>
        <span>首頁</span>
      </button>
      <button onclick="window.location.href='/shop/catalog'" id="tab-catalog">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="7" height="7" rx="1"/><rect x="14" y="4" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span>目錄</span>
      </button>
      <button onclick="window.location.href='/shop/order/new'" id="tab-voice" class="active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
        <span>下單</span>
      </button>
      <button onclick="window.location.href='/shop/orders'" id="tab-orders">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h6a2 2 0 0 1 2 2v14l-5-2-5 2V6a2 2 0 0 1 2-2z"/></svg>
        <span>訂單</span>
      </button>
      <button onclick="window.location.href='/shop/checkout'" id="tab-cart" style="position:relative">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"/></svg>
        <span>購物車</span>
        <span class="dot" id="cart-dot" style="display:none"></span>
      </button>
    </nav>

    <script type="module">
      import { getAuth } from '/js/auth.js';
      const auth = getAuth();
      if (!auth.isLoggedIn) { window.location.href = '/shop/login'; }

      // Pre-fill customer for B2B (stored globally for order submission)
      window._customerCode = auth.user?.customer_code || '';

      // Cart dot
      try {
        const raw = localStorage.getItem('inari_cart');
        if (raw) {
          const c = JSON.parse(raw);
          const count = (c.items||[]).reduce((s,i)=>s+(i.qty||0),0);
          if (count > 0) document.getElementById('cart-dot').style.display = 'block';
        }
      } catch {}

      // Check for text mode URL param
      const urlMode = new URLSearchParams(location.search).get('mode');
      if (urlMode === 'text') window.setMode && window.setMode('text');
    </script>

    <script>
      let currentMode = 'voice';
      let recognition = null;
      let isRecording = false;
      let rawText = '';
      let parsedItems = [];

      // Mode toggle
      window.setMode = function(mode) {
        currentMode = mode;
        document.getElementById('btn-voice').classList.toggle('active', mode === 'voice');
        document.getElementById('btn-text').classList.toggle('active', mode === 'text');
        document.getElementById('voice-panel').style.display = mode === 'voice' ? '' : 'none';
        document.getElementById('text-panel').style.display = mode === 'text' ? '' : 'none';
      };

      // Check if mode param already set
      const urlMode = new URLSearchParams(location.search).get('mode');
      if (urlMode === 'text') setMode('text');

      // ── Voice recording ──
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      window.toggleRecording = function() {
        if (!SpeechRecognition) {
          document.getElementById('mic-caption').textContent = '此瀏覽器不支援語音識別，請用文字模式';
          return;
        }
        if (isRecording) stopRecording();
        else startRecording();
      };

      function startRecording() {
        recognition = new SpeechRecognition();
        recognition.lang = 'zh-HK';
        recognition.interimResults = true;
        recognition.continuous = true;

        recognition.onresult = (e) => {
          let interim = '', final = '';
          for (let i = e.resultIndex; i < e.results.length; i++) {
            if (e.results[i].isFinal) final += e.results[i][0].transcript;
            else interim += e.results[i][0].transcript;
          }
          const text = final || interim || '聆聽中...';
          document.getElementById('voice-transcript').textContent = `"${text}"`;
          if (final) rawText = (rawText + ' ' + final).trim();
        };

        recognition.onerror = (e) => {
          if (e.error === 'no-speech') return; // ignore silence timeout, onend will restart
          document.getElementById('mic-caption').textContent = `識別錯誤：${e.error}`;
          stopRecording();
        };

        // Auto-restart on silence so user can speak their full order before pressing stop
        recognition.onend = () => {
          if (isRecording) {
            try { recognition.start(); } catch { stopRecording(); }
          }
        };

        recognition.start();
        isRecording = true;
        document.getElementById('mic-btn').classList.add('active');
        document.getElementById('mic-caption').textContent = '正在聆聽… 粵語 zh-HK';
      }

      function stopRecording() {
        isRecording = false; // set first so onend doesn't restart
        if (recognition) { try { recognition.stop(); } catch {} recognition = null; }
        document.getElementById('mic-btn').classList.remove('active');
        const fullText = rawText.trim();
        if (fullText) {
          document.getElementById('voice-transcript').textContent = `"${fullText}"`;
          document.getElementById('mic-caption').textContent = '辨識完成，正在解析…';
          parseText('voice');
        } else {
          document.getElementById('mic-caption').textContent = '按一下開始說話';
        }
      }

      // ── Parse ──
      window.parseText = async function(source) {
        const text = source === 'voice'
          ? rawText || document.getElementById('voice-transcript').textContent.replace(/^"|"$/g,'')
          : document.getElementById('text-input').value.trim();

        if (!text || text.includes('語音識別結果')) {
          alert('請先輸入訂單內容');
          return;
        }

        document.getElementById('mic-caption').textContent = '解析中...';

        try {
          const res = await fetch('/api/voice/parse', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || '解析失敗');

          parsedItems = data.items || [];
          renderParsed();
          document.getElementById('mic-caption').textContent = '辨識完成，可修改後下單';
        } catch (err) {
          document.getElementById('mic-caption').textContent = '解析失敗：' + err.message;
        }
      };

      function renderParsed() {
        const panel = document.getElementById('results-panel');
        const list = document.getElementById('parsed-list');
        if (parsedItems.length === 0) { panel.style.display = 'none'; return; }

        panel.style.display = 'block';
        const kwCount = parsedItems.filter(r => r.match_confidence === 'keyword').length;
        const fzCount = parsedItems.filter(r => r.match_confidence === 'fuzzy').length;

        document.getElementById('results-title').textContent = `辨識結果 · ${parsedItems.length} 項`;
        document.getElementById('results-summary').textContent = `${kwCount} 確認 · ${fzCount} 模糊`;

        const total = parsedItems.reduce((s, r) => s + ((r.qty || 0) * (r.suggested_price || r.unit_price || 0)), 0);
        document.getElementById('results-total').textContent = `MOP ${total.toLocaleString('en-US',{maximumFractionDigits:0})}`;

        list.innerHTML = parsedItems.map((r, i) => {
          const matchCls = r.match_confidence === 'keyword' ? 'kw' : r.match_confidence === 'fuzzy' ? 'fz' : 'um';
          const matchLabel = r.match_confidence === 'keyword' ? 'KW' : r.match_confidence === 'fuzzy' ? 'FZ' : '?';
          const name = r.product_name || r.product_guess || '未知商品';
          const price = r.suggested_price || r.unit_price || 0;
          const qty = r.qty || 1;
          const unit = r.suggested_unit || r.unit || '件';
          const lineTotal = qty * price;

          return `
            <div class="parse-row ${matchCls}" id="parse-row-${i}">
              <div class="lead">${matchLabel}</div>
              <div>
                <div style="font-size:13px;font-weight:600;line-height:1.3">${name}</div>
                <div style="font-family:var(--mono);font-size:10.5px;color:var(--mute);margin-top:3px">${r.product_code || r.sku || ''}</div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:8px">
                  <div class="stepper" style="background:var(--paper-2)">
                    <button onclick="updateQty(${i},-1)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M5 12h14"/></svg>
                    </button>
                    <span class="val" id="qty-${i}">${qty}</span>
                    <button onclick="updateQty(${i},1)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M12 5v14M5 12h14"/></svg>
                    </button>
                  </div>
                  <span style="font-size:11px;color:var(--mute)">${unit}</span>
                  <span style="margin-left:auto;font-family:var(--mono);font-size:12px">
                    <span style="color:var(--mute)">×</span> MOP ${price.toLocaleString('en-US',{maximumFractionDigits:0})}
                  </span>
                </div>
              </div>
              <div style="font-family:var(--mono);font-weight:700;font-size:13px;align-self:flex-end">
                MOP ${lineTotal.toLocaleString('en-US',{maximumFractionDigits:0})}
              </div>
            </div>`;
        }).join('');
      }

      window.updateQty = function(i, delta) {
        parsedItems[i].qty = Math.max(1, (parsedItems[i].qty || 1) + delta);
        renderParsed();
      };

      window.addManualItem = function() {
        parsedItems.push({
          product_name: '手動商品',
          match_confidence: 'unmatched',
          qty: 1, unit: '件',
          suggested_price: 0, unit_price: 0,
        });
        renderParsed();
      };

      // ── Submit / Checkout ──
      window.handleCheckout = async function() {
        // If we have parse results, submit as order first then go to orders
        if (parsedItems.length > 0) {
          const customerCode = window._customerCode || '';
          if (!customerCode) {
            // No customer code — just save to cart and navigate to checkout
            navigateCheckout();
            return;
          }

          const btn = document.getElementById('checkout-btn');
          btn.disabled = true;
          btn.textContent = '提交中...';

          try {
            const res = await fetch('/api/orders', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                customer_code: customerCode,
                items: parsedItems,
                raw_text: rawText || document.getElementById('text-input')?.value || '',
                source: 'web',
              }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || '提交失敗');

            window.location.href = '/shop/order/confirmed?no=' + encodeURIComponent(data.order_no);
          } catch (err) {
            alert('提交失敗：' + err.message);
            btn.disabled = false;
            btn.innerHTML = '確認並結帳 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
          }
        } else {
          navigateCheckout();
        }
      };

      function navigateCheckout() {
        window.location.href = '/shop/checkout';
      }
    </script>
  </body>
</html>
