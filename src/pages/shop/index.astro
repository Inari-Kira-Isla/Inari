---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>稻荷商城</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "PingFang TC", "Noto Sans TC", sans-serif;
        background: #f8fafc;
        min-height: 100vh;
      }
      header {
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo { font-size: 18px; font-weight: 700; color: #3245ff; }
      .user-info { font-size: 13px; color: #6b7280; }
      .logout-btn {
        background: none;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        cursor: pointer;
        color: #6b7280;
      }
      .main { max-width: 600px; margin: 0 auto; padding: 24px 16px; }
      h2 { font-size: 22px; font-weight: 700; color: #111; margin-bottom: 20px; }
      .menu-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 32px;
      }
      .menu-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px 20px;
        text-decoration: none;
        color: #111;
        border: 1.5px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .menu-card:hover { border-color: #3245ff; box-shadow: 0 4px 16px rgba(50,69,255,0.08); }
      .menu-card.admin-card { border-color: #c0392b; }
      .menu-card.admin-card:hover { border-color: #a93226; box-shadow: 0 4px 16px rgba(192,57,43,0.15); }
      .menu-icon { font-size: 28px; }
      .menu-title { font-size: 15px; font-weight: 600; }
      .menu-desc { font-size: 12px; color: #9ca3af; }
      .recent-orders h3 { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
      .order-row {
        background: #fff;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid #e5e7eb;
      }
      .order-no { font-size: 13px; font-weight: 600; color: #3245ff; }
      .order-meta { font-size: 12px; color: #9ca3af; margin-top: 2px; }
      .status-badge {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 500;
      }
      .status-draft { background: #fef3c7; color: #92400e; }
      .status-confirmed { background: #d1fae5; color: #065f46; }
      .status-invoiced { background: #dbeafe; color: #1e3a8a; }
      .empty { text-align: center; color: #9ca3af; font-size: 14px; padding: 32px 0; }
    </style>
  </head>
  <body>
    <header>
      <div class="logo">稻荷商城</div>
      <div style="display:flex;align-items:center;gap:12px">
        <span id="user-display" class="user-info"></span>
        <button class="logout-btn" onclick="logout()">登出</button>
      </div>
    </header>

    <div class="main">
      <h2>你好 👋</h2>

      <div class="menu-grid">
        <a href="/shop/order/new" class="menu-card">
          <div class="menu-icon">🎙️</div>
          <div class="menu-title">語音下單</div>
          <div class="menu-desc">說出訂單，自動識別商品</div>
        </a>
        <a href="/shop/orders" class="menu-card">
          <div class="menu-icon">📋</div>
          <div class="menu-title">訂單記錄</div>
          <div class="menu-desc">查看歷史訂單狀態</div>
        </a>
        <a href="/shop/search" class="menu-card">
          <div class="menu-icon">🔍</div>
          <div class="menu-title">商品搜尋</div>
          <div class="menu-desc">搜尋稻荷商品目錄</div>
        </a>
        <a href="/shop/order/new?mode=text" class="menu-card">
          <div class="menu-icon">✏️</div>
          <div class="menu-title">文字下單</div>
          <div class="menu-desc">手動輸入訂單明細</div>
        </a>
        <a href="/shop/catalog" class="menu-card">
          <div class="menu-icon">🛒</div>
          <div class="menu-title">商品目錄</div>
          <div class="menu-desc">瀏覽商品，加入購物車</div>
        </a>
        <a href="/shop/checkout" class="menu-card">
          <div class="menu-icon">💳</div>
          <div class="menu-title">購物車結帳</div>
          <div class="menu-desc" id="cart-count-desc">查看購物車並結帳</div>
        </a>
      </div>

      <div class="recent-orders">
        <h3>最近訂單</h3>
        <div id="orders-list"><div class="empty">載入中...</div></div>
      </div>
    </div>

    <script type="module">
      import { getAuth, logout as doLogout } from '/js/auth.js';

      const auth = getAuth();
      if (!auth.isLoggedIn) { window.location.href = '/shop/login'; }

      const display = document.getElementById('user-display');
      if (auth.user) {
        display.textContent = auth.user.username + (auth.user.customer_code ? ` (${auth.user.customer_code})` : '');
      }

      window.logout = () => { doLogout(); };

      // Show cart count in checkout card
      try {
        const cartRaw = localStorage.getItem('inari_cart');
        if (cartRaw) {
          const cart = JSON.parse(cartRaw);
          const count = (cart.items || []).reduce((s, i) => s + (i.qty || 0), 0);
          if (count > 0) {
            const desc = document.getElementById('cart-count-desc');
            if (desc) desc.textContent = `購物車 ${count} 件商品`;
          }
        }
      } catch {}

      if (auth.isStaff || auth.user?.user_type === 'manager') {
        const menuGrid = document.querySelector('.menu-grid');
        if (menuGrid) {
          const adminCard = document.createElement('a');
          adminCard.href = '/shop/admin/orders';
          adminCard.className = 'menu-card admin-card';
          adminCard.innerHTML = '<div class="menu-icon">⚙️</div><div class="menu-title">訂單管理</div><div class="menu-desc">查看/確認/開單</div>';
          menuGrid.appendChild(adminCard);
        }
      }

      // Load recent orders
      fetch('/api/orders?limit=5')
        .then(r => r.json())
        .then(data => {
          const list = document.getElementById('orders-list');
          const orders = data.orders || [];
          if (orders.length === 0) {
            list.innerHTML = '<div class="empty">暫無訂單記錄</div>';
            return;
          }
          list.innerHTML = orders.map(o => `
            <div class="order-row">
              <div>
                <div class="order-no">${o.order_no}</div>
                <div class="order-meta">${o.customer_name || o.customer_code} · ${o.order_date}</div>
              </div>
              <span class="status-badge status-${o.status}">${statusLabel(o.status)}</span>
            </div>
          `).join('');
        })
        .catch(() => {
          document.getElementById('orders-list').innerHTML = '<div class="empty">無法載入訂單</div>';
        });

      function statusLabel(s) {
        return {draft:'草稿',confirmed:'已確認',invoiced:'已開票',cancelled:'已取消'}[s] || s;
      }
    </script>
  </body>
</html>
