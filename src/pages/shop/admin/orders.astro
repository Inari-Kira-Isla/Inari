---
---
<!doctype html>
<html lang="zh-TW" class="admin-layout">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow">
    <title>稻荷商城 — 訂單管理</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
    <style>
      /* Admin is desktop-first — override mobile body constraint */
      html.admin-layout body {
        max-width: none;
        display: block;
        min-height: 100vh;
        min-height: 100dvh;
      }
    </style>
  </head>
  <body>
    <div class="admin-shell">
      <!-- Sidebar -->
      <aside class="admin-side">
        <div class="brand">
          <div class="mark">稻</div>
          <div>
            <div style="font-weight:700;font-size:14px">稻荷商城</div>
            <div style="font-size:10px;font-family:var(--mono);color:oklch(70% 0.01 240);margin-top:1px">STAFF · 管理</div>
          </div>
        </div>

        <div class="sect">營運</div>
        <div class="navitem active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h6a2 2 0 0 1 2 2v14l-5-2-5 2V6a2 2 0 0 1 2-2z"/></svg>
          訂單管理
        </div>
        <div class="navitem">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h12l4 4v12H4z"/><path d="M8 12h8M8 16h5M8 8h4"/></svg>
          商品庫存
        </div>
        <div class="navitem">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0M16 11a3.5 3.5 0 0 0 0-7M21 20a6 6 0 0 0-3.5-5.5"/></svg>
          客戶管理
        </div>
        <div class="navitem">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
          物流出貨
        </div>

        <div class="sect">系統</div>
        <div class="navitem">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 0 0-.1-1.2l2-1.5-2-3.4-2.3.9a7 7 0 0 0-2-1.2l-.4-2.5h-4l-.4 2.5a7 7 0 0 0-2 1.2L5.4 6 3.4 9.4l2 1.5A7 7 0 0 0 5 12a7 7 0 0 0 .1 1.2l-2 1.5 2 3.4 2.3-.9a7 7 0 0 0 2 1.2l.4 2.5h4l.4-2.5a7 7 0 0 0 2-1.2l2.3.9 2-3.4-2-1.5A7 7 0 0 0 19 12z"/></svg>
          設定
        </div>
        <div class="navitem" onclick="window.location.href='/shop'" style="cursor:pointer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11 12 4l8 7v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z"/></svg>
          返回商城
        </div>

        <!-- User footer -->
        <div style="margin-top:auto;padding:14px 10px;display:flex;align-items:center;gap:10px">
          <div style="width:32px;height:32px;border-radius:50%;background:var(--coral);color:white;display:grid;place-items:center;font-weight:700;flex-shrink:0" id="staff-avatar">—</div>
          <div>
            <div style="font-size:12px;font-weight:600" id="staff-name">員工</div>
            <div style="font-size:10px;color:oklch(70% 0.01 240);font-family:var(--mono)" id="staff-role">STAFF</div>
          </div>
        </div>
      </aside>

      <!-- Main panel -->
      <div class="admin-main">
        <div class="admin-top">
          <div>
            <div style="font-size:10px;color:var(--mute);letter-spacing:.1em;text-transform:uppercase;font-family:var(--mono);margin-bottom:2px" id="today-label">—</div>
            <h1>訂單管理</h1>
          </div>
          <div style="display:flex;align-items:center;gap:10px">
            <button class="btn ghost sm" onclick="exportOrders()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M4 5h16l-6 8v5l-4 2v-7z"/></svg>
              匯出
            </button>
            <button class="btn primary sm" onclick="alert('請透過語音下單或商城下單建立訂單')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M12 5v14M5 12h14"/></svg>
              手動建單
            </button>
          </div>
        </div>

        <div class="admin-body">
          <!-- Stats grid -->
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px">
            <div class="stat-card">
              <div class="lbl">草稿待確認</div>
              <div class="val" id="stat-draft">—</div>
              <div class="sub">需 staff 處理</div>
            </div>
            <div class="stat-card">
              <div class="lbl">已確認</div>
              <div class="val" style="color:var(--leaf-ink)" id="stat-confirmed">—</div>
              <div class="sub">準備出貨</div>
            </div>
            <div class="stat-card">
              <div class="lbl">已開單</div>
              <div class="val" style="color:var(--sea-ink)" id="stat-invoiced">—</div>
              <div class="sub">本週累計</div>
            </div>
            <div class="stat-card accent">
              <div class="lbl">今日金額</div>
              <div class="val" id="stat-amount">MOP —</div>
              <div class="sub" id="stat-orders-count">— 張訂單</div>
            </div>
          </div>

          <!-- Filter bar -->
          <div class="card" style="padding:12px 14px;margin-bottom:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <input class="input" id="f-date" type="date" style="width:160px;padding:8px 12px" onchange="loadOrders()" />
            <select class="select input" id="f-status" style="width:160px;padding:8px 12px" onchange="loadOrders()">
              <option value="">全部狀態</option>
              <option value="draft">草稿</option>
              <option value="confirmed">已確認</option>
              <option value="invoiced">已開單</option>
              <option value="cancelled">已取消</option>
            </select>
            <input class="input" id="f-customer" type="text" style="flex:1;min-width:160px;padding:8px 12px" placeholder="搜尋客戶或訂單號…" oninput="debouncedLoad()" />
            <button class="btn primary sm" onclick="loadOrders()">查詢</button>
          </div>

          <!-- Table -->
          <div class="card" style="overflow:hidden">
            <div style="overflow-x:auto">
              <table class="tbl">
                <thead>
                  <tr>
                    <th>單號</th>
                    <th>客戶</th>
                    <th>日期</th>
                    <th>品項</th>
                    <th style="text-align:right">金額</th>
                    <th>付款</th>
                    <th>狀態</th>
                    <th style="text-align:right">操作</th>
                  </tr>
                </thead>
                <tbody id="orders-tbody">
                  <tr><td colspan="8" style="text-align:center;padding:32px;color:var(--mute);font-size:13px">載入中...</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Pagination info -->
          <div style="margin-top:14px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--mute)">
            <span id="pagination-info">顯示 — 張</span>
            <div style="display:flex;gap:6px">
              <button class="btn ghost sm">上一頁</button>
              <button class="btn ghost sm">下一頁</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast -->
    <div id="admin-toast" style="position:fixed;bottom:28px;right:24px;background:var(--ink);color:var(--paper);padding:12px 20px;border-radius:8px;font-size:14px;opacity:0;transition:opacity .3s;pointer-events:none;z-index:100"></div>

    <script type="module">
      import { getAuth, logout as doLogoutFn } from '/js/auth.js';

      const auth = await getAuth();
      if (!auth.isLoggedIn || (!auth.isStaff && auth.user?.user_type !== 'manager')) {
        window.location.href = '/shop/login';
      }

      // Staff info
      if (auth.user) {
        const name = auth.user.full_name || auth.user.username || '員工';
        document.getElementById('staff-name').textContent = name;
        document.getElementById('staff-avatar').textContent = name[0] || '員';
        document.getElementById('staff-role').textContent = auth.user.user_type === 'manager' ? 'MANAGER' : 'STAFF';
      }
    </script>

    <script>
      const todayStr = () => new Date().toISOString().slice(0, 10);
      const days = ['週日','週一','週二','週三','週四','週五','週六'];
      const now = new Date();
      document.getElementById('today-label').textContent =
        `${now.getFullYear()} / ${String(now.getMonth()+1).padStart(2,'0')} / ${String(now.getDate()).padStart(2,'0')} · ${days[now.getDay()]}`;
      document.getElementById('f-date').value = todayStr();

      const STATUS_LABELS = { draft:'草稿', confirmed:'已確認', invoiced:'已開單', cancelled:'已取消' };

      function statusBadge(status) {
        const map = {
          draft: ['amber','草稿'],
          confirmed: ['leaf','已確認'],
          invoiced: ['sea','已開單'],
          cancelled: ['slate','已取消'],
        };
        const [tone, label] = map[status] || ['amber','草稿'];
        return `<span class="badge ${tone}"><span class="dot"></span>${label}</span>`;
      }

      function showToast(msg, duration = 2800) {
        const t = document.getElementById('admin-toast');
        t.textContent = msg;
        t.style.opacity = '1';
        t.style.pointerEvents = 'auto';
        setTimeout(() => { t.style.opacity = '0'; t.style.pointerEvents = 'none'; }, duration);
      }

      function fmtMOP(n) {
        return 'MOP ' + Number(n||0).toLocaleString('en-US',{maximumFractionDigits:0});
      }

      function esc(s) {
        if (s == null) return '';
        return String(s)
          .replace(/&/g,'&amp;')
          .replace(/</g,'&lt;')
          .replace(/>/g,'&gt;')
          .replace(/"/g,'&quot;');
      }

      function calcTotal(order) {
        const items = order.inari_customer_order_items || [];
        return items.reduce((s, i) => s + Number(i.amount || i.line_total || (i.qty * (i.unit_price || 0)) || 0), 0);
      }

      let debounceTimer;
      window.debouncedLoad = () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(loadOrders, 400);
      };

      window.loadOrders = async function() {
        const tbody = document.getElementById('orders-tbody');
        tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--mute);font-size:13px">載入中...</td></tr>';

        const date = document.getElementById('f-date').value;
        const status = document.getElementById('f-status').value;
        const customer = document.getElementById('f-customer').value;

        const params = new URLSearchParams();
        if (date) params.set('date', date);
        if (status) params.set('status', status);
        if (customer) params.set('customer', customer);

        try {
          const res = await fetch('/api/admin/orders?' + params.toString());
          if (res.status === 401) { window.location.href = '/shop/login'; return; }
          const { orders = [] } = await res.json();
          renderOrders(orders);
          updateStats(orders, date || todayStr());
        } catch {
          tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--mute);font-size:13px">載入失敗，請重試</td></tr>';
        }
      };

      function renderOrders(orders) {
        const tbody = document.getElementById('orders-tbody');
        document.getElementById('pagination-info').textContent = `顯示 ${orders.length} 張`;

        if (!orders.length) {
          tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--mute);font-size:13px">無訂單記錄</td></tr>';
          return;
        }

        const micSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:10px;height:10px"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>`;
        const bagSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="width:10px;height:10px"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"/></svg>`;

        tbody.innerHTML = orders.map(o => {
          const items = o.inari_customer_order_items || [];
          const preview = items.slice(0,2).map(i => i.product_name || i.product_code).filter(Boolean).join('、');
          const more = items.length > 2 ? ` +${items.length - 2}` : '';
          const total = calcTotal(o);
          const payLabel = o.payment_method || '-';
          const isMic = o.source === 'voice';

          let actions = '';
          if (o.status === 'draft') {
            actions = `
              <button style="background:var(--leaf-soft);color:var(--leaf-ink);font-size:11px;padding:6px 10px;border-radius:var(--r-sm);font-weight:600"
                onclick="updateStatus('${o.id}','confirmed')">確認訂單</button>
              <button style="background:var(--paper-2);color:var(--ink-2);font-size:11px;padding:6px 10px;border-radius:var(--r-sm);font-weight:600"
                onclick="updateStatus('${o.id}','cancelled')">取消</button>`;
          } else if (o.status === 'confirmed') {
            actions = `
              <button style="background:var(--sea-soft);color:var(--sea-ink);font-size:11px;padding:6px 10px;border-radius:var(--r-sm);font-weight:600"
                onclick="updateStatus('${o.id}','invoiced')">標記開單</button>
              <button style="background:var(--paper-2);color:var(--ink-2);font-size:11px;padding:6px 10px;border-radius:var(--r-sm);font-weight:600"
                onclick="updateStatus('${o.id}','cancelled')">取消</button>`;
          } else {
            actions = '<span style="font-size:11px;color:var(--mute)">—</span>';
          }

          return `<tr>
            <td>
              <div class="mono" style="font-weight:600;color:var(--ink)">${esc(o.order_no)}</div>
              <div style="font-size:10.5px;color:var(--mute);margin-top:3px;display:flex;align-items:center;gap:4px">
                ${isMic ? micSvg : bagSvg} ${isMic ? '語音' : 'Web'}
              </div>
            </td>
            <td>
              <div style="font-weight:600">${esc(o.customer_name || o.customer_code)}</div>
              <div class="mono" style="font-size:10.5px;color:var(--mute);margin-top:3px">${esc(o.customer_code || '')}</div>
            </td>
            <td>
              <div>${esc(o.order_date ? o.order_date.slice(5) : '-')}</div>
              <div style="font-size:10.5px;color:var(--mute);margin-top:3px">送 ${esc(o.delivery_date ? o.delivery_date.slice(5) : '-')}</div>
            </td>
            <td>
              <div style="font-size:12px;line-height:1.5;max-width:220px;color:var(--ink-2)">
                ${esc(preview)}${more ? `<span style="color:var(--mute)"> ${esc(more)}</span>` : ''}
              </div>
              <div class="mono" style="font-size:10.5px;color:var(--mute);margin-top:3px">${items.length} 項</div>
            </td>
            <td style="text-align:right">
              <div class="num" style="color:var(--coral-deep)">${fmtMOP(total)}</div>
            </td>
            <td>
              <span class="badge slate sq">${esc(payLabel)}</span>
            </td>
            <td>${statusBadge(o.status)}</td>
            <td style="text-align:right">
              <div style="display:inline-flex;gap:6px">${actions}</div>
            </td>
          </tr>`;
        }).join('');
      }

      function updateStats(orders, filterDate) {
        document.getElementById('stat-draft').textContent = orders.filter(o => o.status === 'draft').length;
        document.getElementById('stat-confirmed').textContent = orders.filter(o => o.status === 'confirmed').length;
        document.getElementById('stat-invoiced').textContent = orders.filter(o => o.status === 'invoiced').length;
        const todayOrders = filterDate ? orders.filter(o => o.order_date === filterDate) : orders;
        const totalAmt = todayOrders.reduce((s, o) => s + calcTotal(o), 0);
        document.getElementById('stat-amount').textContent = fmtMOP(totalAmt);
        document.getElementById('stat-orders-count').textContent = `${todayOrders.length} 張訂單`;
      }

      window.updateStatus = async function(id, status) {
        const msgs = {
          confirmed: '確認此訂單？',
          invoiced: '標記為已開單？',
          cancelled: '確定取消此訂單？這個動作無法撤銷。',
        };
        if (!confirm(msgs[status] || '確認操作？')) return;

        try {
          const res = await fetch('/api/admin/orders/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status }),
          });
          const data = await res.json();
          if (data.ok) {
            showToast('已更新：' + (STATUS_LABELS[status] || status));
            loadOrders();
          } else {
            showToast('操作失敗: ' + (data.error || '請重試'));
          }
        } catch {
          showToast('網絡錯誤，請重試');
        }
      };

      window.exportOrders = function() {
        const date = document.getElementById('f-date').value;
        const status = document.getElementById('f-status').value;
        const params = new URLSearchParams();
        if (date) params.set('date', date);
        if (status) params.set('status', status);
        params.set('format', 'csv');
        window.open('/api/admin/orders/export?' + params.toString(), '_blank');
      };

      // Init
      loadOrders();
    </script>
  </body>
</html>
