---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>稻荷商城 — 商品搜尋</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
  </head>
  <body>
    <!-- App header with search -->
    <div class="app-header">
      <button class="icon-btn" onclick="window.location.href='/shop'" aria-label="返回">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div style="flex:1;padding:0 8px">
        <div style="position:relative">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
            style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--mute);pointer-events:none">
            <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
          </svg>
          <input class="search-input" id="search-input" placeholder="搜尋 SKU、品名、別稱…" autofocus
            oninput="onSearchInput(this.value)" />
        </div>
      </div>
    </div>

    <!-- Scrollable content -->
    <div class="screen-scroll" style="flex:1" id="scroll-area">
      <!-- Default state: recent + trending -->
      <div id="default-state">
        <div class="section-head"><h2>最近搜尋</h2></div>
        <div style="padding:0 18px 18px;display:flex;flex-wrap:wrap;gap:8px">
          <button class="pill" onclick="fillSearch('海膽')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;color:var(--mute)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            海膽
          </button>
          <button class="pill" onclick="fillSearch('扇貝')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;color:var(--mute)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            扇貝
          </button>
          <button class="pill" onclick="fillSearch('A1A0005')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;color:var(--mute)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            A1A0005
          </button>
          <button class="pill" onclick="fillSearch('三文魚')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;color:var(--mute)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            三文魚
          </button>
          <button class="pill" onclick="fillSearch('毛蟹')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;color:var(--mute)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            毛蟹
          </button>
        </div>

        <div class="section-head"><h2>熱門關鍵字</h2></div>
        <div style="padding:0 18px 28px;display:flex;flex-direction:column;gap:1px">
          <button style="padding:12px 4px;border-bottom:1px solid var(--hairline);width:100%;text-align:left;display:flex;align-items:center;justify-content:space-between" onclick="fillSearch('北海道海膽')">
            <div>
              <div style="font-size:13px;font-weight:600">北海道海膽</div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--mute);margin-top:2px">A1A0005</div>
            </div>
            <div style="font-family:var(--mono);font-weight:700;color:var(--coral-deep)">MOP 550</div>
          </button>
          <button style="padding:12px 4px;border-bottom:1px solid var(--hairline);width:100%;text-align:left;display:flex;align-items:center;justify-content:space-between" onclick="fillSearch('築地本鮪赤身')">
            <div>
              <div style="font-size:13px;font-weight:600">築地本鮪赤身</div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--mute);margin-top:2px">A2C0021</div>
            </div>
            <div style="font-family:var(--mono);font-weight:700;color:var(--coral-deep)">MOP 1,280</div>
          </button>
          <button style="padding:12px 4px;border-bottom:1px solid var(--hairline);width:100%;text-align:left;display:flex;align-items:center;justify-content:space-between" onclick="fillSearch('青森活帆立貝')">
            <div>
              <div style="font-size:13px;font-weight:600">青森活帆立貝</div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--mute);margin-top:2px">A1B0012</div>
            </div>
            <div style="font-family:var(--mono);font-weight:700;color:var(--coral-deep)">MOP 285</div>
          </button>
          <button style="padding:12px 4px;border-bottom:1px solid var(--hairline);width:100%;text-align:left;display:flex;align-items:center;justify-content:space-between" onclick="fillSearch('木魚花')">
            <div>
              <div style="font-size:13px;font-weight:600">寬永木魚花</div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--mute);margin-top:2px">KK0007</div>
            </div>
            <div style="font-family:var(--mono);font-weight:700;color:var(--coral-deep)">MOP 92</div>
          </button>
        </div>
      </div>

      <!-- Results state -->
      <div id="results-state" style="display:none">
        <div style="padding:14px 18px 8px;font-size:12px;color:var(--mute)">
          <span style="font-family:var(--mono);color:var(--ink);font-weight:600" id="result-count">0</span> 個結果
        </div>
        <div style="padding:0 18px 28px;display:flex;flex-direction:column;gap:10px" id="result-list"></div>
      </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast">
      <span class="check">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px"><path d="m5 12 5 5L20 7"/></svg>
      </span>
      <span id="toast-msg"></span>
    </div>

    <script type="module">
      import { getAuth } from '/js/auth.js';
      const auth = getAuth();
      if (!auth.isLoggedIn) { window.location.href = '/shop/login'; }
    </script>

    <script>
      let searchTimer;

      window.fillSearch = function(q) {
        const input = document.getElementById('search-input');
        input.value = q;
        doSearch(q);
      };

      window.onSearchInput = function(val) {
        clearTimeout(searchTimer);
        const q = val.trim();
        if (!q) {
          document.getElementById('default-state').style.display = '';
          document.getElementById('results-state').style.display = 'none';
          return;
        }
        searchTimer = setTimeout(() => doSearch(q), 300);
      };

      function typeBadge(item) {
        if (item.is_air_freight) return `<span class="badge gold sq">空運</span>`;
        if (item.storage_type === '冷凍') return `<span class="badge ice sq">冷凍</span>`;
        return `<span class="badge leaf sq">冰鮮</span>`;
      }

      function showToast(msg) {
        const t = document.getElementById('toast');
        document.getElementById('toast-msg').textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2200);
      }

      function addToCartLocal(sku, name, price, unit) {
        try {
          const raw = localStorage.getItem('inari_cart');
          const c = raw ? JSON.parse(raw) : { items: [] };
          if (!c.items) c.items = [];
          const idx = c.items.findIndex(i => i.sku === sku);
          if (idx >= 0) {
            c.items[idx].qty++;
            c.items[idx].line_total = c.items[idx].qty * c.items[idx].unit_price;
          } else {
            c.items.push({ sku, product_name: name, qty: 1, unit, unit_price: price, line_total: price });
          }
          localStorage.setItem('inari_cart', JSON.stringify(c));
          showToast(`已加入 ${name.slice(0,12)}…`);
        } catch {}
      }

      async function doSearch(q) {
        document.getElementById('default-state').style.display = 'none';
        document.getElementById('results-state').style.display = '';
        document.getElementById('result-list').innerHTML = '<div style="padding:20px;text-align:center;color:var(--mute);font-size:13px">搜尋中…</div>';

        try {
          const res = await fetch(`/api/products/search?q=${encodeURIComponent(q)}&limit=20`);
          const data = await res.json();
          const items = data.results || data.items || [];

          document.getElementById('result-count').textContent = items.length;

          if (items.length === 0) {
            document.getElementById('result-list').innerHTML =
              `<div style="padding:40px;text-align:center;color:var(--mute);font-size:13px">無符合結果</div>`;
            return;
          }

          document.getElementById('result-list').innerHTML = items.map(p => {
            const sku = p.sku || p.product_code || '';
            const name = p.name || p.product_name || '';
            const price = p.sales_price || p.price || 0;
            const unit = p.unit || '件';
            return `
              <div class="card" style="display:flex;align-items:center;gap:12px;padding:10px">
                <div style="width:56px;height:56px;border-radius:8px;display:grid;place-items:center;flex-shrink:0;background:var(--mist);position:relative">
                  <span style="font-size:22px;color:oklch(35% 0.04 240 / .55)">🐟</span>
                </div>
                <div style="flex:1;min-width:0">
                  <div style="display:flex;gap:6px;align-items:center;margin-bottom:3px;flex-wrap:wrap">
                    ${typeBadge(p)}
                    <span style="font-family:var(--mono);font-size:10px;color:var(--mute)">${sku}</span>
                  </div>
                  <div style="font-size:13px;font-weight:600;line-height:1.3">${name}</div>
                  <div style="font-family:var(--mono);font-size:12px;color:var(--coral-deep);font-weight:700;margin-top:4px">
                    MOP ${Number(price).toLocaleString('en-US',{maximumFractionDigits:0})}
                    <span style="color:var(--mute);font-weight:500">/ ${unit}</span>
                  </div>
                </div>
                <button class="add" onclick="addToCartLocal('${sku}','${name.replace(/'/g,"\\'")}',${price},'${unit}')" aria-label="加入購物車">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>`;
          }).join('');
        } catch {
          document.getElementById('result-list').innerHTML =
            '<div style="padding:40px;text-align:center;color:var(--mute);font-size:13px">搜尋失敗，請稍後重試</div>';
        }
      }
    </script>
  </body>
</html>
