---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow">
    <title>稻荷商城 — 登入</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
    <style>
      /* Login page: full-bleed dark gradient background */
      html, body {
        height: 100%;
        max-width: none;
      }
      body {
        max-width: none;
        background: radial-gradient(120% 60% at 50% 0%, oklch(40% 0.08 232), oklch(20% 0.04 240)), var(--sea);
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }
    </style>
  </head>
  <body>
    <div class="login-stage">
      <!-- Logo + brand -->
      <div style="flex:1;display:flex;flex-direction:column;justify-content:flex-start">
        <div style="display:flex;align-items:center;gap:12px">
          <div style="width:44px;height:44px;background:var(--paper);color:var(--sea-ink);display:grid;place-items:center;border-radius:12px;font-weight:700;font-size:22px;letter-spacing:0;flex-shrink:0">稻</div>
          <div>
            <div style="font-weight:700;font-size:18px;letter-spacing:-.01em">稻荷商城</div>
            <div style="font-family:var(--mono);font-size:10px;opacity:.7;letter-spacing:.1em">INARI · MARKET</div>
          </div>
        </div>

        <div style="margin-top:56px">
          <div style="font-size:11px;font-weight:600;letter-spacing:.14em;opacity:.65;text-transform:uppercase">歡迎回來 · 専業海鮮食材直送</div>
          <h1 style="font-size:32px;font-weight:300;line-height:1.15;letter-spacing:-.02em;margin:14px 0 0;text-wrap:pretty">
            來自<span style="font-weight:700;font-style:italic"> 北海道 </span>築地<br>的早班空運。
          </h1>
          <div style="margin-top:10px;font-size:13px;opacity:.8;line-height:1.6">
            B2B 採購員專屬入口 · 月結 / 現金 / 即時下單
          </div>
        </div>
      </div>

      <!-- Login sheet -->
      <div style="background:var(--paper);color:var(--ink);margin:0 -28px -36px;padding:28px 28px 40px;border-radius:24px 24px 0 0;display:flex;flex-direction:column;gap:14px">
        <div class="field">
          <label>用戶名 · USERNAME</label>
          <input class="input" id="username" type="text" placeholder="如 ab001_sawada" autocomplete="username" />
        </div>
        <div class="field">
          <label>密碼 · PASSWORD</label>
          <input class="input" id="password" type="password" placeholder="••••••••" autocomplete="current-password" />
        </div>
        <p id="error-msg" style="font-size:12px;color:var(--coral-deep);min-height:16px;margin:0"></p>
        <button class="btn primary lg block" id="submit-btn" style="margin-top:4px">
          登入
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--mute);margin-top:4px">
          <span>B2B 採購員入口</span>
          <a style="color:var(--sea);font-weight:500" href="#">忘記密碼？</a>
        </div>
      </div>
    </div>

    <script>
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;

      async function handleLogin() {
        const username = (document.getElementById('username') as HTMLInputElement).value.trim();
        const password = (document.getElementById('password') as HTMLInputElement).value;

        errorMsg.textContent = '';
        submitBtn.disabled = true;
        submitBtn.textContent = '登入中...';

        try {
          const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password }),
          });

          const data = await res.json();

          if (res.ok) {
            const params = new URLSearchParams(window.location.search);
            const next = params.get('next');
            if (next) {
              window.location.href = decodeURIComponent(next);
            } else if (data.user_type === 'wholesale') {
              window.location.href = '/wholesale/';
            } else if (data.user_type === 'staff' || data.user_type === 'manager') {
              window.location.href = '/admin/';
            } else {
              window.location.href = '/shop';
            }
          } else {
            errorMsg.textContent = data.error || '登入失敗，請再試一次';
            (document.getElementById('password') as HTMLInputElement).value = '';
            (document.getElementById('password') as HTMLInputElement).focus();
          }
        } catch {
          errorMsg.textContent = '網絡錯誤，請稍後再試';
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = '登入 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
        }
      }

      submitBtn.addEventListener('click', handleLogin);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') handleLogin();
      });
    </script>
  </body>
</html>
