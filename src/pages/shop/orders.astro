---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow">
    <title>稻荷商城 — 訂單記錄</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
    <style>
      /* 07-23修：訂單詳情由「連去唔存在嘅 /shop/orders/{id} 頁」(404) 改做原地展開，
         同 /account 頁一致嘅 accordion 模式 */
      .order-body { display: none; padding: 0 16px 14px; border-top: 1px solid var(--hairline); }
      .card.open .order-body { display: block; }
      .card.open .order-chevron { transform: rotate(90deg); }
      .order-chevron { transition: transform .2s; flex-shrink: 0; }
      .item-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--hairline); font-size: 12px; }
      .item-row:last-child { border-bottom: none; }
    </style>
  </head>
  <body>
    <!-- App header -->
    <div class="app-header">
      <button class="icon-btn" onclick="window.location.href='/shop'" aria-label="返回">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div style="margin-left:4px">
        <div style="font-family:var(--mono);font-size:10px;color:var(--mute);letter-spacing:.06em">ORDER HISTORY</div>
        <div style="font-weight:700;font-size:15px;letter-spacing:-.01em">訂單記錄</div>
      </div>
    </div>

    <!-- Scrollable content -->
    <div class="screen-scroll" style="flex:1">
      <!-- Page title -->
      <div class="page-title" style="padding-top:10px;padding-bottom:4px">
        <div class="eyebrow" id="orders-eyebrow">最近 100 張</div>
        <h1 style="font-size:22px">您的訂單</h1>
      </div>

      <!-- Filter pills -->
      <div class="pill-rail" id="filter-rail">
        <button class="pill active" data-filter="all" onclick="setFilter('all',this)">全部 <span class="ct" id="ct-all">0</span></button>
        <button class="pill" data-filter="draft" onclick="setFilter('draft',this)">草稿 <span class="ct" id="ct-draft">0</span></button>
        <button class="pill" data-filter="confirmed" onclick="setFilter('confirmed',this)">已確認 <span class="ct" id="ct-confirmed">0</span></button>
        <button class="pill" data-filter="invoiced" onclick="setFilter('invoiced',this)">已開單 <span class="ct" id="ct-invoiced">0</span></button>
        <button class="pill" data-filter="cancelled" onclick="setFilter('cancelled',this)">已取消 <span class="ct" id="ct-cancelled">0</span></button>
      </div>

      <!-- Orders list -->
      <div style="padding:4px 18px 100px;display:flex;flex-direction:column;gap:10px" id="orders-list">
        <div style="padding:32px;text-align:center;color:var(--mute);font-size:13px">載入中...</div>
      </div>
    </div>

    <!-- FAB -->
    <button class="fab" onclick="window.location.href='/shop/order/new'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M12 5v14M5 12h14"/></svg>
      新增訂單
    </button>

    <!-- Tab bar -->
    <nav class="tab-bar">
      <button onclick="window.location.href='/shop'" id="tab-home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11 12 4l8 7v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z"/></svg>
        <span>首頁</span>
      </button>
      <button onclick="window.location.href='/shop/catalog'" id="tab-catalog">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="7" height="7" rx="1"/><rect x="14" y="4" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span>目錄</span>
      </button>
      <button onclick="window.location.href='/shop/order/new'" id="tab-voice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
        <span>下單</span>
      </button>
      <button onclick="window.location.href='/shop/orders'" id="tab-orders" class="active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h6a2 2 0 0 1 2 2v14l-5-2-5 2V6a2 2 0 0 1 2-2z"/></svg>
        <span>訂單</span>
      </button>
      <button onclick="window.location.href='/shop/checkout'" id="tab-cart" style="position:relative">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"/></svg>
        <span>購物車</span>
        <span class="dot" id="cart-dot" style="display:none"></span>
      </button>
    </nav>

    <script type="module">
      import { getAuth } from '/js/auth.js';
      const auth = await getAuth();
      if (!auth.isLoggedIn) { window.location.href = '/shop/login'; }

      // Cart dot
      try {
        const raw = localStorage.getItem('inari_cart');
        if (raw) {
          const c = JSON.parse(raw);
          const count = (c.items||[]).reduce((s,i)=>s+(i.qty||0),0);
          if (count > 0) document.getElementById('cart-dot').style.display = 'block';
        }
      } catch {}
    </script>

    <script>
      let allOrders = [];
      let currentFilter = 'all';

      function statusBadge(status) {
        const map = {
          draft: ['amber','草稿'],
          confirmed: ['leaf','已確認'],
          invoiced: ['sea','已開單'],
          cancelled: ['slate','已取消'],
        };
        const [tone, label] = map[status] || ['amber','草稿'];
        return `<span class="badge ${tone}"><span class="dot"></span>${label}</span>`;
      }

      function renderOrders() {
        const list = document.getElementById('orders-list');
        const filtered = currentFilter === 'all'
          ? allOrders
          : allOrders.filter(o => o.status === currentFilter);

        // Update counts
        document.getElementById('ct-all').textContent = allOrders.length;
        ['draft','confirmed','invoiced','cancelled'].forEach(s => {
          const el = document.getElementById('ct-' + s);
          if (el) el.textContent = allOrders.filter(o => o.status === s).length;
        });
        document.getElementById('orders-eyebrow').textContent = `最近 100 張 · ${filtered.length} 顯示中`;

        if (filtered.length === 0) {
          list.innerHTML = '<div style="padding:40px;text-align:center;color:var(--mute);font-size:13px">沒有訂單記錄</div>';
          return;
        }

        const micSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>`;
        const bagSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"/></svg>`;

        list.innerHTML = filtered.map((o, i) => {
          const isMic = o.source === 'voice';
          const amt = Number(o.total_amount || 0).toLocaleString('en-US',{maximumFractionDigits:0});
          const preview = o.raw_text ? o.raw_text.slice(0,60) : (o.preview || '');
          const items = o.items || [];
          return `
            <div class="card" id="oc-${i}" style="padding:0">
              <button style="all:unset;box-sizing:border-box;cursor:pointer;text-align:left;display:block;width:100%" onclick="toggleOrder(${i})">
                <div style="padding:14px 16px 10px;display:flex;align-items:center;gap:10px">
                  <div style="width:30px;height:30px;border-radius:8px;background:${isMic ? 'var(--coral-soft)' : 'var(--mist)'};color:${isMic ? 'var(--coral-deep)' : 'var(--ink-2)'};display:grid;place-items:center;flex-shrink:0">
                    ${isMic ? micSvg : bagSvg}
                  </div>
                  <div style="flex:1;min-width:0">
                    <div style="font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:.02em">${o.order_no}</div>
                    <div style="font-size:11.5px;color:var(--mute);margin-top:2px">${o.customer_name || o.customer_code || ''} · ${o.order_date || ''}</div>
                  </div>
                  ${statusBadge(o.status)}
                  <svg class="order-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;color:var(--mute)"><path d="m9 6 6 6-6 6"/></svg>
                </div>
                <div style="padding:0 16px 14px;display:flex;justify-content:space-between;align-items:flex-end;gap:12px">
                  <div style="font-size:12px;color:var(--ink-2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1">
                    ${preview}
                  </div>
                  <div style="font-family:var(--mono);font-weight:700;font-size:14px;white-space:nowrap">MOP ${amt}</div>
                </div>
              </button>
              <div class="order-body">
                ${items.length ? items.map(item => `
                  <div class="item-row">
                    <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.product_name || '—'}</span>
                    <span style="flex-shrink:0;color:var(--mute)">${item.qty ?? '?'} ${item.unit || ''}</span>
                    <span style="flex-shrink:0;font-family:var(--mono);font-weight:600">${item.unit_price ? 'MOP ' + Number(item.unit_price * item.qty).toLocaleString() : '—'}</span>
                  </div>`).join('') : '<div style="padding:12px 0;font-size:12px;color:var(--mute)">冇明細記錄</div>'}
                ${o.notes ? `<div style="margin-top:8px;font-size:11px;color:var(--mute);padding:8px;background:var(--paper-2);border-radius:8px">備注：${o.notes}</div>` : ''}
              </div>
            </div>`;
        }).join('');
      }

      window.toggleOrder = function(i) {
        document.getElementById('oc-' + i)?.classList.toggle('open');
      };

      window.setFilter = function(f, btn) {
        currentFilter = f;
        document.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderOrders();
      };

      async function loadOrders() {
        try {
          const res = await fetch('/api/orders?limit=100');
          const data = await res.json();
          allOrders = data.orders || [];
          renderOrders();
        } catch {
          document.getElementById('orders-list').innerHTML = '<div style="padding:40px;text-align:center;color:var(--mute);font-size:13px">載入失敗，請稍後重試</div>';
        }
      }

      loadOrders();
    </script>
  </body>
</html>
