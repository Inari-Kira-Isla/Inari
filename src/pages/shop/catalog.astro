---
---
<!doctype html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>稻荷商城 — 商品目錄</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:-apple-system,BlinkMacSystemFont,"PingFang TC","Noto Sans TC",sans-serif;background:#f8fafc;min-height:100vh}
    
    /* Header */
    .shop-header{background:#fff;border-bottom:1px solid #e5e7eb;padding:0 20px;height:60px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,.05)}
    .back-btn{font-size:20px;text-decoration:none;color:#374151;flex-shrink:0}
    .header-logo{font-size:16px;font-weight:700;color:#c0392b;flex-shrink:0}
    .header-search{flex:1;max-width:360px;position:relative}
    .header-search input{width:100%;border:1.5px solid #e5e7eb;border-radius:24px;padding:8px 16px 8px 36px;font-size:14px;outline:none;background:#f8fafc;transition:border-color .15s}
    .header-search input:focus{border-color:#c0392b;background:#fff}
    .search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:15px;pointer-events:none}
    .cart-btn{position:relative;background:none;border:none;cursor:pointer;font-size:24px;padding:4px;flex-shrink:0;margin-left:auto}
    .cart-badge{position:absolute;top:-4px;right:-4px;background:#c0392b;color:#fff;border-radius:50%;width:18px;height:18px;font-size:11px;font-weight:700;display:none;align-items:center;justify-content:center;line-height:1}
    
    /* Layout */
    .catalog-layout{display:grid;grid-template-columns:180px 1fr;gap:0;max-width:1280px;margin:0 auto}
    @media(max-width:768px){.catalog-layout{grid-template-columns:1fr}}
    
    /* Category sidebar */
    .category-sidebar{background:#fff;border-right:1px solid #e5e7eb;padding:16px 0;position:sticky;top:60px;height:calc(100vh - 60px);overflow-y:auto}
    @media(max-width:768px){.category-sidebar{position:static;height:auto;display:flex;overflow-x:auto;padding:12px 16px;gap:8px;border-right:none;border-bottom:1px solid #e5e7eb;scrollbar-width:none}}
    @media(max-width:768px){.category-sidebar::-webkit-scrollbar{display:none}}
    .cat-btn{display:block;width:100%;text-align:left;padding:11px 20px;border:none;background:none;cursor:pointer;font-size:14px;color:#374151;transition:background .15s;border-left:3px solid transparent}
    @media(max-width:768px){.cat-btn{flex-shrink:0;border-radius:20px;border:1.5px solid #e5e7eb;padding:7px 14px;white-space:nowrap;border-left:1.5px solid #e5e7eb}}
    .cat-btn:hover{background:#fef2f2;color:#c0392b}
    .cat-btn.active{background:#fef2f2;color:#c0392b;font-weight:600;border-left-color:#c0392b}
    @media(max-width:768px){.cat-btn.active{background:#c0392b;color:#fff;border-color:#c0392b}}
    
    /* Product area */
    .product-area{padding:20px 24px}
    @media(max-width:768px){.product-area{padding:16px}}
    .result-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
    .result-info{font-size:13px;color:#6b7280}
    
    /* Product grid */
    .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(188px,1fr));gap:16px}
    @media(max-width:640px){.product-grid{grid-template-columns:repeat(2,1fr);gap:12px}}
    
    /* Product card */
    .product-card{background:#fff;border-radius:14px;border:1px solid #e5e7eb;overflow:hidden;transition:box-shadow .2s,transform .2s;display:flex;flex-direction:column}
    .product-card:hover{box-shadow:0 6px 20px rgba(0,0,0,.1);transform:translateY(-2px)}
    .product-img{aspect-ratio:1;overflow:hidden;background:#f8fafc;position:relative}
    .product-img img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
    .product-card:hover .product-img img{transform:scale(1.05)}
    .badge-air{position:absolute;top:8px;left:8px;background:#3b82f6;color:#fff;font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px}
    .badge-frozen{position:absolute;top:8px;left:8px;background:#06b6d4;color:#fff;font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px}
    .product-info{padding:10px 12px;flex:1}
    .product-sku{font-size:10px;color:#9ca3af;letter-spacing:.5px;text-transform:uppercase}
    .product-name{font-size:13px;font-weight:600;color:#1f2937;margin:3px 0 6px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .product-price{font-size:17px;font-weight:700;color:#c0392b}
    .product-unit{font-size:11px;color:#9ca3af;font-weight:400}
    .product-actions{padding:10px 12px;border-top:1px solid #f3f4f6}
    .qty-row{display:flex;align-items:center;gap:6px;margin-bottom:8px}
    .qty-btn{width:30px;height:30px;border:1.5px solid #e5e7eb;border-radius:8px;background:#fff;cursor:pointer;font-size:16px;color:#374151;display:flex;align-items:center;justify-content:center;transition:border-color .15s}
    .qty-btn:hover{border-color:#c0392b;color:#c0392b}
    .qty-input{flex:1;border:1.5px solid #e5e7eb;border-radius:8px;padding:5px;text-align:center;font-size:14px;font-weight:600;outline:none;min-width:0}
    .qty-input:focus{border-color:#c0392b}
    .add-btn{width:100%;background:#c0392b;color:#fff;border:none;border-radius:10px;padding:9px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s;display:flex;align-items:center;justify-content:center;gap:6px}
    .add-btn:hover{background:#a93226}
    .add-btn.added{background:#27ae60}
    
    /* Load more */
    .load-more-wrap{text-align:center;padding:32px 0}
    .load-more-btn{background:#fff;border:2px solid #c0392b;color:#c0392b;padding:12px 32px;border-radius:24px;font-size:14px;font-weight:600;cursor:pointer;transition:all .15s}
    .load-more-btn:hover{background:#c0392b;color:#fff}
    
    /* Skeleton */
    .skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
    @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
    
    /* Empty state */
    .empty-state{text-align:center;padding:60px 20px;color:#9ca3af}
    .empty-icon{font-size:48px;margin-bottom:12px}
  </style>
</head>
<body>
  <header class="shop-header">
    <a href="/shop" class="back-btn">←</a>
    <span class="header-logo">稻荷商城</span>
    <div class="header-search">
      <span class="search-icon">🔍</span>
      <input type="text" id="header-search" placeholder="搜尋商品名稱或SKU..." autocomplete="off" oninput="debounceSearch(this.value)">
    </div>
    <button class="cart-btn" onclick="openCartPanel()" aria-label="購物車">
      🛒
      <span class="cart-badge" id="cart-badge-header"></span>
    </button>
  </header>

  <div class="catalog-layout">
    <aside class="category-sidebar" id="category-sidebar">
      <button class="cat-btn active" data-cat="" onclick="selectCategory('', this)">全部商品</button>
      <!-- categories injected by JS -->
    </aside>

    <main class="product-area">
      <div class="result-bar">
        <span class="result-info">共 <strong id="result-count">—</strong> 件商品</span>
      </div>
      <div id="product-grid" class="product-grid">
        <!-- skeleton placeholders -->
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
        <div class="product-card"><div class="product-img skeleton"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>
      </div>
      <div class="load-more-wrap">
        <button id="load-more-btn" class="load-more-btn" onclick="loadMore()" style="display:none">載入更多商品</button>
      </div>
    </main>
  </div>

  <script type="module">
    import { initCart, addToCart, openCartPanel } from '/js/cart.js';
    initCart();
    window.openCartPanel = openCartPanel;

    let currentPage = 1;
    let currentCategory = '';
    let currentSearch = '';
    let searchTimer = null;
    let isLoading = false;

    async function loadProducts(reset = false) {
      if (isLoading) return;
      isLoading = true;
      if (reset) {
        currentPage = 1;
        document.getElementById('product-grid').innerHTML = Array(6).fill('<div class="product-card"><div class="product-img skeleton" style="aspect-ratio:1"></div><div class="product-info"><div class="skeleton" style="height:10px;width:40%;border-radius:4px;margin-bottom:6px"></div><div class="skeleton" style="height:14px;width:80%;border-radius:4px;margin-bottom:4px"></div><div class="skeleton" style="height:17px;width:50%;border-radius:4px"></div></div></div>').join('');
      }

      const params = new URLSearchParams({ page: currentPage, limit: 24 });
      if (currentCategory) params.set('category', currentCategory);
      if (currentSearch) params.set('q', currentSearch);

      try {
        const res = await fetch('/api/products/catalog?' + params);
        const data = await res.json();

        if (reset) {
          document.getElementById('product-grid').innerHTML = '';
        }

        if (!data.items || !data.items.length && reset) {
          document.getElementById('product-grid').innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">🐟</div><p>沒有符合條件的商品</p></div>';
        } else {
          renderProducts(data.items);
        }

        document.getElementById('result-count').textContent = data.total || 0;
        document.getElementById('load-more-btn').style.display = data.has_more ? 'block' : 'none';

        // Populate categories (only on first load)
        if (reset && data.categories && data.categories.length) {
          populateCategories(data.categories);
        }
      } catch (err) {
        console.error(err);
        document.getElementById('product-grid').innerHTML = '<div class="empty-state" style="grid-column:1/-1"><p style="color:#ef4444">載入失敗，請重試</p></div>';
      } finally {
        isLoading = false;
      }
    }

    function populateCategories(cats) {
      const sidebar = document.getElementById('category-sidebar');
      // Keep "全部商品" button, add categories
      const existing = sidebar.querySelector('[data-cat=""]');
      sidebar.innerHTML = '';
      sidebar.appendChild(existing);
      cats.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'cat-btn';
        btn.dataset.cat = cat;
        btn.textContent = cat;
        btn.onclick = () => selectCategory(cat, btn);
        sidebar.appendChild(btn);
      });
    }

    window.selectCategory = function(cat, btn) {
      currentCategory = cat;
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadProducts(true);
    };

    window.debounceSearch = function(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => { currentSearch = val; loadProducts(true); }, 350);
    };

    window.loadMore = function() { currentPage++; loadProducts(false); };

    function renderProducts(items) {
      const grid = document.getElementById('product-grid');
      items.forEach(item => {
        const card = document.createElement('div');
        card.className = 'product-card';
        const badgeHtml = item.is_air_freight
          ? '<span class="badge-air">✈️ 空運</span>'
          : (item.storage_type === '冷凍' ? '<span class="badge-frozen">❄️ 冷凍</span>' : '');
        const imgSrc = `/image-db/images/${item.sku}.jpg`;
        card.innerHTML = `
          <div class="product-img">
            <img src="${imgSrc}" alt="${item.name}" loading="lazy" onerror="this.src='/images/food-placeholder.svg'">
            ${badgeHtml}
          </div>
          <div class="product-info">
            <div class="product-sku">${item.sku}</div>
            <div class="product-name">${item.name}</div>
            <div class="product-price">${item.sales_price ? 'MOP ' + item.sales_price : '—'} <span class="product-unit">/ ${item.unit || '件'}</span></div>
          </div>
          <div class="product-actions">
            <div class="qty-row">
              <button class="qty-btn" onclick="decreaseQty('${item.sku}')">−</button>
              <input class="qty-input" type="number" id="qty-${item.sku}" value="1" min="1" max="9999">
              <button class="qty-btn" onclick="increaseQty('${item.sku}')">+</button>
            </div>
            <button class="add-btn" id="add-${item.sku}" 
              onclick="handleAddToCart('${item.sku}','${item.name.replace(/'/g,"\\'")}',${item.sales_price||0},'${item.unit||'件'}','${item.id}')">
              🛒 加入購物車
            </button>
          </div>
        `;
        grid.appendChild(card);
      });
    }

    window.decreaseQty = function(sku) {
      const input = document.getElementById('qty-' + sku);
      if (input) input.value = Math.max(1, parseInt(input.value || 1) - 1);
    };
    window.increaseQty = function(sku) {
      const input = document.getElementById('qty-' + sku);
      if (input) input.value = parseInt(input.value || 1) + 1;
    };

    window.handleAddToCart = function(sku, name, price, unit, productId) {
      const qty = parseFloat(document.getElementById('qty-' + sku)?.value) || 1;
      addToCart({ sku, product_id: productId, product_name: name, qty, unit, unit_price: price, line_total: qty * price });
      const btn = document.getElementById('add-' + sku);
      if (btn) {
        btn.textContent = '✓ 已加入';
        btn.classList.add('added');
        setTimeout(() => { btn.innerHTML = '🛒 加入購物車'; btn.classList.remove('added'); }, 1500);
      }
      openCartPanel();
    };

    // Init
    loadProducts(true);
  </script>
</body>
</html>
