---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="對話記錄" active="conversations" pageTitle="對話記錄">
  <div class="d-flex align-items-center gap-2 mb-3 text-muted">
    <i class="ti ti-messages"></i>
    <span>總對話數：</span>
    <span class="badge bg-blue-lt text-blue" id="total-sessions">—</span>
  </div>

  <div class="row g-3 conversation-layout">
    <div class="col-12 col-lg-4">
      <div class="card h-100">
        <div class="card-header">
          <h3 class="card-title">Sessions</h3>
        </div>
        <div class="list-group list-group-flush session-list" id="conv-sidebar">
          <div class="text-center text-muted py-4">
            <span class="spinner-border spinner-border-sm me-2"></span>載入中…
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-8">
      <div class="card h-100 conversation-card" id="conv-main">
        <div class="card-body d-flex align-items-center justify-content-center text-center text-muted">
          請選擇左側的對話 session 來查看內容
        </div>
      </div>
    </div>
  </div>

  <style>
    .conversation-layout { min-height: 32rem; }
    .session-list { max-height: 42rem; overflow-y: auto; }
    .session-item { cursor: pointer; text-align: left; }
    .session-item.active { border-left: 3px solid var(--tblr-primary); }
    .session-preview {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .conversation-card { max-height: 42rem; overflow: hidden; }
    .conversation-messages {
      display: flex;
      flex: 1;
      flex-direction: column;
      gap: 1rem;
      overflow-y: auto;
    }
    .message { max-width: 85%; }
    .message.user { align-self: flex-end; text-align: right; }
    .message-bubble {
      border-radius: var(--tblr-border-radius-lg);
      padding: .75rem 1rem;
      text-align: left;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .message.user .message-bubble { background: var(--tblr-primary); color: #fff; }
    .message.assistant .message-bubble { background: var(--tblr-bg-surface-secondary); }
    @media (max-width: 991.98px) {
      .conversation-layout { min-height: 0; }
      .session-list { max-height: 18rem; }
      .conversation-card { min-height: 28rem; }
    }
  </style>

  <script>
    let allSessions = [];
    let activeSessionId = null;

    const convSidebar = document.getElementById('conv-sidebar');
    const convMain = document.getElementById('conv-main');
    const totalSessionsEl = document.getElementById('total-sessions');

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function formatTime(timestamp) {
      if (!timestamp) return '';
      try {
        const value = timestamp.includes('T') ? timestamp : timestamp.replace(' ', 'T') + 'Z';
        return new Date(value).toLocaleString('zh-TW', {
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        });
      } catch {
        return timestamp;
      }
    }

    function renderSessions() {
      if (!allSessions.length) {
        convSidebar.innerHTML = '<div class="text-center text-muted py-4">尚無對話記錄</div>';
        return;
      }

      convSidebar.innerHTML = allSessions.map((session) => `
        <button
          type="button"
          class="list-group-item list-group-item-action session-item ${activeSessionId === session.session_id ? 'active' : ''}"
          data-session-id="${escapeHtml(session.session_id)}"
        >
          <div class="session-preview fw-medium">${escapeHtml(session.preview || '（無訊息）')}</div>
          <div class="d-flex justify-content-between mt-1 text-muted small">
            <span>${formatTime(session.last_message_at)}</span>
            <span class="badge bg-secondary-lt text-secondary">${Number(session.message_count) || 0} 則</span>
          </div>
        </button>
      `).join('');

      convSidebar.querySelectorAll('[data-session-id]').forEach((item) => {
        item.addEventListener('click', () => selectSession(item.dataset.sessionId));
      });
    }

    async function loadSessions() {
      convSidebar.innerHTML = `
        <div class="text-center text-muted py-4">
          <span class="spinner-border spinner-border-sm me-2"></span>載入中…
        </div>`;

      try {
        const response = await fetch('/api/conversations');
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json();
        allSessions = data.sessions || [];
        totalSessionsEl.textContent = String(data.total ?? allSessions.length);
        renderSessions();
      } catch {
        convSidebar.innerHTML = '<div class="text-center text-danger py-4">載入失敗</div>';
        totalSessionsEl.textContent = '—';
      }
    }

    async function selectSession(sessionId) {
      if (!sessionId) return;
      activeSessionId = sessionId;
      renderSessions();
      convMain.innerHTML = `
        <div class="card-body d-flex align-items-center justify-content-center text-muted">
          <span class="spinner-border spinner-border-sm me-2"></span>載入中…
        </div>`;

      try {
        const response = await fetch(`/api/conversations?session_id=${encodeURIComponent(sessionId)}`);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json();
        renderConversation(sessionId, data.messages || []);
      } catch {
        convMain.innerHTML = '<div class="card-body text-center text-danger py-5">載入失敗</div>';
      }
    }

    function renderConversation(sessionId, messages) {
      const shortId = sessionId.length > 20 ? sessionId.slice(0, 20) + '…' : sessionId;
      convMain.innerHTML = `
        <div class="card-header d-flex align-items-center justify-content-between">
          <div class="text-muted small text-break">Session: ${escapeHtml(shortId)}</div>
          <button type="button" class="btn btn-danger btn-sm" id="delete-session">
            <i class="ti ti-trash me-1"></i>刪除對話
          </button>
        </div>
        <div class="card-body conversation-messages">
          ${messages.length
            ? messages.map((message) => {
                const isUser = message.role === 'user';
                return `
                  <div class="message ${isUser ? 'user' : 'assistant'}">
                    <div class="small fw-semibold mb-1">${isUser ? '用戶' : 'AI 助手'}</div>
                    <div class="message-bubble">${escapeHtml(message.message)}</div>
                    <div class="text-muted small mt-1">${formatTime(message.created_at)}</div>
                  </div>`;
              }).join('')
            : '<div class="m-auto text-muted">此對話沒有記錄</div>'}
        </div>`;

      document.getElementById('delete-session')?.addEventListener('click', () => deleteSession(sessionId));
    }

    async function deleteSession(sessionId) {
      if (!window.confirm('確定要刪除這個對話 session？此操作無法復原。')) return;

      const deleteButton = document.getElementById('delete-session');
      if (deleteButton) {
        deleteButton.disabled = true;
        deleteButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>刪除中…';
      }

      try {
        const response = await fetch(
          `/api/conversations?session_id=${encodeURIComponent(sessionId)}`,
          { method: 'DELETE' },
        );
        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        activeSessionId = null;
        convMain.innerHTML = `
          <div class="card-body d-flex align-items-center justify-content-center text-center text-muted">
            請選擇左側的對話 session 來查看內容
          </div>`;
        await loadSessions();
      } catch {
        window.alert('刪除失敗，請稍後再試。');
        if (deleteButton) {
          deleteButton.disabled = false;
          deleteButton.innerHTML = '<i class="ti ti-trash me-1"></i>刪除對話';
        }
      }
    }

    loadSessions();
  </script>
</AdminLayout>
