---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="商品目錄" active="products" pageTitle="商品目錄">

  <div class="row g-3 mb-3">
    <div class="col">
      <div class="input-group">
        <span class="input-group-text"><i class="ti ti-search"></i></span>
        <input type="text" class="form-control" id="search-input"
          placeholder="搜尋 SKU 或商品名稱…" oninput="debounceSearch(this.value)" />
      </div>
    </div>
    <div class="col-auto">
      <select class="form-select" id="cat-filter" onchange="applyFilter()">
        <option value="">全部類別</option>
      </select>
    </div>
    <div class="col-auto">
      <!-- 3-way status selector -->
      <div class="btn-group" id="status-tabs" role="group">
        <input type="radio" class="btn-check" name="status" id="s-active" value="active" checked autocomplete="off" onchange="loadProducts(true)" />
        <label class="btn btn-outline-secondary" for="s-active">上架中</label>
        <input type="radio" class="btn-check" name="status" id="s-inactive" value="inactive" autocomplete="off" onchange="loadProducts(true)" />
        <label class="btn btn-outline-secondary" for="s-inactive">未上架</label>
        <input type="radio" class="btn-check" name="status" id="s-all" value="all" autocomplete="off" onchange="loadProducts(true)" />
        <label class="btn btn-outline-secondary" for="s-all">全部</label>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
      <span id="count-label" class="text-muted small">—</span>
      <button class="btn btn-sm btn-outline-secondary" onclick="loadProducts(true)">
        <i class="ti ti-refresh me-1"></i>重新整理
      </button>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>SKU</th>
            <th>商品名稱</th>
            <th>類別</th>
            <th class="text-end">單價</th>
            <th class="d-none d-md-table-cell">單位</th>
            <th class="d-none d-md-table-cell">產地</th>
            <th class="d-none d-lg-table-cell">類型</th>
            <th id="status-th" style="display:none">狀態</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="products-tbody">
          <tr><td colspan="9" class="text-center py-5 text-muted">載入中…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer d-flex align-items-center justify-content-between">
      <span id="page-label" class="text-muted small">—</span>
      <button id="load-more-btn" class="btn btn-sm btn-outline-secondary" style="display:none" onclick="loadMore()">載入更多</button>
    </div>
  </div>

  <script>
    let allProducts = [], filtered = [], currentSearch = '', currentCat = '', page = 1;
    const PAGE_SIZE = 50;
    let searchTimer = null;

    function getStatus() {
      return document.querySelector('input[name="status"]:checked')?.value || 'active';
    }

    async function loadProducts(reset = false) {
      if (reset) {
        page = 1;
        allProducts = [];
        const catSel = document.getElementById('cat-filter');
        while (catSel.options.length > 1) catSel.remove(1);
        document.getElementById('products-tbody').innerHTML =
          '<tr><td colspan="9" class="text-center py-5 text-muted">載入中…</td></tr>';
      }

      const status = getStatus();
      const resp = await fetch(`/api/admin/products?status=${status}`);
      if (!resp.ok) {
        document.getElementById('products-tbody').innerHTML =
          '<tr><td colspan="9" class="text-center py-5 text-danger">載入失敗</td></tr>';
        return;
      }
      const data = await resp.json();
      allProducts = data.products || [];

      document.getElementById('status-th').style.display = status !== 'active' ? '' : 'none';

      const cats = [...new Set(allProducts.map(p => p.category).filter(Boolean))].sort();
      const catSel = document.getElementById('cat-filter');
      cats.forEach(c => {
        if (!catSel.querySelector(`option[value="${c}"]`)) {
          const opt = document.createElement('option'); opt.value = c; opt.textContent = c;
          catSel.appendChild(opt);
        }
      });

      applyFilter();
    }

    function applyFilter() {
      currentCat = document.getElementById('cat-filter').value;
      filtered = allProducts.filter(p => {
        const q = currentSearch.toLowerCase();
        return (!currentCat || p.category === currentCat) &&
          (!q || (p.sku || '').toLowerCase().includes(q) ||
                 (p.name || '').toLowerCase().includes(q));
      });
      page = 1;
      render();
    }

    function render() {
      const status = getStatus();
      const showStatusCol = status !== 'active';
      const slice = filtered.slice(0, page * PAGE_SIZE);

      if (status === 'all') {
        const aC = filtered.filter(p => p.is_active !== false).length;
        const iC = filtered.length - aC;
        document.getElementById('count-label').innerHTML =
          `共 ${filtered.length} 件 &nbsp;` +
          `<span class="badge bg-success-lt text-success">上架 ${aC}</span> ` +
          `<span class="badge bg-secondary-lt text-muted">未上架 ${iC}</span>`;
      } else {
        document.getElementById('count-label').textContent = `共 ${filtered.length} 件商品`;
      }

      document.getElementById('page-label').textContent = `顯示 ${slice.length} / ${filtered.length}`;
      document.getElementById('load-more-btn').style.display = filtered.length > slice.length ? '' : 'none';

      const tbody = document.getElementById('products-tbody');
      if (!slice.length) {
        const msg = status === 'inactive' ? '目前沒有未上架商品' : '無符合商品';
        tbody.innerHTML = `<tr><td colspan="9" class="text-center py-5 text-muted">${msg}</td></tr>`;
        return;
      }

      tbody.innerHTML = slice.map(p => {
        const name = p.name || '—';
        const price = p.sales_price ?? p.price;
        const priceFmt = price != null ? `MOP ${Number(price).toLocaleString()}` : '—';
        const storeBadge = p.is_air_freight
          ? `<span class="badge bg-yellow-lt text-yellow">空運</span>`
          : p.storage_type === '冷凍'
            ? `<span class="badge bg-blue-lt text-blue">冷凍</span>`
            : p.storage_type
              ? `<span class="badge bg-green-lt text-green">${p.storage_type}</span>`
              : `<span class="text-muted">—</span>`;

        const isActive = p.is_active !== false;
        const statusCell = showStatusCol
          ? `<td>${isActive
              ? '<span class="badge bg-success-lt text-success">上架</span>'
              : '<span class="badge bg-secondary-lt text-muted">未上架</span>'
            }</td>`
          : '';

        const toggleBtn = isActive
          ? `<button class="btn btn-sm btn-ghost-danger" title="下架" onclick="toggleActive(${p.id}, false, this)">
               <i class="ti ti-eye-off"></i>
             </button>`
          : `<button class="btn btn-sm btn-ghost-success" title="上架" onclick="toggleActive(${p.id}, true, this)">
               <i class="ti ti-eye"></i>
             </button>`;

        const rowClass = !isActive ? 'opacity-50' : '';
        return `<tr class="${rowClass}" id="row-${p.id}">
          <td class="font-mono text-muted small">${p.sku || '—'}</td>
          <td class="fw-medium">${name}</td>
          <td class="text-muted small">${p.category || '—'}</td>
          <td class="text-end font-mono small fw-semibold">${priceFmt}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.unit || '—'}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.origin || '—'}</td>
          <td class="d-none d-lg-table-cell">${storeBadge}</td>
          ${statusCell}
          <td class="text-end">${toggleBtn}</td>
        </tr>`;
      }).join('');
    }

    window.toggleActive = async function(id, newActive, btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

      const resp = await fetch('/api/admin/products', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: newActive }),
      });

      if (!resp.ok) {
        btn.disabled = false;
        btn.innerHTML = newActive ? '<i class="ti ti-eye"></i>' : '<i class="ti ti-eye-off"></i>';
        alert('操作失敗');
        return;
      }

      // Update local data and re-render
      const p = allProducts.find(x => x.id === id);
      if (p) p.is_active = newActive;
      applyFilter();
    };

    window.debounceSearch = function(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => { currentSearch = val; applyFilter(); }, 300);
    };
    window.loadMore = function() { page++; render(); };

    loadProducts(true);
  </script>
</AdminLayout>
