---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="商品目錄" active="products" pageTitle="商品目錄">

  <div class="row g-3 mb-3">
    <div class="col">
      <div class="input-group">
        <span class="input-group-text"><i class="ti ti-search"></i></span>
        <input type="text" class="form-control" id="search-input" placeholder="搜尋 SKU 或商品名稱…" />
      </div>
    </div>
    <div class="col-auto">
      <select class="form-select" id="cat-filter">
        <option value="">全部類別</option>
      </select>
    </div>
    <div class="col-auto">
      <div class="btn-group" role="group">
        <input type="radio" class="btn-check" name="status" id="s-active" value="active" checked autocomplete="off" />
        <label class="btn btn-outline-secondary" for="s-active">上架中</label>
        <input type="radio" class="btn-check" name="status" id="s-inactive" value="inactive" autocomplete="off" />
        <label class="btn btn-outline-secondary" for="s-inactive">未上架</label>
        <input type="radio" class="btn-check" name="status" id="s-all" value="all" autocomplete="off" />
        <label class="btn btn-outline-secondary" for="s-all">全部</label>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
      <span id="count-label" class="text-muted small">—</span>
      <button class="btn btn-sm btn-outline-secondary" id="refresh-btn">
        <i class="ti ti-refresh me-1"></i>重新整理
      </button>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>SKU</th>
            <th>商品名稱</th>
            <th>類別</th>
            <th class="text-end">單價</th>
            <th class="d-none d-md-table-cell">單位</th>
            <th class="d-none d-md-table-cell">產地</th>
            <th class="d-none d-lg-table-cell">類型</th>
            <th id="status-th" style="display:none">狀態</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="products-tbody">
          <tr><td colspan="9" class="text-center py-5 text-muted">載入中…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer d-flex align-items-center justify-content-between">
      <span id="page-label" class="text-muted small">—</span>
      <button id="load-more-btn" class="btn btn-sm btn-outline-secondary" style="display:none">載入更多</button>
    </div>
  </div>

  <script>
    let allProducts = [], filtered = [], currentSearch = '', currentCat = '', page = 1;
    const PAGE_SIZE = 50;
    let searchTimer = null;

    // ── helpers ──────────────────────────────────────────────────────────
    function getStatus() {
      return (document.querySelector('input[name="status"]:checked') as HTMLInputElement)?.value || 'active';
    }

    // ── load from API ────────────────────────────────────────────────────
    async function loadProducts(reset = false) {
      if (reset) {
        page = 1;
        allProducts = [];
        const catSel = document.getElementById('cat-filter') as HTMLSelectElement;
        while (catSel.options.length > 1) catSel.remove(1);
        currentCat = '';
        document.getElementById('products-tbody')!.innerHTML =
          '<tr><td colspan="9" class="text-center py-5 text-muted">載入中…</td></tr>';
      }

      const status = getStatus();
      const resp = await fetch(`/api/admin/products?status=${status}`);
      if (!resp.ok) {
        document.getElementById('products-tbody')!.innerHTML =
          '<tr><td colspan="9" class="text-center py-5 text-danger">載入失敗</td></tr>';
        return;
      }
      const data = await resp.json();
      allProducts = data.products || [];

      document.getElementById('status-th')!.style.display = status !== 'active' ? '' : 'none';

      // populate category dropdown
      const cats = [...new Set(allProducts.map((p: any) => p.category).filter(Boolean))].sort();
      const catSel = document.getElementById('cat-filter') as HTMLSelectElement;
      cats.forEach((c: any) => {
        const opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        catSel.appendChild(opt);
      });

      applyFilter();
    }

    // ── filter + render ──────────────────────────────────────────────────
    function applyFilter() {
      currentCat = (document.getElementById('cat-filter') as HTMLSelectElement).value;
      filtered = allProducts.filter((p: any) => {
        const q = currentSearch.toLowerCase();
        return (!currentCat || p.category === currentCat) &&
          (!q || (p.sku || '').toLowerCase().includes(q) ||
                 (p.name || '').toLowerCase().includes(q));
      });
      page = 1;
      render();
    }

    function render() {
      const status = getStatus();
      const showStatusCol = status !== 'active';
      const slice = filtered.slice(0, page * PAGE_SIZE);

      if (status === 'all') {
        const aC = filtered.filter((p: any) => p.is_active !== false).length;
        const iC = filtered.length - aC;
        document.getElementById('count-label')!.innerHTML =
          `共 ${filtered.length} 件 &nbsp;` +
          `<span class="badge bg-success-lt text-success">上架 ${aC}</span> ` +
          `<span class="badge bg-secondary-lt text-muted">未上架 ${iC}</span>`;
      } else {
        document.getElementById('count-label')!.textContent = `共 ${filtered.length} 件商品`;
      }

      document.getElementById('page-label')!.textContent = `顯示 ${slice.length} / ${filtered.length}`;
      const loadMoreBtn = document.getElementById('load-more-btn')!;
      loadMoreBtn.style.display = filtered.length > slice.length ? '' : 'none';

      const tbody = document.getElementById('products-tbody')!;
      if (!slice.length) {
        const msg = status === 'inactive' ? '目前沒有未上架商品' : '無符合商品';
        tbody.innerHTML = `<tr><td colspan="9" class="text-center py-5 text-muted">${msg}</td></tr>`;
        return;
      }

      tbody.innerHTML = (slice as any[]).map(p => {
        const price = p.sales_price ?? p.price;
        const priceFmt = price != null ? `MOP ${Number(price).toLocaleString()}` : '—';
        const storeBadge = p.is_air_freight
          ? `<span class="badge bg-yellow-lt text-yellow">空運</span>`
          : p.storage_type === '冷凍'
            ? `<span class="badge bg-blue-lt text-blue">冷凍</span>`
            : p.storage_type
              ? `<span class="badge bg-green-lt text-green">${p.storage_type}</span>`
              : `<span class="text-muted">—</span>`;

        const isActive = p.is_active !== false;
        const statusCell = showStatusCol
          ? `<td>${isActive
              ? '<span class="badge bg-success-lt text-success">上架</span>'
              : '<span class="badge bg-secondary-lt text-muted">未上架</span>'
            }</td>`
          : '';

        const toggleBtn = isActive
          ? `<button class="btn btn-sm btn-ghost-danger" data-id="${p.id}" data-active="false" title="下架">
               <i class="ti ti-eye-off"></i>
             </button>`
          : `<button class="btn btn-sm btn-ghost-success" data-id="${p.id}" data-active="true" title="上架">
               <i class="ti ti-eye"></i>
             </button>`;

        return `<tr class="${!isActive ? 'opacity-50' : ''}" id="row-${p.id}">
          <td class="font-mono text-muted small">${p.sku || '—'}</td>
          <td class="fw-medium">${p.name || '—'}</td>
          <td class="text-muted small">${p.category || '—'}</td>
          <td class="text-end font-mono small fw-semibold">${priceFmt}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.unit || '—'}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.origin || '—'}</td>
          <td class="d-none d-lg-table-cell">${storeBadge}</td>
          ${statusCell}
          <td class="text-end">${toggleBtn}</td>
        </tr>`;
      }).join('');
    }

    // ── toggle active via event delegation ───────────────────────────────
    async function handleToggle(id: number, newActive: boolean, btn: HTMLButtonElement) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

      const resp = await fetch('/api/admin/products', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: newActive }),
      });

      if (!resp.ok) {
        btn.disabled = false;
        btn.innerHTML = newActive ? '<i class="ti ti-eye"></i>' : '<i class="ti ti-eye-off"></i>';
        alert('操作失敗');
        return;
      }

      const p = allProducts.find((x: any) => x.id === id);
      if (p) (p as any).is_active = newActive;
      applyFilter();
    }

    // ── wire up all event listeners ──────────────────────────────────────
    document.getElementById('search-input')!.addEventListener('input', (e) => {
      clearTimeout(searchTimer);
      const val = (e.target as HTMLInputElement).value;
      searchTimer = setTimeout(() => { currentSearch = val; applyFilter(); }, 300) as any;
    });

    document.getElementById('cat-filter')!.addEventListener('change', applyFilter);
    document.getElementById('refresh-btn')!.addEventListener('click', () => loadProducts(true));
    document.getElementById('load-more-btn')!.addEventListener('click', () => { page++; render(); });

    document.querySelectorAll('input[name="status"]').forEach(radio => {
      radio.addEventListener('change', () => loadProducts(true));
    });

    // event delegation for toggle buttons (rendered dynamically)
    document.getElementById('products-tbody')!.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-id]') as HTMLButtonElement | null;
      if (!btn) return;
      const id = parseInt(btn.dataset.id!);
      const newActive = btn.dataset.active === 'true';
      handleToggle(id, newActive, btn);
    });

    loadProducts(true);
  </script>
</AdminLayout>
