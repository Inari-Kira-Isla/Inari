---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="商品目錄" active="products" pageTitle="商品目錄">

  <div class="row g-3 mb-3">
    <div class="col">
      <div class="input-group">
        <span class="input-group-text"><i class="ti ti-search"></i></span>
        <input type="text" class="form-control" id="search-input" placeholder="搜尋 SKU 或商品名稱…" oninput="debounceSearch(this.value)" />
      </div>
    </div>
    <div class="col-auto">
      <select class="form-select" id="cat-filter" onchange="applyFilter()">
        <option value="">全部類別</option>
      </select>
    </div>
    <div class="col-auto d-flex align-items-center">
      <label class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="show-inactive" onchange="loadProducts(true)" />
        <span class="form-check-label text-muted">顯示停用商品</span>
      </label>
    </div>
  </div>

  <div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
      <span id="count-label" class="text-muted small">—</span>
      <button class="btn btn-sm btn-outline-secondary" onclick="loadProducts(true)">
        <i class="ti ti-refresh me-1"></i>重新整理
      </button>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>SKU</th>
            <th>商品名稱</th>
            <th>類別</th>
            <th class="text-end">單價</th>
            <th class="d-none d-md-table-cell">單位</th>
            <th class="d-none d-md-table-cell">產地</th>
            <th class="d-none d-lg-table-cell">類型</th>
            <th class="d-none d-lg-table-cell" id="status-col" style="display:none!important">狀態</th>
          </tr>
        </thead>
        <tbody id="products-tbody">
          <tr><td colspan="8" class="text-center py-5 text-muted">載入中…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer d-flex align-items-center justify-content-between">
      <span id="page-label" class="text-muted small">—</span>
      <button id="load-more-btn" class="btn btn-sm btn-outline-secondary" style="display:none" onclick="loadMore()">載入更多</button>
    </div>
  </div>

  <script>
    let allProducts = [], filtered = [], currentSearch = '', currentCat = '', page = 1;
    const PAGE_SIZE = 50;
    let searchTimer = null;

    async function loadProducts(reset = false) {
      if (reset) {
        page = 1;
        allProducts = [];
        document.getElementById('products-tbody').innerHTML =
          '<tr><td colspan="8" class="text-center py-5 text-muted">載入中…</td></tr>';
        // Reset category filter
        const catSel = document.getElementById('cat-filter');
        while (catSel.options.length > 1) catSel.remove(1);
      }

      const showInactive = document.getElementById('show-inactive').checked;
      const url = '/api/admin/products' + (showInactive ? '?inactive=1' : '');

      const resp = await fetch(url);
      if (!resp.ok) {
        document.getElementById('products-tbody').innerHTML =
          '<tr><td colspan="8" class="text-center py-5 text-danger">載入失敗</td></tr>';
        return;
      }
      const data = await resp.json();
      allProducts = data.products || data.items || [];

      // Populate category filter
      const cats = [...new Set(allProducts.map(p => p.category).filter(Boolean))].sort();
      const catSel = document.getElementById('cat-filter');
      cats.forEach(c => {
        if (!catSel.querySelector(`option[value="${c}"]`)) {
          const opt = document.createElement('option'); opt.value = c; opt.textContent = c; catSel.appendChild(opt);
        }
      });

      // Show/hide status column
      const statusCol = document.getElementById('status-col');
      if (showInactive) {
        statusCol.style.removeProperty('display');
      } else {
        statusCol.style.setProperty('display', 'none', 'important');
      }

      applyFilter();
    }

    function applyFilter() {
      currentCat = document.getElementById('cat-filter').value;
      const showInactive = document.getElementById('show-inactive').checked;
      filtered = allProducts.filter(p => {
        const q = currentSearch.toLowerCase();
        return (!currentCat || p.category === currentCat) &&
          (!q || (p.sku||'').toLowerCase().includes(q) ||
                 (p.name||p.product_name||'').toLowerCase().includes(q));
      });
      page = 1;
      render(showInactive);
    }

    function render(showInactive) {
      const slice = filtered.slice(0, page * PAGE_SIZE);
      document.getElementById('count-label').textContent = `共 ${filtered.length} 件商品`;
      document.getElementById('page-label').textContent = `顯示 ${slice.length} / ${filtered.length}`;
      document.getElementById('load-more-btn').style.display = filtered.length > slice.length ? '' : 'none';

      const tbody = document.getElementById('products-tbody');
      if (!slice.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-5 text-muted">無符合商品</td></tr>';
        return;
      }

      tbody.innerHTML = slice.map(p => {
        const name = p.name || p.product_name || '—';
        const price = p.sales_price ?? p.price;
        const priceFmt = price != null ? `MOP ${Number(price).toLocaleString()}` : '—';
        const storeBadge = p.is_air_freight
          ? `<span class="badge bg-yellow-lt text-yellow">空運</span>`
          : p.storage_type === '冷凍'
            ? `<span class="badge bg-blue-lt text-blue">冷凍</span>`
            : p.storage_type
              ? `<span class="badge bg-green-lt text-green">${p.storage_type}</span>`
              : `<span class="badge bg-secondary-lt text-secondary">—</span>`;
        const statusCell = showInactive
          ? `<td class="d-none d-lg-table-cell">${p.is_active !== false ? '<span class="badge bg-success-lt text-success">上架</span>' : '<span class="badge bg-secondary-lt text-muted">停用</span>'}</td>`
          : '';
        const inactiveClass = p.is_active === false ? 'text-muted opacity-50' : '';
        return `<tr class="${inactiveClass}">
          <td class="font-mono text-muted small">${p.sku || '—'}</td>
          <td class="fw-medium">${name}</td>
          <td class="text-muted small">${p.category || '—'}</td>
          <td class="text-end font-mono small fw-semibold">${priceFmt}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.unit || '—'}</td>
          <td class="text-muted small d-none d-md-table-cell">${p.origin || '—'}</td>
          <td class="d-none d-lg-table-cell">${storeBadge}</td>
          ${statusCell}
        </tr>`;
      }).join('');
    }

    window.debounceSearch = function(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => { currentSearch = val; applyFilter(); }, 300);
    };
    window.loadMore = function() { page++; render(document.getElementById('show-inactive').checked); };
    loadProducts(true);
  </script>
</AdminLayout>
