---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="儀表板" active="dashboard" pageTitle="儀表板" pageSubtitle="稻荷管理後台">

  <div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
      <div class="card card-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-auto"><span class="bg-blue-lt avatar"><i class="ti ti-currency-dollar text-blue"></i></span></div>
            <div class="col">
              <div class="fw-semibold" id="kpi-today-rev">—</div>
              <div class="text-muted small">今日收入</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card card-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-auto"><span class="bg-yellow-lt avatar"><i class="ti ti-clock text-yellow"></i></span></div>
            <div class="col">
              <div class="fw-semibold" id="kpi-drafts">—</div>
              <div class="text-muted small">待確認草稿</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card card-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-auto"><span class="bg-green-lt avatar"><i class="ti ti-clipboard-check text-green"></i></span></div>
            <div class="col">
              <div class="fw-semibold" id="kpi-month-orders">—</div>
              <div class="text-muted small">本月訂單</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card card-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-auto"><span class="bg-cyan-lt avatar"><i class="ti ti-users text-cyan"></i></span></div>
            <div class="col">
              <div class="fw-semibold" id="kpi-month-amt">—</div>
              <div class="text-muted small">本月金額</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h3 class="card-title mb-0">最近訂單</h3>
          <a href="/admin/orders" class="btn btn-sm btn-ghost-primary">查看全部 <i class="ti ti-arrow-right ms-1"></i></a>
        </div>
        <div class="table-responsive">
          <table class="table table-vcenter table-hover card-table">
            <thead>
              <tr>
                <th>狀態</th>
                <th>訂單號</th>
                <th>客戶</th>
                <th class="text-end">金額</th>
                <th class="d-none d-md-table-cell">時間</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="recent-orders">
              <tr><td colspan="6" class="text-center py-4 text-muted">載入中…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-title mb-0">本月旬物 <span id="seasonal-month" class="text-muted small ms-1"></span></h3>
        </div>
        <div class="card-body p-0" id="seasonal-list">
          <div class="text-muted text-center py-3 small">載入中…</div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><h3 class="card-title mb-0">快速操作</h3></div>
        <div class="list-group list-group-flush">
          <a href="/admin/orders" class="list-group-item list-group-item-action"><i class="ti ti-clipboard-list me-2 text-muted"></i>待確認訂單</a>
          <a href="/admin/customers" class="list-group-item list-group-item-action"><i class="ti ti-users me-2 text-muted"></i>客戶管理</a>
          <a href="/admin/analytics" class="list-group-item list-group-item-action"><i class="ti ti-chart-bar me-2 text-muted"></i>報表分析</a>
          <a href="/shop/order/new" class="list-group-item list-group-item-action"><i class="ti ti-microphone me-2 text-muted"></i>語音下單</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const statusMap = { draft:'草稿', confirmed:'已確認', invoiced:'已開單', cancelled:'已取消' };
    const statusColor = { draft:'warning', confirmed:'success', invoiced:'primary', cancelled:'secondary' };
    const today = new Date().toISOString().slice(0, 10);
    const thisMonth = new Date().toISOString().slice(0, 7);

    async function loadOrders() {
      const resp = await fetch('/api/admin/orders?limit=50');
      if (!resp.ok) return;
      const { orders } = await resp.json();
      const todayAmt = orders.filter(o => o.order_date === today && o.status !== 'cancelled').reduce((s, o) => s + (o.total_amount || 0), 0);
      const drafts = orders.filter(o => o.status === 'draft').length;
      const monthOrders = orders.filter(o => o.created_at?.startsWith(thisMonth));
      const monthAmt = monthOrders.reduce((s, o) => s + (o.total_amount || 0), 0);
      document.getElementById('kpi-today-rev').textContent = 'MOP ' + todayAmt.toLocaleString('zh-TW', { maximumFractionDigits: 0 });
      document.getElementById('kpi-drafts').textContent = drafts;
      document.getElementById('kpi-month-orders').textContent = monthOrders.length;
      document.getElementById('kpi-month-amt').textContent = 'MOP ' + monthAmt.toLocaleString('zh-TW', { maximumFractionDigits: 0 });
      const tbody = document.getElementById('recent-orders');
      const recent = orders.slice(0, 8);
      if (!recent.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-muted">無訂單記錄</td></tr>'; return; }
      tbody.innerHTML = recent.map(o => {
        const color = statusColor[o.status] || 'secondary';
        const amt = o.total_amount ? `MOP ${Number(o.total_amount).toLocaleString()}` : '—';
        const dt = new Date(o.created_at).toLocaleString('zh-TW', { month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' });
        return `<tr>
          <td><span class="badge bg-${color}-lt text-${color}">${statusMap[o.status] || o.status}</span></td>
          <td class="font-mono small fw-semibold">${o.order_no || '—'}</td>
          <td class="small">${o.customer_name || o.customer_code || '—'}</td>
          <td class="text-end font-mono small fw-semibold">${amt}</td>
          <td class="text-muted small d-none d-md-table-cell">${dt}</td>
          <td><a href="/admin/orders/${o.id}" class="btn btn-sm btn-ghost-secondary px-1"><i class="ti ti-arrow-right"></i></a></td>
        </tr>`;
      }).join('');
    }

    async function loadSeasonal() {
      const month = new Date().getMonth() + 1;
      document.getElementById('seasonal-month').textContent = `${month}月`;
      const resp = await fetch(`/api/seasonal?month=${month}`);
      if (!resp.ok) return;
      const { items } = await resp.json();
      const el = document.getElementById('seasonal-list');
      if (!items?.length) { el.innerHTML = '<div class="text-muted text-center py-3 small">暫無資料</div>'; return; }
      el.innerHTML = items.slice(0, 4).map(item => `
        <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom">
          <div class="flex-fill"><div class="fw-medium small">${item.item_name_zh || '—'}</div><div class="text-muted" style="font-size:11px">${item.origin || ''}</div></div>
          <span class="badge bg-green-lt text-green">旺季</span>
        </div>`).join('');
    }

    loadOrders();
    loadSeasonal();
  </script>
</AdminLayout>
