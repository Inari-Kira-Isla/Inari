---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="知識庫" active="knowledge" pageTitle="知識庫管理">

  <!-- Tab nav -->
  <ul class="nav nav-tabs mb-3" id="knowledge-tabs">
    <li class="nav-item">
      <a class="nav-link active" data-tab="biz" href="#">
        <i class="ti ti-brain me-1"></i>業務知識庫
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-tab="product" href="#">
        <i class="ti ti-fish me-1"></i>產品品牌知識庫
      </a>
    </li>
  </ul>

  <!-- ── Business knowledge panel ── -->
  <div id="panel-biz">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="row g-2 flex-fill me-3">
        <div class="col">
          <div class="input-group">
            <span class="input-group-text"><i class="ti ti-search"></i></span>
            <input type="text" class="form-control" id="search-input" placeholder="搜尋標題或行動建議…" />
          </div>
        </div>
        <div class="col-auto">
          <select class="form-select" id="domain-filter">
            <option value="">全部領域</option>
          </select>
        </div>
      </div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="ti ti-plus me-1"></i>新增
      </button>
    </div>

    <div class="d-flex gap-2 mb-3" id="stats-row">
      <span class="badge bg-secondary-lt text-secondary px-3 py-2">載入中…</span>
    </div>

    <div class="card">
      <div class="table-responsive">
        <table class="table table-vcenter table-hover card-table">
          <thead>
            <tr>
              <th style="width:140px">領域</th>
              <th>標題 / 洞察</th>
              <th class="d-none d-md-table-cell">行動建議</th>
              <th class="text-center d-none d-lg-table-cell" style="width:60px">分數</th>
              <th style="width:48px"></th>
            </tr>
          </thead>
          <tbody id="knowledge-tbody">
            <tr><td colspan="5" class="text-center py-4 text-muted">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── Product knowledge panel ── -->
  <div id="panel-product" style="display:none">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="row g-2 flex-fill me-3">
        <div class="col">
          <div class="input-group">
            <span class="input-group-text"><i class="ti ti-search"></i></span>
            <input type="text" class="form-control" id="prod-search" placeholder="搜尋品類、名稱或知識內容…" />
          </div>
        </div>
        <div class="col-auto">
          <select class="form-select" id="prod-source-filter">
            <option value="">全部來源</option>
            <option value="product_knowledge">商品知識卡</option>
            <option value="zukan">圖鑑生物</option>
            <option value="food_md">產業研究文件</option>
          </select>
        </div>
        <div class="col-auto">
          <select class="form-select" id="prod-cat-filter">
            <option value="">全部品類</option>
          </select>
        </div>
      </div>
    </div>
    <div class="d-flex gap-2 mb-3 flex-wrap" id="prod-stats-row">
      <span class="badge bg-secondary-lt text-secondary px-3 py-2">載入中…</span>
    </div>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-vcenter table-hover card-table">
          <thead>
            <tr>
              <th style="width:80px">來源</th>
              <th style="width:140px">品類</th>
              <th>標題 / 內容</th>
              <th class="d-none d-md-table-cell" style="width:160px">附加資訊</th>
            </tr>
          </thead>
          <tbody id="prod-tbody">
            <tr><td colspan="4" class="text-center py-4 text-muted">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── Detail offcanvas (shared) ── -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="detailDrawer" style="width:min(540px,100vw)">
    <div class="offcanvas-header border-bottom">
      <div>
        <div id="detail-source-badge"></div>
        <h5 class="offcanvas-title mt-1" id="detail-title">—</h5>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body" id="detail-body" style="overflow-y:auto">
      <div class="text-muted text-center py-4">選擇一筆記錄查看詳情</div>
    </div>
  </div>

  <!-- Add modal -->
  <div class="modal modal-blur fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">新增知識條目</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-5">
              <label class="form-label required">知識領域</label>
              <input type="text" class="form-control" id="add-domain" placeholder="例：銷售管理" list="domain-list" />
              <datalist id="domain-list"></datalist>
            </div>
            <div class="col-md-5">
              <label class="form-label required">標題</label>
              <input type="text" class="form-control" id="add-title" placeholder="書名或知識來源標題" />
            </div>
            <div class="col-md-2">
              <label class="form-label">重要度（1-5）</label>
              <input type="number" class="form-control" id="add-score" min="1" max="5" value="3" />
            </div>
            <div class="col-12">
              <label class="form-label">關鍵洞察</label>
              <textarea class="form-control" id="add-insight" rows="3" placeholder="核心研究結論或數據…"></textarea>
            </div>
            <div class="col-12">
              <label class="form-label required">對稻荷的行動建議</label>
              <textarea class="form-control" id="add-action" rows="4" placeholder="具體可執行的業務行動…"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">來源類型</label>
              <input type="text" class="form-control" id="add-source-type" placeholder="書籍 / 論文 / 報告…" />
            </div>
            <div class="col-md-6">
              <label class="form-label">標籤（逗號分隔）</label>
              <input type="text" class="form-control" id="add-tags" placeholder="收款, 應收, 月結" />
            </div>
          </div>
          <div id="add-error" class="alert alert-danger d-none mt-2"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-link me-auto" data-bs-dismiss="modal">取消</button>
          <button class="btn btn-primary" onclick="addItem()"><i class="ti ti-plus me-1"></i>建立</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit modal -->
  <div class="modal modal-blur fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">編輯知識條目</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="edit-id" />
          <div class="row g-3">
            <div class="col-md-5">
              <label class="form-label required">知識領域</label>
              <input type="text" class="form-control" id="edit-domain" list="domain-list" />
            </div>
            <div class="col-md-5">
              <label class="form-label required">標題</label>
              <input type="text" class="form-control" id="edit-title" />
            </div>
            <div class="col-md-2">
              <label class="form-label">重要度（1-5）</label>
              <input type="number" class="form-control" id="edit-score" min="1" max="5" />
            </div>
            <div class="col-12">
              <label class="form-label">關鍵洞察</label>
              <textarea class="form-control" id="edit-insight" rows="3"></textarea>
            </div>
            <div class="col-12">
              <label class="form-label required">對稻荷的行動建議</label>
              <textarea class="form-control" id="edit-action" rows="4"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">來源類型</label>
              <input type="text" class="form-control" id="edit-source-type" />
            </div>
            <div class="col-md-6">
              <label class="form-label">標籤（逗號分隔）</label>
              <input type="text" class="form-control" id="edit-tags" />
            </div>
          </div>
          <div id="edit-error" class="alert alert-danger d-none mt-2"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-danger me-auto" onclick="deleteItem()"><i class="ti ti-trash me-1"></i>刪除</button>
          <button class="btn btn-link" data-bs-dismiss="modal">取消</button>
          <button class="btn btn-primary" onclick="saveEdit()">儲存</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let allItems = [], filtered = [], currentSearch = '', currentDomain = '';
    let searchTimer = null;

    const DOMAIN_COLORS = {
      '銷售管理': 'blue', '應收帳款管理': 'red', '市場學': 'purple',
      '日本料理': 'orange', '管理會計': 'green', '行為經濟學': 'cyan',
    };

    function domainBadge(d) {
      const color = DOMAIN_COLORS[d] || 'secondary';
      return `<span class="badge bg-${color}-lt text-${color}">${d || '—'}</span>`;
    }

    async function load() {
      const tbody = document.getElementById('knowledge-tbody');
      tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">載入中…</td></tr>';
      try {
        const resp = await fetch('/api/knowledge?limit=100');
        if (!resp.ok) {
          const err = await resp.json().catch(() => ({}));
          tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-danger">載入失敗：${err.error || resp.status}</td></tr>`;
          return;
        }
        const data = await resp.json();
        allItems = data.items || [];
        populateDomains(allItems);
        updateStats(allItems);
        applyFilter();
      } catch (e) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-danger">網路錯誤：${e.message}</td></tr>`;
      }
    }

    function populateDomains(items) {
      const domains = [...new Set(items.map(i => i.domain).filter(Boolean))].sort();
      const sel = document.getElementById('domain-filter');
      const dl = document.getElementById('domain-list');
      domains.forEach(d => {
        if (!sel.querySelector(`option[value="${d}"]`)) {
          const o = document.createElement('option'); o.value = d; o.textContent = d; sel.appendChild(o);
        }
        if (!dl.querySelector(`option[value="${d}"]`)) {
          const o2 = document.createElement('option'); o2.value = d; dl.appendChild(o2);
        }
      });
    }

    function updateStats(items) {
      const domains = new Set(items.map(i => i.domain).filter(Boolean));
      document.getElementById('stats-row').innerHTML =
        `<span class="badge bg-blue-lt text-blue px-3 py-2">共 <b>${items.length}</b> 筆</span>
         <span class="badge bg-green-lt text-green px-3 py-2"><b>${domains.size}</b> 個領域</span>`;
    }

    function applyFilter() {
      currentDomain = document.getElementById('domain-filter').value;
      filtered = allItems.filter(item => {
        const q = currentSearch.toLowerCase();
        return (!currentDomain || item.domain === currentDomain) &&
          (!q || (item.title||'').toLowerCase().includes(q) ||
                 (item.action_for_inari||'').toLowerCase().includes(q) ||
                 (item.key_insight||'').toLowerCase().includes(q));
      });
      render();
    }

    function render() {
      const tbody = document.getElementById('knowledge-tbody');
      if (!filtered.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">無條目</td></tr>';
        return;
      }
      tbody.innerHTML = filtered.map(item => {
        const score = item.relevance_score || 3;
        const scoreStars = '★'.repeat(score) + '☆'.repeat(5 - score);
        const insight = (item.key_insight || '').slice(0, 80);
        const action = (item.action_for_inari || '').slice(0, 100);
        return `<tr style="cursor:pointer" data-item-id="${item.id}">
          <td>${domainBadge(item.domain)}</td>
          <td>
            <div class="fw-medium">${item.title || '—'}</div>
            ${insight ? `<div class="text-muted small mt-1" style="font-size:11px">${insight}${item.key_insight?.length > 80 ? '…' : ''}</div>` : ''}
          </td>
          <td class="text-muted small d-none d-md-table-cell" style="max-width:280px">
            ${action}${(item.action_for_inari||'').length > 100 ? '…' : ''}
          </td>
          <td class="text-center d-none d-lg-table-cell" style="color:#f6a623;font-size:11px">${scoreStars}</td>
          <td>
            <button class="btn btn-sm btn-ghost-secondary" onclick='event.stopPropagation();openEdit(${JSON.stringify(item)})'>
              <i class="ti ti-pencil"></i>
            </button>
          </td>
        </tr>`;
      }).join('');
    }

    window.openEdit = function(item) {
      document.getElementById('edit-id').value = item.id;
      document.getElementById('edit-domain').value = item.domain || '';
      document.getElementById('edit-title').value = item.title || '';
      document.getElementById('edit-score').value = item.relevance_score || 3;
      document.getElementById('edit-insight').value = item.key_insight || '';
      document.getElementById('edit-action').value = item.action_for_inari || '';
      document.getElementById('edit-source-type').value = item.source_type || '';
      document.getElementById('edit-tags').value = Array.isArray(item.tags) ? item.tags.join(', ') : (item.tags || '');
      document.getElementById('edit-error').classList.add('d-none');
      new bootstrap.Modal(document.getElementById('editModal')).show();
    };

    window.addItem = async function() {
      const domain = document.getElementById('add-domain').value.trim();
      const title = document.getElementById('add-title').value.trim();
      const action_for_inari = document.getElementById('add-action').value.trim();
      const errEl = document.getElementById('add-error');
      if (!domain || !title || !action_for_inari) {
        errEl.textContent = '領域、標題、行動建議為必填';
        errEl.classList.remove('d-none');
        return;
      }
      const body = {
        domain,
        title,
        action_for_inari,
        key_insight: document.getElementById('add-insight').value.trim() || null,
        source_type: document.getElementById('add-source-type').value.trim() || null,
        relevance_score: parseInt(document.getElementById('add-score').value) || 3,
        tags: document.getElementById('add-tags').value.split(',').map(t => t.trim()).filter(Boolean),
      };
      const resp = await fetch('/api/knowledge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await resp.json();
      if (!data.ok && !data.id) {
        errEl.textContent = data.error || '建立失敗';
        errEl.classList.remove('d-none');
        return;
      }
      bootstrap.Modal.getInstance(document.getElementById('addModal'))?.hide();
      ['add-domain','add-title','add-insight','add-action','add-source-type','add-tags'].forEach(id => {
        document.getElementById(id).value = '';
      });
      document.getElementById('add-score').value = '3';
      errEl.classList.add('d-none');
      load();
    };

    window.saveEdit = async function() {
      const id = document.getElementById('edit-id').value;
      const domain = document.getElementById('edit-domain').value.trim();
      const title = document.getElementById('edit-title').value.trim();
      const action_for_inari = document.getElementById('edit-action').value.trim();
      const errEl = document.getElementById('edit-error');
      if (!domain || !title || !action_for_inari) {
        errEl.textContent = '領域、標題、行動建議為必填';
        errEl.classList.remove('d-none');
        return;
      }
      const body = {
        id,
        domain,
        title,
        action_for_inari,
        key_insight: document.getElementById('edit-insight').value.trim() || null,
        source_type: document.getElementById('edit-source-type').value.trim() || null,
        relevance_score: parseInt(document.getElementById('edit-score').value) || 3,
        tags: document.getElementById('edit-tags').value.split(',').map(t => t.trim()).filter(Boolean),
      };
      const resp = await fetch('/api/knowledge', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await resp.json();
      if (!data.ok) {
        errEl.textContent = data.error || '更新失敗';
        errEl.classList.remove('d-none');
        return;
      }
      bootstrap.Modal.getInstance(document.getElementById('editModal'))?.hide();
      load();
    };

    window.deleteItem = async function() {
      const id = document.getElementById('edit-id').value;
      if (!confirm('確定刪除此條目？')) return;
      await fetch(`/api/knowledge?id=${id}`, { method: 'DELETE' });
      bootstrap.Modal.getInstance(document.getElementById('editModal'))?.hide();
      load();
    };

    document.getElementById('search-input').addEventListener('input', (e) => {
      clearTimeout(searchTimer);
      const val = e.target.value;
      searchTimer = setTimeout(() => { currentSearch = val; applyFilter(); }, 300);
    });

    document.getElementById('domain-filter').addEventListener('change', applyFilter);

    load();

    // ── Product knowledge tab ────────────────────────────────────────────
    let allProdItems = [], filteredProd = [], prodSearch = '', prodCat = '', prodSource = '';
    let prodTimer = null;

    const SOURCE_LABELS = {
      product_knowledge: { label: '商品知識卡', color: 'orange' },
      zukan:             { label: '圖鑑生物',   color: 'blue'   },
      food_md:           { label: '產業研究',   color: 'green'  },
    };

    function sourceBadge(source) {
      const s = SOURCE_LABELS[source] || { label: source, color: 'secondary' };
      return `<span class="badge bg-${s.color}-lt text-${s.color}" style="white-space:nowrap">${s.label}</span>`;
    }

    async function loadProductKnowledge() {
      const tbody = document.getElementById('prod-tbody');
      try {
        const resp = await fetch('/api/product-knowledge');
        if (!resp.ok) {
          tbody.innerHTML = `<tr><td colspan="4" class="text-center py-4 text-danger">載入失敗 (${resp.status})</td></tr>`;
          return;
        }
        const { items } = await resp.json();
        allProdItems = items || [];
        populateProdCategories(allProdItems);
        updateProdStats(allProdItems);
        applyProdFilter();
      } catch (e) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center py-4 text-danger">網路錯誤：${e.message}</td></tr>`;
      }
    }

    function populateProdCategories(items) {
      const cats = [...new Set(items.map(i => i.category).filter(Boolean))].sort();
      const sel = document.getElementById('prod-cat-filter');
      // clear non-default options first to avoid duplicates on reload
      while (sel.options.length > 1) sel.remove(1);
      cats.forEach(c => {
        const o = document.createElement('option'); o.value = c; o.textContent = c; sel.appendChild(o);
      });
    }

    function updateProdStats(items) {
      const total = items.length;
      const cats = new Set(items.map(i => i.category).filter(Boolean));
      const pkCount = items.filter(i => i.source === 'product_knowledge').length;
      const zukanCount = items.filter(i => i.source === 'zukan').length;
      const foodCount = items.filter(i => i.source === 'food_md').length;
      document.getElementById('prod-stats-row').innerHTML =
        `<span class="badge bg-secondary-lt text-secondary px-3 py-2">共 <b>${total}</b> 筆</span>
         <span class="badge bg-orange-lt text-orange px-3 py-2">商品知識卡 <b>${pkCount}</b></span>
         <span class="badge bg-blue-lt text-blue px-3 py-2">圖鑑生物 <b>${zukanCount}</b></span>
         <span class="badge bg-green-lt text-green px-3 py-2">產業研究 <b>${foodCount}</b></span>
         <span class="badge bg-purple-lt text-purple px-3 py-2"><b>${cats.size}</b> 個品類</span>`;
    }

    function applyProdFilter() {
      prodCat = document.getElementById('prod-cat-filter').value;
      prodSource = document.getElementById('prod-source-filter').value;
      filteredProd = allProdItems.filter(item => {
        const q = prodSearch.toLowerCase();
        return (!prodSource || item.source === prodSource) &&
          (!prodCat || item.category === prodCat) &&
          (!q || (item.category || '').toLowerCase().includes(q) ||
                 (item.title || '').toLowerCase().includes(q) ||
                 (item.content || '').toLowerCase().includes(q) ||
                 (item.extra || '').toLowerCase().includes(q));
      });
      renderProdTable();
    }

    function renderProdTable() {
      const tbody = document.getElementById('prod-tbody');
      if (!filteredProd.length) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">無資料</td></tr>';
        return;
      }
      tbody.innerHTML = filteredProd.map(item => {
        const excerpt = (item.content || '').slice(0, 120);
        const hasMore = (item.content || '').length > 120;
        return `<tr style="cursor:pointer" data-item-id="${item.id}">
          <td>${sourceBadge(item.source)}</td>
          <td>${item.category ? `<span class="badge bg-secondary-lt text-secondary">${item.category}</span>` : '—'}</td>
          <td>
            <div class="fw-medium">${item.title || '—'}</div>
            ${excerpt ? `<div class="text-muted small mt-1" style="font-size:11px">${excerpt}${hasMore ? '…' : ''}</div>` : ''}
          </td>
          <td class="text-muted small d-none d-md-table-cell" style="font-size:11px;max-width:160px;word-break:break-word">${item.extra || '—'}</td>
        </tr>`;
      }).join('');
    }

    // ── Detail drawer ────────────────────────────────────────────────────
    const detailDrawer = new bootstrap.Offcanvas(document.getElementById('detailDrawer'));

    function tags(arr) {
      if (!arr || !arr.length) return '<span class="text-muted">—</span>';
      return arr.map(v => `<span class="badge bg-secondary-lt text-secondary me-1">${v}</span>`).join('');
    }
    function field(label, val) {
      if (!val) return '';
      return `<div class="mb-3"><div class="text-muted small mb-1">${label}</div><div>${val}</div></div>`;
    }

    async function openProductDetail(itemId) {
      document.getElementById('detail-body').innerHTML = '<div class="text-center py-4 text-muted">載入中…</div>';
      detailDrawer.show();
      try {
        const resp = await fetch(`/api/product-knowledge?id=${itemId}`);
        const data = await resp.json();
        const r = data.item;
        if (!r) { document.getElementById('detail-body').innerHTML = '<div class="alert alert-danger">找不到資料</div>'; return; }
        renderDetail(itemId, r);
      } catch(e) {
        document.getElementById('detail-body').innerHTML = `<div class="alert alert-danger">${e.message}</div>`;
      }
    }

    function renderDetail(itemId, r) {
      const src = itemId.split('_')[0];
      const srcInfo = SOURCE_LABELS[src === 'pk' ? 'product_knowledge' : src === 'food' ? 'food_md' : 'zukan'] || { label: src, color: 'secondary' };
      document.getElementById('detail-source-badge').innerHTML = `<span class="badge bg-${srcInfo.color}-lt text-${srcInfo.color}">${srcInfo.label}</span>`;

      let html = '';
      if (src === 'pk') {
        document.getElementById('detail-title').textContent = r.item_name || r.item_code || '—';
        const seasons = Array.isArray(r.peak_seasons) ? r.peak_seasons : [];
        const origins = Array.isArray(r.origin_regions) ? r.origin_regions : [];
        const suppliers = Array.isArray(r.key_suppliers) ? r.key_suppliers : [];
        const restTypes = Array.isArray(r.restaurant_types) ? r.restaurant_types : [];
        html = `
          ${field('品類 / 子品類', [r.category, r.subcategory].filter(Boolean).join(' › '))}
          ${field('價格定位', r.price_tier === 'premium' ? '🏆 高端' : r.price_tier === 'mid' ? '中端' : r.price_tier === 'economy' ? '經濟' : r.price_tier)}
          ${field('信心度', r.confidence)}
          ${r.notes ? `<div class="mb-3"><div class="text-muted small mb-1">知識備注</div><div class="p-2 bg-light rounded small">${r.notes}</div></div>` : ''}
          ${seasons.length ? `<div class="mb-3"><div class="text-muted small mb-1">旺季</div>${tags(seasons)}</div>` : ''}
          ${origins.length ? `<div class="mb-3"><div class="text-muted small mb-1">產地</div>${tags(origins)}</div>` : ''}
          ${suppliers.length ? `<div class="mb-3"><div class="text-muted small mb-1">主要供應商</div>${tags(suppliers)}</div>` : ''}
          ${restTypes.length ? `<div class="mb-3"><div class="text-muted small mb-1">適合餐廳類型</div>${tags(restTypes)}</div>` : ''}
          ${r.grade_system ? `<div class="mb-3"><div class="text-muted small mb-1">等級體系</div><pre class="small bg-light p-2 rounded">${JSON.stringify(r.grade_system, null, 2)}</pre></div>` : ''}`;
      } else if (src === 'zukan') {
        document.getElementById('detail-title').textContent = r.name_ja || '—';
        html = `
          ${field('學名', `<em>${r.scientific_name || '—'}</em>`)}
          ${field('英文 / 外文名', r.foreign_names)}
          ${field('分類', r.category)}
          ${r.taste ? `<div class="mb-3"><div class="text-muted small mb-1">味道 / 食味</div><div class="small">${r.taste}</div></div>` : ''}
          ${r.season ? `<div class="mb-3"><div class="text-muted small mb-1">季節 / 旺季</div><div class="small">${r.season}</div></div>` : ''}
          ${r.market_note ? `<div class="mb-3"><div class="text-muted small mb-1">市場備注</div><div class="small">${r.market_note}</div></div>` : ''}
          ${r.selection ? `<div class="mb-3"><div class="text-muted small mb-1">挑選方法</div><div class="small">${r.selection}</div></div>` : ''}
          ${r.cooking_methods ? `<div class="mb-3"><div class="text-muted small mb-1">料理方法</div><div class="small">${r.cooking_methods}</div></div>` : ''}
          ${r.nutrition ? `<div class="mb-3"><div class="text-muted small mb-1">營養成分</div><div class="small">${r.nutrition}</div></div>` : ''}
          ${r.origin_natural ? `<div class="mb-3"><div class="text-muted small mb-1">天然產地</div><div class="small">${r.origin_natural}</div></div>` : ''}
          ${r.origin_farmed ? `<div class="mb-3"><div class="text-muted small mb-1">養殖產地</div><div class="small">${r.origin_farmed}</div></div>` : ''}
          ${field('重要度', r.importance)} ${field('知識等級', r.knowledge_level)}
          ${r.url ? `<div class="mt-3"><a href="${r.url}" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="ti ti-external-link me-1"></i>查看圖鑑原頁</a></div>` : ''}`;
      } else {
        document.getElementById('detail-title').textContent = r.title || r.filename || '—';
        const content = r.content || '';
        html = `
          ${field('品類', r.category)}
          ${field('來源資料夾', r.source_dir)}
          ${field('檔案名稱', r.filename)}
          <div class="mb-3"><div class="text-muted small mb-1">全文內容</div>
            <div class="small p-3 bg-light rounded" style="white-space:pre-wrap;max-height:60vh;overflow-y:auto;font-family:monospace;font-size:11px">${content.replace(/</g,'&lt;')}</div>
          </div>`;
      }
      document.getElementById('detail-body').innerHTML = html || '<div class="text-muted">無詳細資料</div>';
    }

    // Click delegation on product table
    document.getElementById('prod-tbody').addEventListener('click', (e) => {
      const row = e.target.closest('tr[data-item-id]');
      if (row) openProductDetail(row.dataset.itemId);
    });

    // Click delegation on business knowledge table — show full content
    document.getElementById('knowledge-tbody').addEventListener('click', (e) => {
      const row = e.target.closest('tr[data-item-id]');
      if (!row) return;
      const item = allItems.find(i => String(i.id) === row.dataset.itemId);
      if (!item) return;
      const srcInfo = { label: item.domain || '業務知識', color: 'purple' };
      document.getElementById('detail-source-badge').innerHTML = `<span class="badge bg-${srcInfo.color}-lt text-${srcInfo.color}">${srcInfo.label}</span>`;
      document.getElementById('detail-title').textContent = item.title || '—';
      const scoreStars = '★'.repeat(item.relevance_score||3) + '☆'.repeat(5-(item.relevance_score||3));
      const tagsArr = Array.isArray(item.tags) ? item.tags : [];
      document.getElementById('detail-body').innerHTML = `
        ${item.key_insight ? `<div class="mb-3"><div class="text-muted small mb-1">關鍵洞察</div><div class="small p-2 bg-light rounded">${item.key_insight}</div></div>` : ''}
        ${item.action_for_inari ? `<div class="mb-3"><div class="text-muted small mb-1">對稻荷的行動建議</div><div class="small p-2 bg-primary-lt rounded">${item.action_for_inari}</div></div>` : ''}
        ${field('來源類型', item.source_type)}
        <div class="mb-3"><div class="text-muted small mb-1">重要度</div><span style="color:#f6a623">${scoreStars}</span></div>
        ${tagsArr.length ? `<div class="mb-3"><div class="text-muted small mb-1">標籤</div>${tags(tagsArr)}</div>` : ''}`;
      detailDrawer.show();
    });

    document.getElementById('prod-search').addEventListener('input', (e) => {
      clearTimeout(prodTimer);
      prodTimer = setTimeout(() => { prodSearch = e.target.value; applyProdFilter(); }, 300);
    });
    document.getElementById('prod-cat-filter').addEventListener('change', applyProdFilter);
    document.getElementById('prod-source-filter').addEventListener('change', applyProdFilter);

    // ── Tab switching ────────────────────────────────────────────────────
    let prodLoaded = false;
    document.getElementById('knowledge-tabs').addEventListener('click', (e) => {
      const link = e.target.closest('a[data-tab]');
      if (!link) return;
      e.preventDefault();
      const tab = link.dataset.tab;
      document.querySelectorAll('#knowledge-tabs .nav-link').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
      document.getElementById('panel-biz').style.display = tab === 'biz' ? '' : 'none';
      document.getElementById('panel-product').style.display = tab === 'product' ? '' : 'none';
      if (tab === 'product' && !prodLoaded) { prodLoaded = true; loadProductKnowledge(); }
    });
  </script>
</AdminLayout>
