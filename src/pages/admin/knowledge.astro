---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="知識庫" active="knowledge" pageTitle="知識庫管理">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="row g-2 flex-fill me-3">
      <div class="col">
        <div class="input-group">
          <span class="input-group-text"><i class="ti ti-search"></i></span>
          <input type="text" class="form-control" id="search-input" placeholder="搜尋知識條目…" oninput="debounceSearch(this.value)" />
        </div>
      </div>
      <div class="col-auto">
        <select class="form-select" id="cat-filter" onchange="applyFilter()">
          <option value="">全部分類</option>
        </select>
      </div>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
      <i class="ti ti-plus me-1"></i>新增
    </button>
  </div>

  <!-- Stats -->
  <div class="d-flex gap-2 mb-3" id="stats-row">
    <span class="badge bg-secondary-lt text-secondary px-3 py-2">載入中…</span>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>標題</th>
            <th>分類</th>
            <th class="d-none d-md-table-cell">摘要</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="knowledge-tbody">
          <tr><td colspan="4" class="text-center py-4 text-muted">載入中…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add modal -->
  <div class="modal modal-blur fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">新增知識條目</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-8"><label class="form-label required">標題（中文）</label><input type="text" class="form-control" id="add-title" /></div>
            <div class="col-md-4"><label class="form-label required">分類</label><input type="text" class="form-control" id="add-category" placeholder="例：銷售管理" /></div>
            <div class="col-12"><label class="form-label">摘要</label><textarea class="form-control" id="add-summary" rows="2"></textarea></div>
            <div class="col-12"><label class="form-label">正文內容</label><textarea class="form-control" id="add-content" rows="5"></textarea></div>
            <div class="col-md-4"><label class="form-label">標籤（逗號分隔）</label><input type="text" class="form-control" id="add-tags" /></div>
            <div class="col-md-4"><label class="form-label">重要度（1-5）</label><input type="number" class="form-control" id="add-importance" min="1" max="5" value="3" /></div>
          </div>
          <div id="add-error" class="alert alert-danger d-none mt-2"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-link me-auto" data-bs-dismiss="modal">取消</button>
          <button class="btn btn-primary" onclick="addItem()"><i class="ti ti-plus me-1"></i>建立</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit modal -->
  <div class="modal modal-blur fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">編輯知識條目</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <input type="hidden" id="edit-id" />
          <div class="row g-3">
            <div class="col-md-8"><label class="form-label required">標題（中文）</label><input type="text" class="form-control" id="edit-title" /></div>
            <div class="col-md-4"><label class="form-label required">分類</label><input type="text" class="form-control" id="edit-category" /></div>
            <div class="col-12"><label class="form-label">摘要</label><textarea class="form-control" id="edit-summary" rows="2"></textarea></div>
            <div class="col-12"><label class="form-label">正文內容</label><textarea class="form-control" id="edit-content" rows="5"></textarea></div>
            <div class="col-md-4"><label class="form-label">標籤</label><input type="text" class="form-control" id="edit-tags" /></div>
            <div class="col-md-4"><label class="form-label">重要度（1-5）</label><input type="number" class="form-control" id="edit-importance" min="1" max="5" /></div>
          </div>
          <div id="edit-error" class="alert alert-danger d-none mt-2"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-danger me-auto" onclick="deleteItem()"><i class="ti ti-trash me-1"></i>刪除</button>
          <button class="btn btn-link" data-bs-dismiss="modal">取消</button>
          <button class="btn btn-primary" onclick="saveEdit()">儲存</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let allItems = [], filtered = [], currentSearch = '', currentCat = '';
    let searchTimer = null;

    async function load() {
      const resp = await fetch('/api/knowledge?limit=200');
      if (!resp.ok) return;
      const data = await resp.json();
      allItems = data.items || [];
      populateCategories(allItems);
      updateStats(allItems);
      applyFilter();
    }

    function populateCategories(items) {
      const cats = [...new Set(items.map(i => i.category).filter(Boolean))].sort();
      const sel = document.getElementById('cat-filter');
      cats.forEach(c => {
        if (!sel.querySelector(`option[value="${c}"]`)) {
          const o = document.createElement('option'); o.value = c; o.textContent = c; sel.appendChild(o);
        }
      });
    }

    function updateStats(items) {
      const cats = new Set(items.map(i => i.category).filter(Boolean));
      document.getElementById('stats-row').innerHTML =
        `<span class="badge bg-blue-lt text-blue px-3 py-2">共 <b>${items.length}</b> 筆</span>
         <span class="badge bg-green-lt text-green px-3 py-2"><b>${cats.size}</b> 個分類</span>`;
    }

    function applyFilter() {
      currentCat = document.getElementById('cat-filter').value;
      filtered = allItems.filter(item => {
        const q = currentSearch.toLowerCase();
        return (!currentCat || item.category === currentCat) &&
          (!q || (item.title_zh||'').toLowerCase().includes(q) || (item.summary||'').toLowerCase().includes(q));
      });
      render();
    }

    function render() {
      const tbody = document.getElementById('knowledge-tbody');
      if (!filtered.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">無條目</td></tr>'; return; }
      tbody.innerHTML = filtered.map(item => {
        const stars = '★'.repeat(item.importance_score || 3) + '☆'.repeat(5 - (item.importance_score || 3));
        return `<tr>
          <td class="fw-medium">${item.title_zh || '—'}</td>
          <td><span class="badge bg-blue-lt text-blue">${item.category || '—'}</span></td>
          <td class="text-muted small d-none d-md-table-cell" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.summary || '—'}</td>
          <td class="text-end">
            <button class="btn btn-sm btn-outline-secondary" onclick='openEdit(${JSON.stringify(item)})'>
              <i class="ti ti-pencil"></i>
            </button>
          </td>
        </tr>`;
      }).join('');
    }

    window.openEdit = function(item) {
      document.getElementById('edit-id').value = item.id;
      document.getElementById('edit-title').value = item.title_zh || '';
      document.getElementById('edit-category').value = item.category || '';
      document.getElementById('edit-summary').value = item.summary || '';
      document.getElementById('edit-content').value = item.content || '';
      document.getElementById('edit-tags').value = (item.tags || []).join(', ');
      document.getElementById('edit-importance').value = item.importance_score || 3;
      document.getElementById('edit-error').classList.add('d-none');
      new bootstrap.Modal(document.getElementById('editModal')).show();
    };

    window.addItem = async function() {
      const title_zh = document.getElementById('add-title').value.trim();
      const category = document.getElementById('add-category').value.trim();
      const errEl = document.getElementById('add-error');
      if (!title_zh || !category) { errEl.textContent = '標題和分類為必填'; errEl.classList.remove('d-none'); return; }
      const body = {
        title_zh,
        category,
        summary: document.getElementById('add-summary').value.trim(),
        content: document.getElementById('add-content').value.trim(),
        tags: document.getElementById('add-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
        importance_score: parseInt(document.getElementById('add-importance').value) || 3,
      };
      const resp = await fetch('/api/knowledge', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
      const data = await resp.json();
      if (!data.ok && !data.id) { errEl.textContent = data.error || '建立失敗'; errEl.classList.remove('d-none'); return; }
      bootstrap.Modal.getInstance(document.getElementById('addModal'))?.hide();
      ['add-title','add-category','add-summary','add-content','add-tags'].forEach(id => document.getElementById(id).value = '');
      errEl.classList.add('d-none');
      load();
    };

    window.saveEdit = async function() {
      const id = document.getElementById('edit-id').value;
      const errEl = document.getElementById('edit-error');
      const body = {
        id,
        title_zh: document.getElementById('edit-title').value.trim(),
        category: document.getElementById('edit-category').value.trim(),
        summary: document.getElementById('edit-summary').value.trim(),
        content: document.getElementById('edit-content').value.trim(),
        tags: document.getElementById('edit-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
        importance_score: parseInt(document.getElementById('edit-importance').value) || 3,
      };
      const resp = await fetch('/api/knowledge', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
      const data = await resp.json();
      if (!data.ok) { errEl.textContent = data.error || '更新失敗'; errEl.classList.remove('d-none'); return; }
      bootstrap.Modal.getInstance(document.getElementById('editModal'))?.hide();
      load();
    };

    window.deleteItem = async function() {
      const id = document.getElementById('edit-id').value;
      if (!confirm('確定刪除此條目？')) return;
      await fetch(`/api/knowledge?id=${id}`, { method:'DELETE' });
      bootstrap.Modal.getInstance(document.getElementById('editModal'))?.hide();
      load();
    };

    window.debounceSearch = function(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => { currentSearch = val; applyFilter(); }, 300);
    };

    load();
  </script>
</AdminLayout>
