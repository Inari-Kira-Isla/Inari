---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="收款管理" active="collections" pageTitle="收款管理" pageSubtitle="每日收款工作板 + 月度槽位進度">

<style>
  .slot-card { cursor: default; transition: box-shadow .15s; }
  .slot-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.1); }
  .slot-amount { font-size: 1.25rem; font-weight: 700; font-family: 'IBM Plex Mono', monospace; }
  .slot-label  { font-size: .75rem; color: #6c757d; }
  .progress-thin { height: 4px; border-radius: 2px; }
  .tab-badge { font-size: .7rem; padding: 1px 6px; border-radius: 10px; }
  .action-row td { vertical-align: middle; }
  .action-btn { font-size: .75rem; padding: 2px 8px; white-space: nowrap; }
  .last-action { font-size: .72rem; color: #6c757d; }
  .promised-badge { font-size: .7rem; }
  .trend-bar-wrap { display: flex; align-items: flex-end; gap: 4px; height: 60px; }
  .trend-bar { flex: 1; border-radius: 3px 3px 0 0; min-width: 8px; transition: opacity .2s; }
  .trend-bar:hover { opacity: .75; }
  /* alert banner */
  #alert-banner { display: none; }
  #alert-banner.show { display: flex; }
</style>

<!-- ZONE A: 今日警示 + 槽位進度 -->
<div id="alert-banner" class="alert alert-danger d-flex align-items-center gap-2 mb-3 py-2">
  <i class="ti ti-alert-triangle"></i>
  <span id="alert-text"></span>
</div>

<div class="row g-2 mb-3" id="slot-cards">
  <!-- 6 slot cards rendered by JS -->
  <div class="col-12 text-center text-muted py-4" id="slots-loading">載入槽位中…</div>
</div>

<!-- ZONE B: 每日工作板 -->
<div class="card mb-3">
  <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <ul class="nav nav-tabs card-header-tabs" id="work-tabs" role="tablist">
      <li class="nav-item">
        <a class="nav-link active" data-tab="cash" href="#" role="tab">
          現金/轉帳待收 <span class="badge bg-orange tab-badge ms-1" id="badge-cash">—</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-tab="monthly" href="#" role="tab">
          月結應收 <span class="badge bg-blue tab-badge ms-1" id="badge-monthly">—</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-tab="overdue" href="#" role="tab">
          逾期追收 <span class="badge bg-red tab-badge ms-1" id="badge-overdue">—</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-tab="cheques" href="#" role="tab">
          支票到期 <span class="badge bg-purple tab-badge ms-1" id="badge-cheques">—</span>
        </a>
      </li>
    </ul>
    <span class="text-muted small" id="data-freshness"></span>
  </div>
  <div class="card-body p-0">
    <div id="tab-content" class="table-responsive">
      <div class="text-center text-muted py-4" id="tab-loading">載入中…</div>
    </div>
  </div>
</div>

<!-- ZONE C: 近3月趨勢（收合） -->
<div class="accordion" id="trend-accordion">
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed py-2" type="button"
              data-bs-toggle="collapse" data-bs-target="#trend-body">
        <i class="ti ti-chart-bar me-2 text-muted"></i>
        <span class="small fw-semibold">近3個月收款趨勢</span>
      </button>
    </h2>
    <div id="trend-body" class="accordion-collapse collapse">
      <div class="accordion-body pt-2" id="trend-content">
        <div class="text-muted small text-center py-3">展開後載入…</div>
      </div>
    </div>
  </div>
</div>

<!-- 追收記錄 Modal -->
<div class="modal fade" id="actionModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title small fw-semibold">📝 追收記錄</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-2">
          <div class="fw-semibold small" id="modal-customer"></div>
          <div class="text-muted" style="font-size:.75rem" id="modal-outstanding"></div>
        </div>
        <div class="mb-2">
          <label class="form-label form-label-sm mb-1">追收方式 <span class="text-red">*</span></label>
          <div class="d-flex gap-2 flex-wrap">
            <label class="form-check form-check-inline"><input class="form-check-input" type="radio" name="method" value="電話"> <span class="form-check-label small">📞 電話</span></label>
            <label class="form-check form-check-inline"><input class="form-check-input" type="radio" name="method" value="WhatsApp"> <span class="form-check-label small">💬 WhatsApp</span></label>
            <label class="form-check form-check-inline"><input class="form-check-input" type="radio" name="method" value="Telegram"> <span class="form-check-label small">✈️ Telegram</span></label>
            <label class="form-check form-check-inline"><input class="form-check-input" type="radio" name="method" value="當面"> <span class="form-check-label small">🤝 當面</span></label>
          </div>
        </div>
        <div class="mb-2">
          <label class="form-label form-label-sm mb-1">備注（選填）</label>
          <textarea id="modal-notes" class="form-control form-control-sm" rows="2" placeholder="追收情況、客戶回覆…"></textarea>
        </div>
        <div class="mb-1">
          <label class="form-label form-label-sm mb-1">承諾付款日（選填）</label>
          <input type="date" id="modal-promised" class="form-control form-control-sm">
        </div>
      </div>
      <div class="modal-footer py-2">
        <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">取消</button>
        <button class="btn btn-sm btn-primary" id="modal-save">儲存記錄</button>
      </div>
    </div>
  </div>
</div>

<script>
const fmt = (n) => 'MOP ' + Number(n).toLocaleString('zh-HK', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
const fmtDate = (d) => d ? d.slice(0, 10) : '—';
const methodIcon = { '電話': '📞', 'WhatsApp': '💬', 'Telegram': '✈️', '當面': '🤝' };

let _daily = null;
let _modalData = {};
let _activeTab = 'cash';

// ── ZONE A: Slot cards (from /api/admin/collections) ──
async function loadSlots() {
  try {
    const res = await fetch('/api/admin/collections');
    if (!res.ok) throw new Error(await res.text());
    const data = await res.json();

    const slots = data.slots || [];
    const alertItems = [];
    if (data.overdue?.count > 0) alertItems.push(`逾期 ${data.overdue.count} 客 ${fmt(data.overdue.total)}`);
    if (data.cheque_pending?.count > 0) alertItems.push(`支票即將到期 ${data.cheque_pending.count} 張`);

    if (alertItems.length) {
      const banner = document.getElementById('alert-banner');
      document.getElementById('alert-text').textContent = alertItems.join('　|　');
      banner.classList.add('show');
    }

    const slotColors = { '15號': 'blue', '25號': 'cyan', '次結': 'green', '延後2月': 'yellow', '岫收': 'orange', '現金即收': 'pink', '未設': 'secondary' };
    const cards = document.getElementById('slot-cards');
    cards.innerHTML = slots.map(s => {
      const pct = s.total > 0 ? Math.round((s.collected || 0) / s.total * 100) : 0;
      const color = slotColors[s.slot] || 'secondary';
      return `
        <div class="col-6 col-md-2">
          <div class="card card-sm slot-card">
            <div class="card-body py-2 px-3">
              <div class="slot-label mb-1">${s.slot}</div>
              <div class="slot-amount text-${color}">${fmt(s.collectible || 0)}</div>
              <div class="text-muted" style="font-size:.7rem">${s.count} 客</div>
              <div class="progress progress-thin mt-2 bg-${color}-lt">
                <div class="progress-bar bg-${color}" style="width:${pct}%"></div>
              </div>
              <div class="text-muted mt-1" style="font-size:.68rem">已收 ${pct}%</div>
            </div>
          </div>
        </div>`;
    }).join('');
    document.getElementById('slots-loading')?.remove();
  } catch (e) {
    document.getElementById('slots-loading').innerHTML = `<span class="text-danger small">⚠ 槽位載入失敗：${e.message}</span>`;
  }
}

// ── ZONE B: Daily work tabs ──
async function loadDaily() {
  try {
    const res = await fetch('/api/admin/collections/daily');
    if (!res.ok) throw new Error(await res.text());
    _daily = await res.json();

    document.getElementById('badge-cash').textContent = _daily.cash.count;
    document.getElementById('badge-monthly').textContent = _daily.monthly.count;
    document.getElementById('badge-overdue').textContent = _daily.overdue.count;
    document.getElementById('badge-cheques').textContent = _daily.cheques.count;

    if (_daily.meta?.latest_invoice) {
      document.getElementById('data-freshness').textContent = `最新發票：${fmtDate(_daily.meta.latest_invoice)}`;
    }
    renderTab(_activeTab);
  } catch (e) {
    document.getElementById('tab-loading').innerHTML = `<div class="text-danger small p-3">⚠ 載入失敗：${e.message}</div>`;
  }
}

function renderTab(tab) {
  _activeTab = tab;
  document.querySelectorAll('#work-tabs .nav-link').forEach(el => {
    el.classList.toggle('active', el.dataset.tab === tab);
  });
  const wrap = document.getElementById('tab-content');
  if (!_daily) return;

  if (tab === 'cheques') {
    wrap.innerHTML = renderChequesTable(_daily.cheques.rows);
    return;
  }
  const rows = _daily[tab]?.rows || [];
  wrap.innerHTML = renderFollowupTable(rows, tab);
}

function renderFollowupTable(rows, tab) {
  if (!rows.length) return `<div class="text-muted text-center py-4 small">暫無記錄</div>`;
  const bucketBadge = { '本月到期': 'bg-blue-lt text-blue', '逾期·要追': 'bg-red-lt text-red', '現金·需即收': 'bg-orange-lt text-orange' };
  return `
    <table class="table table-sm table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>客戶</th>
          <th class="d-none d-md-table-cell">槽位</th>
          <th class="d-none d-md-table-cell">業務</th>
          <th class="text-end">未收</th>
          <th class="d-none d-sm-table-cell">上次追收</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        ${rows.map(r => `
          <tr class="action-row">
            <td>
              <a href="/admin/customers/${encodeURIComponent(r.canon_code)}" class="fw-semibold text-decoration-none small">${r.customer_name || r.canon_code}</a>
              ${r.promised_date ? `<br><span class="badge promised-badge bg-green-lt text-green">承諾 ${fmtDate(r.promised_date)}</span>` : ''}
            </td>
            <td class="d-none d-md-table-cell">
              <span class="badge ${bucketBadge[r.bucket] || 'bg-secondary-lt'} tab-badge">${r.slot}</span>
            </td>
            <td class="d-none d-md-table-cell small text-muted">${r.salesperson || '—'}</td>
            <td class="text-end fw-semibold font-mono small">${fmt(r.outstanding)}</td>
            <td class="d-none d-sm-table-cell last-action">
              ${r.last_action_date
                ? `${methodIcon[r.last_action_method] || ''}${fmtDate(r.last_action_date)}<br><span class="text-muted">${r.last_action_notes || ''}</span>`
                : '<span class="text-muted">未追收</span>'}
            </td>
            <td>
              <button class="btn btn-sm btn-outline-primary action-btn"
                onclick="openActionModal(${JSON.stringify(JSON.stringify({canon_code:r.canon_code,customer_name:r.customer_name,outstanding:r.outstanding}))})">
                📝
              </button>
            </td>
          </tr>`).join('')}
      </tbody>
      <tfoot class="table-light">
        <tr>
          <td colspan="3" class="small text-muted">共 ${rows.length} 客</td>
          <td class="text-end fw-bold font-mono small">${fmt(rows.reduce((s, r) => s + Number(r.outstanding), 0))}</td>
          <td colspan="2"></td>
        </tr>
      </tfoot>
    </table>`;
}

function renderChequesTable(rows) {
  if (!rows.length) return `<div class="text-muted text-center py-4 small">未來30天無待兌現支票</div>`;
  const today = new Date().toISOString().slice(0, 10);
  return `
    <table class="table table-sm table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>客戶</th>
          <th>支票號</th>
          <th class="d-none d-md-table-cell">銀行</th>
          <th>到期日</th>
          <th class="text-end">金額</th>
        </tr>
      </thead>
      <tbody>
        ${rows.map(r => {
          const due = r.cheque_due_date || '';
          const urgent = due <= today ? 'table-danger' : (due <= new Date(Date.now() + 7*86400000).toISOString().slice(0,10) ? 'table-warning' : '');
          return `
            <tr class="${urgent}">
              <td class="small fw-semibold">${r.customer_name || r.customer_code}</td>
              <td class="font-mono small">${r.cheque_no || '—'}</td>
              <td class="d-none d-md-table-cell small text-muted">${r.cheque_bank || '—'}</td>
              <td class="small">${fmtDate(due)}</td>
              <td class="text-end font-mono small fw-semibold">${fmt(r.amount)}</td>
            </tr>`;
        }).join('')}
      </tbody>
      <tfoot class="table-light">
        <tr>
          <td colspan="4" class="small text-muted">共 ${rows.length} 張</td>
          <td class="text-end fw-bold font-mono small">${fmt(rows.reduce((s, r) => s + Number(r.amount), 0))}</td>
        </tr>
      </tfoot>
    </table>`;
}

// ── ZONE C: Trend (lazy load) ──
async function loadTrend() {
  const content = document.getElementById('trend-content');
  if (content.dataset.loaded) return;
  content.dataset.loaded = '1';
  try {
    const res = await fetch('/api/admin/collections');
    if (!res.ok) throw new Error(await res.text());
    const data = await res.json();
    const months = data.trend || [];
    if (!months.length) { content.innerHTML = '<div class="text-muted small">無趨勢數據</div>'; return; }

    const maxAmt = Math.max(...months.map(m => m.total || 0), 1);
    const ptColors = { '現金': '#f76707', '轉帳': '#1c7ed6', '月結': '#2f9e44', '月結核銷': '#2f9e44', '支票': '#7048e8' };
    const ptypes = [...new Set(months.flatMap(m => Object.keys(m.by_type || {})))];

    content.innerHTML = `
      <div class="row g-3">
        <div class="col-12">
          <div class="small fw-semibold mb-2">各月收款總額</div>
          <div class="trend-bar-wrap">
            ${months.map(m => {
              const pct = Math.round((m.total || 0) / maxAmt * 100);
              return `<div class="trend-bar bg-blue" style="height:${Math.max(pct,4)}%" title="${m.ym}: ${fmt(m.total)}"></div>`;
            }).join('')}
          </div>
          <div class="d-flex gap-1 mt-1">
            ${months.map(m => `<div class="flex-1 text-center text-muted" style="font-size:.65rem;min-width:8px">${(m.ym||'').slice(5)}</div>`).join('')}
          </div>
        </div>
        <div class="col-12">
          <div class="d-flex flex-wrap gap-3">
            ${ptypes.map(pt => {
              const total = months.reduce((s, m) => s + (m.by_type?.[pt] || 0), 0);
              return total > 0 ? `<span class="small"><span style="color:${ptColors[pt]||'#aaa'}">■</span> ${pt}: <strong>${fmt(total)}</strong></span>` : '';
            }).join('')}
          </div>
        </div>
      </div>`;
  } catch (e) {
    content.innerHTML = `<div class="text-danger small">⚠ 趨勢載入失敗：${e.message}</div>`;
  }
}

// ── Action Modal ──
function openActionModal(jsonStr) {
  const d = JSON.parse(jsonStr);
  _modalData = d;
  document.getElementById('modal-customer').textContent = d.customer_name || d.canon_code;
  document.getElementById('modal-outstanding').textContent = `未收：${fmt(d.outstanding)}`;
  document.getElementById('modal-notes').value = '';
  document.getElementById('modal-promised').value = '';
  document.querySelectorAll('input[name="method"]').forEach(el => el.checked = false);
  new bootstrap.Modal(document.getElementById('actionModal')).show();
}

document.getElementById('modal-save').addEventListener('click', async () => {
  const method = document.querySelector('input[name="method"]:checked')?.value;
  if (!method) { alert('請選擇追收方式'); return; }
  const btn = document.getElementById('modal-save');
  btn.disabled = true;
  btn.textContent = '儲存中…';
  try {
    const res = await fetch('/api/admin/collections/daily', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        canon_code: _modalData.canon_code,
        customer_name: _modalData.customer_name,
        method,
        notes: document.getElementById('modal-notes').value || null,
        promised_date: document.getElementById('modal-promised').value || null,
      }),
    });
    const result = await res.json();
    if (!res.ok) throw new Error(result.error || '寫入失敗');
    bootstrap.Modal.getInstance(document.getElementById('actionModal')).hide();
    _daily = null;
    await loadDaily();
  } catch (e) {
    alert('儲存失敗：' + e.message);
  } finally {
    btn.disabled = false;
    btn.textContent = '儲存記錄';
  }
});

// ── Tab clicks ──
document.getElementById('work-tabs').addEventListener('click', e => {
  e.preventDefault();
  const tab = e.target.closest('[data-tab]')?.dataset.tab;
  if (tab) renderTab(tab);
});

// ── Trend lazy load ──
document.getElementById('trend-body').addEventListener('show.bs.collapse', loadTrend);

// ── Init ──
loadSlots();
loadDaily();
</script>
</AdminLayout>
