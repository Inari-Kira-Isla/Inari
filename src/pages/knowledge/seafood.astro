---
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>海鮮品種知識 — 稻荷知識庫</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/shop/styles.css">
    <style>
      html, body { height: 100%; max-width: none; }
      body { max-width: none; }
      .page-max { max-width: 640px; margin: 0 auto; }
      .knl-nav {
        position: sticky; top: 0; z-index: 40;
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; background: var(--paper);
        border-bottom: 1px solid var(--hairline);
      }
      .knl-back {
        display: flex; align-items: center; gap: 6px;
        font-size: 13px; font-weight: 500; color: var(--sea); text-decoration: none;
      }
      .hero {
        padding: 28px 20px;
        background: linear-gradient(160deg, oklch(22% 0.04 240), oklch(30% 0.06 232));
        color: var(--paper);
      }
      .hero-sub { font-family: var(--mono); font-size: 10px; letter-spacing: .16em; color: var(--gold); margin-bottom: 10px; }
      .hero-h1 { font-size: 24px; font-weight: 300; margin: 0 0 8px; }
      .hero-h1 strong { font-weight: 700; }

      .cat-tabs {
        display: flex; overflow-x: auto; gap: 6px; padding: 14px 20px 0;
        scrollbar-width: none;
      }
      .cat-tabs::-webkit-scrollbar { display: none; }
      .cat-tab {
        flex-shrink: 0; padding: 6px 12px; border-radius: 20px; font-size: 12px;
        font-weight: 500; border: 1px solid var(--hairline); background: var(--paper);
        cursor: pointer; transition: all .15s; white-space: nowrap;
      }
      .cat-tab.active { background: var(--sea); color: var(--paper); border-color: var(--sea); }

      .items-list { padding: 16px 20px; display: flex; flex-direction: column; gap: 0; }
      .sf-item {
        padding: 14px 0; border-bottom: 1px solid var(--hairline);
        display: flex; gap: 12px;
      }
      .sf-item:last-child { border-bottom: none; }
      .sf-cat-badge {
        padding: 3px 8px; border-radius: 20px; font-size: 9px; font-weight: 600;
        font-family: var(--mono); letter-spacing: .04em; flex-shrink: 0; height: fit-content;
        margin-top: 2px;
      }
      .sf-q { font-size: 13px; font-weight: 600; }
      .sf-a { font-size: 12px; color: var(--ink-2); line-height: 1.7; margin-top: 4px; }
      .empty { padding: 40px 20px; text-align: center; color: var(--mute); font-size: 13px; }

      /* Category badge colors */
      .cat-銷售管理 { background: var(--sea-soft); color: var(--sea-ink); }
      .cat-應收帳款 { background: var(--coral-soft); color: var(--coral-deep); }
      .cat-市場學 { background: var(--gold-soft); color: var(--gold-ink); }
      .cat-日本料理 { background: var(--leaf-soft); color: var(--leaf-ink); }
      .cat-管理會計 { background: var(--amber-soft); color: var(--amber-ink); }
      .cat-行為經濟學 { background: var(--ice-soft); color: var(--ice-ink); }
    </style>
  </head>
  <body>
    <div class="page-max">
      <nav class="knl-nav">
        <a href="/knowledge" class="knl-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="m15 18-6-6 6-6"/></svg>
          知識庫
        </a>
        <span style="font-size:13px;font-weight:600">知識條目</span>
        <a href="/shop/login" style="font-size:12px;color:var(--sea);font-weight:500;text-decoration:none">下單 →</a>
      </nav>

      <div class="hero">
        <div class="hero-sub">KNOWLEDGE ITEMS · 知識條目</div>
        <h1 class="hero-h1">銷售・採購・<br><strong>日料知識</strong>全覽。</h1>
      </div>

      <div class="cat-tabs" id="cat-tabs">
        <button class="cat-tab active" data-cat="" onclick="selectCat(this, '')">全部</button>
      </div>

      <div class="items-list" id="items-list">
        <div class="empty">載入中...</div>
      </div>
    </div>

    <script>
      let allItems: Array<{id:string;category:string;question?:string;answer:string}> = [];
      let currentCat = '';

      function getBadgeClass(cat: string) {
        return 'sf-cat-badge cat-' + cat;
      }

      function renderItems(items: typeof allItems) {
        const list = document.getElementById('items-list')!;
        if (!items.length) { list.innerHTML = '<div class="empty">本分類暫無條目</div>'; return; }
        list.innerHTML = items.map(item => `
          <div class="sf-item">
            <span class="${getBadgeClass(item.category)}">${item.category}</span>
            <div>
              ${item.question ? `<div class="sf-q">${item.question}</div>` : ''}
              <div class="sf-a">${item.answer}</div>
            </div>
          </div>`).join('');
      }

      function selectCat(btn: HTMLElement, cat: string) {
        currentCat = cat;
        document.querySelectorAll('.cat-tab').forEach(el => el.classList.remove('active'));
        btn.classList.add('active');
        renderItems(cat ? allItems.filter(i => i.category === cat) : allItems);
      }

      function buildCatTabs(items: typeof allItems) {
        const cats = [...new Set(items.map(i => i.category))];
        const tabs = document.getElementById('cat-tabs')!;
        cats.forEach(cat => {
          const btn = document.createElement('button');
          btn.className = 'cat-tab';
          btn.textContent = cat;
          btn.dataset.cat = cat;
          btn.onclick = () => selectCat(btn, cat);
          tabs.appendChild(btn);
        });
      }

      fetch('/api/knowledge')
        .then(r => r.json())
        .then(d => {
          allItems = d.items || [];
          buildCatTabs(allItems);
          renderItems(allItems);
        })
        .catch(() => {
          document.getElementById('items-list')!.innerHTML =
            '<div class="empty">載入失敗，請稍後再試</div>';
        });
    </script>
  </body>
</html>
